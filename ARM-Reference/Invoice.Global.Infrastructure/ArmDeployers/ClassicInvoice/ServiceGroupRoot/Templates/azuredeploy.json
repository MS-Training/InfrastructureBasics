{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "templatespecResourceGroupName": {
      "type": "string",
      "defaultValue": "RG-630-INV-GLOBAL-TEMPLATESPECS"  
    },
    "baseName": {
      "type": "string"
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "3 Letter Evironment Abreviation"
      }
    },
    "deploymentFlags": {
      "type": "Object",
      "metadata": {
        "description": "This is the parameter file under parameters folder"
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is the parameter file under parameters folder"
      }
    },
    "isBCDR": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Change this to true if the deployment is meant to create BCDR resources."
      }
    }
  },
  "variables": {
    "serviceLayer": "[parameters('settings').common.serviceLayer]",
    "resourceBaseName": "[tolower(concat(parameters('baseName'), parameters('environment')))]",
    "baseResourceGroupName": "[toupper(concat('RG-',parameters('settings').common.applicationId, '-', parameters('baseName'), '-', parameters('environment'), '-'))]",
    "resourceNames": {
      "serviceLayer": "[variables('serviceLayer')]",
      "baseResourceGroupName": "[variables('baseResourceGroupName')]",
      "environment": "[parameters('environment')]",
      "baseName": "[parameters('baseName')]",
      "baseTemplatePath": "/BaseTemplates/",
      "vmTemplatePath": "/VirtualMachines/",
      "componentsTemplatePath": "/Components/",
      "scriptsTemplatePath": "/Scripts/",
      "vmsConfigPath": "/VirtualMachinesConfig/",
      "installersPath": "/Installers/",
      "factoriesPath": "/Factories/",
      "modulesPath": "/CustomModules/",
      "resourceBaseName": "[tolower(concat(parameters('baseName'), parameters('environment')))]",
      "commonResourceGroupName": "[toupper(concat(variables('baseResourceGroupName'), 'COMMON-',variables('serviceLayer')))]",
      "asrResourceGroupName": "[toupper(concat(variables('baseResourceGroupName'), 'RECOVERY-',variables('serviceLayer')))]",
      "iisResourceGroupName": "[toupper(concat(variables('baseResourceGroupName'), 'IIS-',variables('serviceLayer')))]",
      "iis2ResourceGroupName": "[toupper(concat(variables('baseResourceGroupName'), 'IIS2-',variables('serviceLayer')))]",
      "CacheServicesResourceGroupName": "[toupper(concat(variables('baseResourceGroupName'), 'CACHE-',variables('serviceLayer')))]",
      "vmEncryptionKeyVaultName": "[concat(variables('resourceBaseName'), 'vmkv',tolower(variables('serviceLayer')))]",
      "automationAccountName": "[concat(variables('resourceBaseName'),'ac',tolower(variables('serviceLayer')))]",
      "storageAccountBaseName": "[concat(variables('resourceBaseName'), 'sa',tolower(variables('serviceLayer')))]",
      "diagnosysStorageAccountName": "[concat(variables('resourceBaseName'), 'sadiag',tolower(variables('serviceLayer')))]",
      "recoveryVaultName": "[concat(variables('resourceBaseName'), 'asr',tolower(variables('serviceLayer')))]",
      "appKeyVaultName": "[concat(variables('resourceBaseName'), 'appkv',tolower(variables('serviceLayer')))]",
      "nameSpaceBaseName": "[concat(variables('resourceBaseName'), 'ns',tolower(variables('serviceLayer')))]",
      "appInsightsName": "[concat(variables('resourceBaseName'), 'ai',tolower(variables('serviceLayer')))]",
      "redisCacheName": "[concat(variables('resourceBaseName'), 'rc',tolower(variables('serviceLayer')))]",
      "managedIdentityName": "[concat(variables('resourceBaseName'), 'mi',tolower(variables('serviceLayer')))]",
      "templatespecsBaseResourceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('templatespecResourceGroupName'),'/providers/Microsoft.Resources/templateSpecs/')]",
      "appKeyVaultId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',toupper(concat(variables('baseResourceGroupName'), 'COMMON-',variables('serviceLayer'))),'/providers/Microsoft.KeyVault/vaults/',variables('resourceBaseName'), 'appkv',tolower(variables('serviceLayer')))]",
      "vmKeyVaultId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',toupper(concat(variables('baseResourceGroupName'), 'COMMON-',variables('serviceLayer'))),'/providers/Microsoft.KeyVault/vaults/',variables('resourceBaseName'), 'vmkv',tolower(variables('serviceLayer')))]",
      "workspaceName": "[concat(variables('resourceBaseName'), 'la',tolower(variables('serviceLayer')))]",
      "workspaceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',toupper(concat(variables('baseResourceGroupName'), 'COMMON-',variables('serviceLayer'))),'/providers/microsoft.operationalinsights/workspaces/',variables('resourceBaseName'), 'la',tolower(variables('serviceLayer')))]",
      "appInsightsId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',toupper(concat(variables('baseResourceGroupName'), 'COMMON-', variables('serviceLayer'))),'/providers/microsoft.insights/components/', variables('resourceBaseName'), 'ai',tolower(variables('serviceLayer')))]",
      "manageIdentityResourceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',toupper(concat(variables('baseResourceGroupName'), 'COMMON-',variables('serviceLayer'))),'/providers/Microsoft.ManagedIdentity/userAssignedIdentities/',variables('resourceBaseName'), 'mi',tolower(variables('serviceLayer')))]",
      "commonVirtualNetworkResourceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('settings').common.vnetResourceGroupName,'/providers/Microsoft.Network/virtualnetworks/',parameters('settings').common.virtualNetworkName)]"
    }
  },
  "resources": [
    {
      "condition": "[not(parameters('deploymentFlags').isResourceGroupLevelDeployment)]",
      "name": "[take(concat('CreateResourceGroups-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "location": "[parameters('settings').common.region]",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'template-resourceGroup', '/versions/v1')]"
        },
        "parameters": {
          "resourceGroupNames": {
            "value": [
              "[variables('resourceNames').commonResourceGroupName]",
              "[if(parameters('deploymentFlags').deployRecoveryServices, variables('resourceNames').asrResourceGroupName,'skip1')]",
              "[if(parameters('deploymentFlags').deployIIS, variables('resourceNames').iisResourceGroupName,'skip2')]",
              "[if(parameters('deploymentFlags').deployIIS2, variables('resourceNames').iis2ResourceGroupName,'skip3')]",
              "[if(parameters('deploymentFlags').deployCacheServices, variables('resourceNames').CacheServicesResourceGroupName,'skip4')]"
            ]
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "componentId": {
            "value": "[parameters('settings').common.componentId]"
          }
        }
      }
    },
    {
      "condition": "[parameters('isBCDR')]",
      "name": "[take(concat('CreateBCDRResourceGroups-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "location": "[parameters('settings').common.region]",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'template-resourceGroup', '/versions/v1')]"
        },
        "parameters": {
          "resourceGroupNames": {
            "value": [
              "[variables('resourceNames').commonResourceGroupName]",
              "[variables('resourceNames').asrResourceGroupName]",
              "[variables('resourceNames').iisResourceGroupName]",
              "[variables('resourceNames').CacheServicesResourceGroupName]"
            ]
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "componentId": {
            "value": "[parameters('settings').common.componentId]"
          }
        }
      }
    },
    {
      "condition": "[or(parameters('deploymentFlags').isNewEnvironment,parameters('deploymentFlags').deployCommonStorage)]",
      "name": "[take(concat('DeployCommon-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('CreateResourceGroups-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-common-resources', '/versions/v1')]"
        },
        "parameters": { 
          "deploymentFlags": {
            "value": "[parameters('deploymentFlags')]"
          },
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[or(parameters('deploymentFlags').deploySecrets,parameters('deploymentFlags').setAppKeyVaultPermissions,parameters('deploymentFlags').isNewEnvironment)]",
      "name": "[take(concat('DeploySecrets-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'secret-manager', '/versions/v1')]"
        },
        "parameters": { 
          "deploymentFlags": {
            "value": "[parameters('deploymentFlags')]"
          },
          "setRBACKevaultPermissions": {
            "value": true
          },
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployAlertingMonitoring]",
      "name": "[take(concat('deployAlertingMonitoring-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-alerting-monitoring', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployAutomationBundle]",
      "name": "[take(concat('DeployAutomationBundle-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('DeploySecrets-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-automation-bundle', '/versions/v1')]"
        },
        "parameters": { 
          "serviceAccountPassword": {
            "reference": {
              "keyVault": {
                "id": "[if(parameters('deploymentFlags').isNewEnvironment,reference(take(concat('DeployCommon-',deployment().name),60)).outputs.appKeyVaultResourceId.value,if(and(not(parameters('deploymentFlags').isNewEnvironment),parameters('deploymentFlags').deploySecrets),reference(take(concat('DeploySecrets-',deployment().name),60)).outputs.appKeyVaultResourceId.value,variables('resourceNames').appKeyVaultId))]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployRecoveryServices]",
      "name": "[take(concat('deployAzureSiteRecovery-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').asrResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('DeploySecrets-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-recovery-services', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployIIS]",
      "name": "[take(concat('deployIISServers-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').iisResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('DeploySecrets-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-classicinvoice-iis-virtualmachines', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "appKeyVaultId": {
            "value": "[if(parameters('deploymentFlags').isNewEnvironment,reference(take(concat('DeployCommon-',deployment().name),60)).outputs.appKeyVaultResourceId.value,if(and(not(parameters('deploymentFlags').isNewEnvironment),parameters('deploymentFlags').deploySecrets),reference(take(concat('DeploySecrets-',deployment().name),60)).outputs.appKeyVaultResourceId.value,variables('resourceNames').appKeyVaultId))]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployIIS2]",
      "name": "[take(concat('deployIISServers2-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').iis2ResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('DeploySecrets-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-classicinvoice-iis2-virtualmachines', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "appKeyVaultId": {
            "value": "[if(parameters('deploymentFlags').isNewEnvironment,reference(take(concat('DeployCommon-',deployment().name),60)).outputs.appKeyVaultResourceId.value,if(and(not(parameters('deploymentFlags').isNewEnvironment),parameters('deploymentFlags').deploySecrets),reference(take(concat('DeploySecrets-',deployment().name),60)).outputs.appKeyVaultResourceId.value,variables('resourceNames').appKeyVaultId))]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployCacheServices]",
      "name": "[take(concat('deployCacheServices-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').CacheServicesResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('DeploySecrets-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-cache-services', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('isBCDR')]",
      "name": "[take(concat('deployBcdrResources-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[variables('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('CreateBCDRResourceGroups-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-bcdr-resources', '/versions/v1')]"
        },
        "parameters": { 
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').bcdrRebuildFailoverServers]",
      "name": "[take(concat('configureBCDRVms-',copyIndex(1),'-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "location": "[parameters('settings').common.region]",
      "copy": {
        "name": "configureBCDRVms",
        "count": "[length(parameters('settings').DRVMDetails)]"
      },
      "dependsOn": [
        "[take(concat('DeployCommon-',deployment().name),60)]",
        "[take(concat('CreateBCDRResourceGroups-',deployment().name),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Classic-bcdr-vm-configuration', '/versions/v1')]"
        },
        "parameters": { 
          "vmList": {
            "value": "[parameters('settings').DRVMDetails [copyIndex()].vmNames]"
          },
          "vmResourceGroupName": {
            "value": "[parameters('settings').DRVMDetails [copyIndex()].resourceGroupName]"
          },
          "clusterType": {
            "value": "[parameters('settings').DRVMDetails [copyIndex()].clusterType]"
          },
          "clusterRoleName": {
            "value": "[parameters('settings').DRVMDetails [copyIndex()].clusterRoleName]"
          },
          "lblname": {
            "value": "[parameters('settings').DRVMDetails [copyIndex()].lblname]"
          },
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').deployOneTimeAutomation]",
      "name": "[take(concat('OneTimeAutomation-',deployment().name),60)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "location": "[parameters('settings').common.region]",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(variables('resourceNames').templatespecsBaseResourceId, 'Global-oneTimeAutomation', '/versions/v1')]"
        },
        "parameters": { 
          "resourceNames": {
            "value": "[variables('resourceNames')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "appKeyVaultResourceId": {
      "type": "string",
      "value": "[if(parameters('deploymentFlags').isNewEnvironment,reference(take(concat('DeployCommon-',deployment().name),60)).outputs.appKeyVaultResourceId.value,if(and(not(parameters('deploymentFlags').isNewEnvironment),parameters('deploymentFlags').deploySecrets),reference(take(concat('DeploySecrets-',deployment().name),60)).outputs.appKeyVaultResourceId.value,variables('resourceNames').appKeyVaultId))]"
    }
  }
}