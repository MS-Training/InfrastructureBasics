{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cognitiveServiceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Cognitive Service Account."
      }
    },
    "openAIModels": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "The open ai models to deploy."
      }
    }
  },
  "resources": [
    {
      "copy": {
        "name": "openAIModels",
        "count": "[length(parameters('openAIModels'))]",
        "mode": "serial"
      },
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-05-01",
      "name": "[concat(parameters('cognitiveServiceName'), '/', parameters('openAIModels')[copyIndex('openAIModels')].deploymentName)]",
      "sku": {
        "name": "[parameters('openAIModels')[copyIndex('openAIModels')].sku]",
        "capacity": "[int(parameters('openAIModels')[copyIndex('openAIModels')].capacity)]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('openAIModels')[copyIndex('openAIModels')].modelName]",
          "version": "[parameters('openAIModels')[copyIndex('openAIModels')].version]"
        },
        "versionUpgradeOption": "NoAutoUpgrade",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    }
  ]
}