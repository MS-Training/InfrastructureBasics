{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cognitiveServiceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Cognitive Service Account to configure Defender for AI settings for."
      }
    },
    "managedIdentities": {
      "type": "object",
      "defaultValue": {
        "type": "SystemAssigned"
      },
      "metadata": {
        "description": "The managed identities to assign to the cognitive service."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "kind": {
      "type": "string",
      "defaultValue": "AIServices",
      "metadata": {
        "description": "The kind of the cognitive service."
      }
    },
    "apiVersion": {
      "type": "string",
      "defaultValue": "2025-06-01",
      "metadata": {
        "description": "The API version to use for the Defender for AI settings resource."
      }
    },
    "projectName": {
      "type": "string",
      "defaultValue": "Default",
      "metadata": {
        "description": "The display name of the cognitive service project."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "[parameters('apiVersion')]",
      "name": "[concat(parameters('cognitiveServiceName'), '/Default')]",
      "location": "[parameters('location')]",
      "kind": "[parameters('kind')]",
      "identity": "[parameters('managedIdentities')]",
      "properties": {
        "description": "Default project created with the resource",
        "displayName": "[parameters('projectName')]"
      }
    }
  ],
  "outputs": {}
}
