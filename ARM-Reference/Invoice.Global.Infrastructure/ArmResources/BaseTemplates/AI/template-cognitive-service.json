{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cognitiveServiceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Cognitive Service Account."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "S0",
      "allowedValues": [
        "S0"
      ]
    },
    "kind": {
      "type": "string",
      "defaultValue": "CognitiveServices",
      "metadata": {
        "description": "The kind of the cognitive service."
      }
    },
    "defaultAction": {
      "type": "string",
      "defaultValue": "Deny",
      "allowedValues": [
        "Allow",
        "Deny"
      ],
      "metadata": {
        "description": "The default action for the network ACLs."
      }
    },
    "disableLocalAuth": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to disable local auth."
      }
    },
    "ipRules": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "list of ip addressesto be added to ipRules"
      }
    },
    "managedIdentities": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "The managed identities to assign to the cognitive service."
      }
    },
    "apiProperties": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Additional API properties for the cognitive service."
      }
    },
    "allowProjectManagement": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to allow project management for the cognitive service."
      }
    },
    "defaultProjectName": {
      "type": "string",
      "defaultValue": "Default",
      "metadata": {
        "description": "The default project name for the cognitive service."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[parameters('cognitiveServiceName')]",
      "identity": "[parameters('managedIdentities')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sku')]"
      },
      "kind": "[parameters('kind')]",
      "properties": {
        "disableLocalAuth": "[parameters('disableLocalAuth')]",
        "customSubDomainName": "[parameters('cognitiveServiceName')]",
        "allowProjectManagement": "[parameters('allowProjectManagement')]",
        "networkAcls": {
          "defaultAction": "[parameters('defaultAction')]",
          "ipRules": "[parameters('ipRules')]"
        },
        "publicNetworkAccess": "Enabled",
        "apiProperties": "[parameters('apiProperties')]"
      },
      "resources": [
        {
          "condition": "[equals(parameters('kind'), 'AIServices')]",
          "type": "projects",
          "apiVersion": "2025-04-01-preview",
          "name": "[parameters('defaultProjectName')]",
          "location": "[parameters('location')]",
          "identity": "[parameters('managedIdentities')]",
          "sku": {
              "name": "S0"
          },
          "properties": {
              "displayName": "[parameters('defaultProjectName')]",
              "description": "Default project created with the resource"
          },
          "dependsOn": [
              "[resourceId('Microsoft.CognitiveServices/accounts', parameters('cognitiveServiceName'))]"
          ]
        }
      ]
    }
  ]
}