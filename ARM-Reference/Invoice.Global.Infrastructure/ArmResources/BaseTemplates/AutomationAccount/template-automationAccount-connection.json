{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "automationAccountName": {
            "type": "string"
        },
        "location": {
            "type": "string",
            "metadata": {
                "description": "Location for all resources."
            }
        },
        "thumbprint": {
            "type": "string"
        },
        "appId": {
            "type": "string"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Automation/automationAccounts/connections",
            "apiVersion": "2019-06-01",
            "location": "[parameters('location')]",
            "name": "[concat(parameters('automationAccountName'), '/AzureRunAsConnection')]",
            "properties": {
                "description": "Default AzureRunAsConnection. Thumbprint is provided in the parameter file, App Id is from common app registration.",
                "connectionType": {
                    "name": "AzureServicePrincipal"
                },
                "fieldDefinitionValues": {
                    "tenantId": "[subscription().tenantId]",
                    "subscriptionId": "[subscription().subscriptionId]",
                    "applicationId": "[parameters('appId')]",
                    "certificateThumbprint": "[parameters('thumbprint')]"
                }
            }
        }
    ]
}
