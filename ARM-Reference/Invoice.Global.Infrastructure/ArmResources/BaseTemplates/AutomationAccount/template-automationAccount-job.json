{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "runbookName": {
      "type": "string"
    },
    "automationAccountName": {
      "type": "string"
    },
    "runbookParameters": {
      "type": "object"
    },
    "runOn": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The default is blank to run this job on Azure"
      }
    },
    "_internalGuidValue": {
      "type": "string",
      "defaultValue": "[newGuid()]",
      "metadata": {
        "description": "Used to update the runbook every time it's deployed. newGuid() can only exist in parameters."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('automationAccountName'), '/', parameters('_internalGuidValue'))]",
      "type": "Microsoft.Automation/automationAccounts/jobs",
      "apiVersion": "2019-06-01",
      "properties": {
        "runOn": "[parameters('runOn')]",
        "runbook": {
          "name": "[parameters('runbookName')]"
        },
        "parameters": "[parameters('runbookParameters')]"
      }
    }
  ]
}