{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "automationAccountName": {
            "type": "string"
        },
        "location": {
            "type": "string",
            "metadata": {
                "description": "Location for all resources."
            }
        },
        "runbooks": {
            "type": "secureObject"
        },
        "env": {
            "type": "string",
            "defaultValue": "dev",
            "metadata": {
                "description": "The 3 letter environment"
            }
        },
        "_utcNow": {
            "type": "string",
            "defaultValue": "[utcNow('u')]",
            "metadata": {
                "description": "Used to update the runbook every time it's deployed. utcNow() can only exist in parameters."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "condition": "[contains(tolower(parameters('runbooks').runbooksDetails[copyIndex()].environmentsToDeploy),tolower(parameters('env')))]",
            "type": "Microsoft.Automation/automationAccounts/runbooks",
            "apiVersion": "2019-06-01",
            "name": "[concat(parameters('automationAccountName'), '/', parameters('runbooks').runbooksDetails[copyIndex()].name)]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "AddAutomationAccountRunbooksLoop",
                "count": "[length(parameters('runbooks').runbooksDetails)]"
            },
            "properties": {
                "description": "undefined",
                "logVerbose": false,
                "logProgress": false,
                "logActivityTrace": 0,
                "runbookType": "[parameters('runbooks').runbooksDetails[copyIndex()].type]",
                "publishContentLink": {
                    "uri": "[concat(parameters('runbooks').baseUrl, parameters('runbooks').runbooksDetails[copyIndex()].name, parameters('runbooks').runbooksDetails[copyIndex()].fileExtension, parameters('runbooks').sasToken)]",
                    "version": "[parameters('_utcNow')]"
                }
            }
        }
    ]
}