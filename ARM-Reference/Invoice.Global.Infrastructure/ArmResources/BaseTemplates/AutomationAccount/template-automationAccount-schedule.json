{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "hybridWorker": {
            "type": "string",
            "defaultValue": "MSSHWBCDRPPEGroup"
        },
        "env": {
            "type": "string",
            "defaultValue": "The 3 letter environment"
        },
        "automationAccountName": {
            "type": "string",
            "metadata": { "description": "Automation Account Name where Schedules need to be deployed to." }
        },
        "baseTime": {
            "type": "string",
            "defaultValue": "[utcNow('u')]"
        },
        "scheduleDetails": {
            "type": "object",
            "metadata": { "description": "Schedule Details" }
        }
    },
    "variables": {
        "startDate": "[take(string(dateTimeAdd(parameters('baseTime'), 'P1D')), 10)]"
    },
    "resources": [
        {
            "condition": "[contains(tolower(parameters('scheduleDetails').daily.schedules[copyIndex()].environmentsToDeploy),tolower(parameters('env')))]",
            "type": "Microsoft.Automation/automationAccounts/schedules",
            "apiVersion": "2015-10-31",
            "name": "[concat(parameters('automationAccountName'), '/',parameters('scheduleDetails').daily.schedules[copyIndex()].name)]",
            "copy": {
                "name": "AddAutomationAccountSchedules-Daily",
                "mode": "Serial",
                "count": "[length(parameters('scheduleDetails').daily.schedules)]"
            },
            "dependsOn": [],
            "properties": {
                "startTime": "[concat(variables('startDate'),'T',parameters('scheduleDetails').daily.schedules[copyIndex()].startTime,':00-08:00')]",
                "expiryTime": "9999-12-31T15:59:00-08:00",
                "interval": "[parameters('scheduleDetails').daily.schedules[copyIndex()].interval]",
                "frequency": "[parameters('scheduleDetails').daily.schedules[copyIndex()].frequency]",
                "timeZone": "America/Los_Angeles"
            }
        },
        {
            "condition": "[contains(tolower(parameters('scheduleDetails').daily.schedules[copyIndex()].environmentsToDeploy),tolower(parameters('env')))]",
            "type": "Microsoft.Automation/automationAccounts/schedules",
            "apiVersion": "2015-10-31",
            "name": "[concat(parameters('automationAccountName'), '/',parameters('scheduleDetails').weekly.schedules[copyIndex()].name)]",
            "copy": {
                "name": "AddAutomationAccountSchedules-Weekly",
                "mode": "Serial",
                "count": "[length(parameters('scheduleDetails').weekly.schedules)]"
            },
            "dependsOn": [],
            "properties": {
                "startTime": "[concat(variables('startDate'),'T',parameters('scheduleDetails').weekly.schedules[copyIndex()].startTime,':00-08:00')]",
                "expiryTime": "9999-12-31T15:59:00-08:00",
                "interval": "[parameters('scheduleDetails').weekly.schedules[copyIndex()].interval]",
                "frequency": "[parameters('scheduleDetails').weekly.schedules[copyIndex()].frequency]",
                "timeZone": "America/Los_Angeles",
                "advancedSchedule": { "weekDays": "[parameters('scheduleDetails').weekly.schedules[copyIndex()].day]" }
            }
        },
        {
            "condition": "[contains(tolower(parameters('scheduleDetails').daily.schedules[copyIndex()].environmentsToDeploy),tolower(parameters('env')))]",
            "type": "Microsoft.Automation/automationAccounts/schedules",
            "apiVersion": "2015-10-31",
            "name": "[concat(parameters('automationAccountName'), '/',parameters('scheduleDetails').monthly.schedules[copyIndex()].name)]",
            "copy": {
                "name": "AddAutomationAccountSchedules-Monthly",
                "mode": "Serial",
                "count": "[length(parameters('scheduleDetails').monthly.schedules)]"
            },
            "dependsOn": [],
            "properties": {
                "startTime": "[concat(variables('startDate'),'T',parameters('scheduleDetails').monthly.schedules[copyIndex()].startTime,':00-08:00')]",
                "expiryTime": "9999-12-31T15:59:00-08:00",
                "interval": "[parameters('scheduleDetails').monthly.schedules[copyIndex()].interval]",
                "frequency": "[parameters('scheduleDetails').monthly.schedules[copyIndex()].frequency]",
                "timeZone": "America/Los_Angeles",
                "advancedSchedule": { "monthDays": "[parameters('scheduleDetails').monthly.schedules[copyIndex()].day]" }
            }
        }
    ]
}