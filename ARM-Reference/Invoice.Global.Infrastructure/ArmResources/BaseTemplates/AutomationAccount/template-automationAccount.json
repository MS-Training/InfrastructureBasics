{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "metadata": {
        "description": "Automation account name"
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Specifies the location in which to create the Automation account."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "Nothing",
      "metadata": {
        "description": "The name of the Keyvault where to store the secrets"
      }
    },
    "workspaceId": {
      "type": "string",
      "defaultValue": "Nothing",
      "metadata": {
        "description": "The name of the Keyvault where to store the secrets"
      }
    },
    "disableLocalAuth": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Disable local authentication for the Automation account."
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2020-01-13-preview",
      "name": "[parameters('automationAccountName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "disableLocalAuth": "[parameters('disableLocalAuth')]",
        "sku": {
          "name": "Basic"
        }
      },
      "resources": [
        {
          "type": "providers/diagnosticSettings",
          "name": "[concat('Microsoft.Insights/', concat(parameters('automationAccountName'),'-Diagnostics'))]",
          "dependsOn": [
            "[parameters('automationAccountName')]"
          ],
          "apiVersion": "2017-05-01-preview",
          "properties": {
            "name": "[concat(parameters('automationAccountName'),'Diagnostics')]",
            "workspaceId": "[parameters('workspaceId')]",
            "logAnalyticsDestinationType": "Dedicated",
            "logs": [
              {
                "category": "JobLogs",
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              },
              {
                "category": "JobStreams",
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              }
            ],
            "metrics": [
              {
                "category": "AllMetrics",
                "enabled": true,
                "retentionPolicy": {
                  "enabled": false,
                  "days": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "condition": "[not(equals(parameters('keyVaultName'), 'Nothing'))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "name": "[concat(parameters('keyVaultName'), '/', concat('kv-',parameters('automationAccountName'),'-PrimaryKey'))]",
      "apiVersion": "2018-02-14",
      "dependsOn": [
        "[concat('Microsoft.Automation/automationAccounts/', parameters('automationAccountName'))]"
      ],
      "properties": {
        "value": "[listKeys(resourceId('Microsoft.Automation/automationAccounts/', parameters('automationAccountName')), '2015-10-31').keys[0].value]"
      }
    },
    {
      "condition": "[not(equals(parameters('keyVaultName'), 'Nothing'))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "name": "[concat(parameters('keyVaultName'), '/', concat('kv-',parameters('automationAccountName'),'-SecondaryKey'))]",
      "apiVersion": "2018-02-14",
      "dependsOn": [
        "[concat('Microsoft.Automation/automationAccounts/', parameters('automationAccountName'))]"
      ],
      "properties": {
        "value": "[listKeys(resourceId('Microsoft.Automation/automationAccounts/', parameters('automationAccountName')), '2015-10-31').keys[1].value]"
      }
    },
    {
      "condition": "[not(equals(parameters('keyVaultName'), 'Nothing'))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "name": "[concat(parameters('keyVaultName'), '/', concat('kv-',parameters('automationAccountName'),'-Endpoint'))]",
      "apiVersion": "2018-02-14",
      "dependsOn": [
        "[concat('Microsoft.Automation/automationAccounts/', parameters('automationAccountName'))]"
      ],
      "properties": {
        "value": "[reference(resourceId('Microsoft.Automation/automationAccounts/', parameters('automationAccountName')), '2015-10-31').RegistrationUrl]"
      }
    }
  ],
  "outputs": {
  }
}
