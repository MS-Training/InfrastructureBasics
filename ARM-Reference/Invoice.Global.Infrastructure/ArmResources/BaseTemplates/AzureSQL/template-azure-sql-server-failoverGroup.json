{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "primarySqlServerName": {
      "type": "string",
      "metadata": {
        "description": "The SQL Logical Server name."
      }
    },
    "failoverPostfix": {
      "type": "string",
      "defaultValue": "vnn",
      "metadata": {
        "description": "The postfix to be added to the end of the failovername. VNN for virtaul name"
      }
    },
    "partnerServers": {
      "type": "array",
      "metadata": {
        "description": [
          { "id": "The resource id of the partner sql server" },
          { "id": "The resource id of the partner sql server" }
        ]
      }
    },
    "databases": {
      "type": "array",
      "defaultValue": []
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Sql/servers/failoverGroups",
      "apiVersion": "2021-11-01",
      "name": "[concat(parameters('primarySqlServerName'), '/', parameters('primarySqlServerName'),parameters('failoverPostfix'))]",
      "properties": {
        "databases": "[parameters('databases')]",
        "partnerServers": "[parameters('partnerServers')]",
        "readWriteEndpoint": {
          "failoverPolicy": "Automatic",
          "failoverWithDataLossGracePeriodMinutes": 60
        }
      }
    }
  ]
}