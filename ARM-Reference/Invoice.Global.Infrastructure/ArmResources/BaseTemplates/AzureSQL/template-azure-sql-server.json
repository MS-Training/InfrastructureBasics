{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "sqlServerName": {
      "defaultValue": "[concat('sql', uniqueString(resourceGroup().id))]",
      "type": "string",
      "metadata": {
        "description": "The SQL Logical Server name."
      }
    },
    "sqlAdministratorLogin": {
      "type": "string",
      "metadata": {
        "description": "The administrator username of the SQL Server."
      }
    },
    "sqlAdministratorPassword": {
      "type": "securestring",
      "metadata": {
        "description": "The administrator password of the SQL Server."
      }
    },
    "location": {
      "defaultValue": "[resourceGroup().location]",
      "type": "string",
      "metadata": {
        "description": "Resource location"
      }
    },
    "aadAdminLogin": {
      "type": "String",
      "metadata": {
        "description": "AAD Admin Login"
      }
    },
    "aadAdminObjectID": {
      "type": "String",
      "metadata": {
        "description": "AAD Admin ObjectID"
      }
    },
    "diagnosticsStorageAccountName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "defaultValue": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourcegroups/RG-630-INV-DEV-COMMON/providers/Microsoft.ManagedIdentity/userAssignedIdentities/invdevmicommon"
    },
    "disableSqlAuth": {
      "type": "bool",
      "defaultValue": true
    }
  },
  "variables": {
    "sqlProperties": {
      "administratorLogin": "[parameters('sqlAdministratorLogin')]",
      "administratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
      "version": "12.0",
      "minimalTlsVersion": "1.2",
      "primaryUserAssignedIdentityId": "[parameters('userAssignedIdentityResourceId')]"
    },
    "sqlPropertiesADOnlyAuth": {
      "administratorLogin": "[parameters('sqlAdministratorLogin')]",
      "version": "12.0",
      "minimalTlsVersion": "1.2",
      "primaryUserAssignedIdentityId": "[parameters('userAssignedIdentityResourceId')]"
    }
  },
  "resources": [
    {
      "name": "[parameters('sqlServerName')]",
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2021-11-01",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[parameters('userAssignedIdentityResourceId')]": {}
        }
      },
      "properties": "[if(parameters('disableSqlAuth'), variables('sqlPropertiesADOnlyAuth'), variables('sqlProperties'))]",
      "resources": [
        {
          "type": "securityAlertPolicies",
          "name": "Default",
          "apiVersion": "2021-11-01",
          "dependsOn": [
            "[resourceId('Microsoft.Sql/servers', parameters('SqlServerName'))]"
          ],
          "properties": {
            "state": "Enabled",
            "disabledAlerts": [
            ],
            "emailAddresses": [
            ],
            "emailAccountAdmins": true,
            "retentionDays": 365
          }
        },
        {
          "apiVersion": "2022-08-01-preview",
          "type": "extendedAuditingSettings",
          "name": "DefaultAuditingSettings",
          "dependsOn": [
            "[concat('Microsoft.Sql/servers/', parameters('SqlServerName'))]"
          ],
          "properties": {
            "retentionDays": 90,
            "auditActionsAndGroups": [
              "SUCCESSFUL_DATABASE_AUTHENTICATION_GROUP",
              "FAILED_DATABASE_AUTHENTICATION_GROUP",
              "BATCH_COMPLETED_GROUP",
              "DATABASE_OBJECT_CHANGE_GROUP",
              "DATABASE_OBJECT_PERMISSION_CHANGE_GROUP",
              "DATABASE_PRINCIPAL_CHANGE_GROUP",
              "DATABASE_PRINCIPAL_IMPERSONATION_GROUP",
              "DATABASE_ROLE_MEMBER_CHANGE_GROUP"
            ],
            "isAzureMonitorTargetEnabled": false,
            "isManagedIdentityInUse": true,
            "state": "Enabled",
            "storageEndpoint": "[concat('https://',parameters('diagnosticsStorageAccountName'),'.blob.core.windows.net/')]",
            "storageAccountSubscriptionId": "[subscription().subscriptionId]"
          }
        },
        {
          "type": "administrators",
          "name": "activeDirectory",
          "apiVersion": "2021-11-01",
          "location": "[parameters('location')]",
          "properties": {
            "administratorType": "ActiveDirectory",
            "login": "[parameters('aadAdminLogin')]",
            "sid": "[parameters('aadAdminObjectID')]",
            "tenantId": "[subscription().tenantId]",
            "azureADOnlyAuthentication": "[parameters('disableSqlAuth')]"
          },
          "dependsOn": [
            "[parameters('sqlServerName')]"
          ]
        },
        {
          "type": "sqlVulnerabilityAssessments",
          "name": "Default",
          "apiVersion": "2022-08-01-preview",
          "location": "[parameters('location')]",
          "dependsOn": [
            "[parameters('sqlServerName')]"
          ],
          "properties": {
            "state": "Enabled"
          }
        }
      ]
    }
  ],
  "outputs": {
  }
}