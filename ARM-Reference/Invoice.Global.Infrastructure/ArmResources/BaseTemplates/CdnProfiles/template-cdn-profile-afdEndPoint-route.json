{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "afdEndPointName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Azure FrontDoor Endpoint."
      }
    },
    "routeName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Route, in this case we use the service name."
      }
    },
    "customDomains": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template",
        "sample": [
          {
            "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON-NETWORK/providers/Microsoft.Cdn/profiles/invdevfdcommon/customdomains/invoice-services-dev-microsoft-com"
          }
        ]
      }
    },
    "originGroupResourceId": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template",
        "sample": {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON-NETWORK/providers/Microsoft.Cdn/profiles/invdevfdcommon/origingroups/sapel-origin-group"
        }

      }
    },
    "ruleSets": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "supportedProtocols": {
      "type": "array",
      "defaultValue": [
        "Http",
        "Https"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "patternsToMatch": {
      "type": "array",
      "defaultValue": [
        "/api/sapel/*"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "forwardingProtocol": {
      "type": "string",
      "defaultValue": "HttpsOnly",
      "allowedValues": [
        "HttpOnly",
        "HttpsOnly",
        "MatchRequest"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "linkToDefaultDomain": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "httpsRedirect": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "enabledState": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/afdendpoints/routes",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('cdnProfileName'), '/',parameters('afdEndPointName'),'/',parameters('routeName'))]",
      "dependsOn": [],
      "properties": {
        "customDomains": "[parameters('customDomains')]",
        "originGroup": "[parameters('originGroupResourceId')]",
        "ruleSets": "[parameters('ruleSets')]",
        "supportedProtocols": "[parameters('supportedProtocols')]",
        "patternsToMatch": "[parameters('patternsToMatch')]",
        "forwardingProtocol": "[parameters('forwardingProtocol')]",
        "linkToDefaultDomain": "[parameters('linkToDefaultDomain')]",
        "httpsRedirect": "[parameters('httpsRedirect')]",
        "enabledState": "[parameters('enabledState')]"
      }
    }
  ],
  "outputs": {
  }
}