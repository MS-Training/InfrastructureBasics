{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "afdEndPointName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Azure FrontDoor Endpoint."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "Global",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "enabledState": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('cdnProfileName'), '/',parameters('afdEndPointName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "enabledState": "[parameters('enabledState')]"
      }
    }
  ],
  "outputs": {
  }
}