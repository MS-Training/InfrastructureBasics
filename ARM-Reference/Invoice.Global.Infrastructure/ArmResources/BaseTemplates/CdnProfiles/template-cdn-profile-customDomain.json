{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "customDomainHostName": {
      "type": "string",
      "metadata": {
        "description": "example tomas.iac.espinoza.com"
      }
    },
    "certificateType": {
      "type": "string",
      "defaultValue": "ManagedCertificate",
      "allowedValues": [
        "ManagedCertificate",
        "AzureFirstPartyManagedCertificate",
        "CustomerCertificate"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/customdomains?pivots=deployment-language-arm-template"
      }
    },
    "minimumTlsVersion": {
      "type": "string",
      "defaultValue": "TLS12",
      "allowedValues": [
        "TLS10",
        "TLS12"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/customdomains?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/customDomains",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('cdnProfileName'), '/',replace(parameters('customDomainHostName'),'.','-'))]",
      "properties": {
        "hostName": "[parameters('customDomainHostName')]",
        "tlsSettings": {
          "certificateType": "[parameters('certificateType')]",
          "minimumTlsVersion": "[parameters('minimumTlsVersion')]"
        }
      }
    }
  ],
  "outputs": {
    "afdCustomEndpoint": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cdn/profiles/customDomains', parameters('cdnProfileName'), replace(parameters('customDomainHostName'), '.', '-'))]"
    }
  }
}