{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "cdnProfileOriginGroupName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Origin group, This will be used to map the back end compute"
      }
    },
    "cdnProfileOriginGroupOriginName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Origin resource."
      }
    },
    "hostName": {
      "type": "string",
      "metadata": {
        "description": "example the host name of an function app that will be our backend"
      }
    },
    "originHostHeader": {
      "type": "string",
      "metadata": {
        "description": "example the host name of an function app that will be our backend"
      }
    },
    "enabledState": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "weight": {
      "type": "int",
      "defaultValue": 1000,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "priority": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "httpPort": {
      "type": "int",
      "defaultValue": 80,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "httpsPort": {
      "type": "int",
      "defaultValue": 443,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "enforceCertificateNameCheck": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/origingroups/origins",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('cdnProfileName'), '/',parameters('cdnProfileOriginGroupName'),'/',parameters('cdnProfileOriginGroupOriginName'))]",
      "dependsOn": [
      ],
      "properties": {
        "hostName": "[parameters('hostName')]",
        "httpPort": "[parameters('httpPort')]",
        "httpsPort": "[parameters('httpsPort')]",
        "originHostHeader": "[parameters('originHostHeader')]",
        "priority": "[parameters('priority')]",
        "weight": "[parameters('weight')]",
        "enabledState": "[parameters('enabledState')]",
        "enforceCertificateNameCheck": "[parameters('enforceCertificateNameCheck')]"
      }
    }
  ],
  "outputs": {
  }
}