{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "cdnProfileOriginGroupName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Origin group, This will be used to map the back end compute"
      }
    },
    "probeIntervalInSeconds": {
      "type": "int",
      "defaultValue": 240,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probePath": {
      "type": "string",
      "defaultValue": "/",
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probeProtocol": {
      "type": "string",
      "defaultValue": "Http",
      "allowedValues": [
        "Http",
        "Https",
        "NotSet"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probeRequestType": {
      "type": "string",
      "defaultValue": "GET",
      "allowedValues": [
        "GET",
        "HEAD",
        "NotSet"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "additionalLatencyInMilliseconds": {
      "type": "int",
      "defaultValue": 50,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "sampleSize": {
      "type": "int",
      "defaultValue": 4,
      "metadata": {
        "description": "Send and receive timeout on forwarding request to the origin. When timeout is reached, the request fails and returns."
      }
    },
    "successfulSamplesRequired": {
      "type": "int",
      "defaultValue": 3,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "sessionAffinityState": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Disabled",
        "Enabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "trafficRestorationTimeToHealedOrNewEndpointsInMinutes": {
      "type": "int",
      "defaultValue": 10,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/originGroups",
      "apiVersion": "2022-11-01-preview",
      "name": "[concat(parameters('cdnProfileName'), '/',parameters('cdnProfileOriginGroupName'))]",
      "properties": {
        "healthProbeSettings": {
          "probeIntervalInSeconds": "[parameters('probeIntervalInSeconds')]",
          "probePath": "[parameters('probePath')]",
          "probeProtocol": "[parameters('probeProtocol')]",
          "probeRequestType": "[parameters('probeRequestType')]"
        },
        "loadBalancingSettings": {
          "additionalLatencyInMilliseconds": "[parameters('additionalLatencyInMilliseconds')]",
          "sampleSize": "[parameters('sampleSize')]",
          "successfulSamplesRequired": "[parameters('successfulSamplesRequired')]"
        },
        "sessionAffinityState": "[parameters('sessionAffinityState')]",
        "trafficRestorationTimeToHealedOrNewEndpointsInMinutes": "[parameters('trafficRestorationTimeToHealedOrNewEndpointsInMinutes')]"
      }
    }
  ],
  "outputs": {
  }
}