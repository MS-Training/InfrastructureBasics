{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "Global",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Premium_AzureFrontDoor",
      "allowedValues": [
        "Premium_AzureFrontDoor",
        "Standard_AzureFrontDoor"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles?pivots=deployment-language-arm-template"
      }
    },
    "extendedProperties": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Key-Value pair representing additional properties for profiles.See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles?pivots=deployment-language-arm-template"
      }
    },
    "originResponseTimeoutSeconds": {
      "type": "int",
      "defaultValue": 60,
      "metadata": {
        "description": "Send and receive timeout on forwarding request to the origin. When timeout is reached, the request fails and returns."
      }
    },
    "workSpaceResourceId": {
      "type": "string",
      "defaultValue": "workspaceID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles",
      "name": "[parameters('cdnProfileName')]",
      "apiVersion": "2022-11-01-preview",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('skuName')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "extendedProperties": "[parameters('extendedProperties')]",
        "originResponseTimeoutSeconds": "[parameters('originResponseTimeoutSeconds')]"
      },
      "resources": [
        {
          "type": "providers/diagnosticSettings",
          "name": "[concat('Microsoft.Insights/', concat(parameters('cdnProfileName'),'-Diagnostics'))]",
          "dependsOn": [
            "[parameters('cdnProfileName')]"
          ],
          "apiVersion": "2021-05-01-preview",
          "properties": {
            "name": "[concat(parameters('cdnProfileName'),'Diagnostics')]",
            "workspaceId": "[parameters('workSpaceResourceId')]",
            "logAnalyticsDestinationType": "Dedicated",
            "logs": [
              {
                "category": null,
                "categoryGroup": "audit",
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              },
              {
                "category": null,
                "categoryGroup": "allLogs",
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              }
            ],
            "metrics": [
              {
                "category": "AllMetrics",
                "enabled": true,
                "retentionPolicy": {
                  "enabled": false,
                  "days": 0
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "outputs": {
  }
}