{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "nameSpaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure Relay namespace"
      }
    },
    "webApplicationName": {
      "type": "string",
      "metadata": {
        "description": "The name of the web Application. i.e name of the Function App"
      }
    },
    "hybridConnectionName": {
      "type": "string",
      "metadata": {
        "description": "The name of the web Application. i.e name of the Function App"
      }
    }
  },
  "variables": {
    "hybridConnectionResourceId": "[concat(subscription().id,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.Relay/namespaces/', parameters('nameSpaceName'),'/HybridConnections/', parameters('hybridConnectionName'))]"
  },
  "resources": [
    {
      "name": "[concat(parameters('webApplicationName'),'/',parameters('nameSpaceName'),'/',parameters('hybridConnectionName'))]",
      "type": "Microsoft.Web/sites/hybridConnectionNamespaces/relays",
      "apiVersion": "2018-11-01",
      "dependsOn": [
      ],
      "properties": {
        "serviceBusNamespace": "[parameters('nameSpaceName')]",
        "relayName": "[parameters('hybridConnectionName')]",
        "relayArmUri": "[variables('hybridConnectionResourceId')]",
        "hostname": "[split(json(reference(variables('hybridConnectionResourceId'), '2017-04-01').userMetadata)[0].value, ':')[0]]",
        "port": "[split(json(reference(variables('hybridConnectionResourceId'), '2017-04-01').userMetadata)[0].value, ':')[1]]",
        "sendKeyName": "defaultSender",
        "sendKeyValue": "[listkeys(concat(variables('hybridConnectionResourceId'), '/authorizationRules/defaultSender'), '2017-04-01').primaryKey]"
      }
    }
  ],
  "outputs": {
  }
}
