{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dotnetFrameworkVersion": {
      "type": "string",
      "defaultValue": "v6.0",
      "metadata": {
        "description": "The .NET Framework version that you want to use for the function app."
      }
    },
    "functionIdentities": {
      "type": "object",
      "defaultValue": {
        "type": "SystemAssigned"
      },
      "metadata": {
        "description": "The System or User Assigned Identities Object used to create the function and the Identities used by the function."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "The name of the function app that you wish to create."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "corsAllowURL": {
      "type": "array",
      "defaultValue": [
        "https://functions.azure.com",
        "https://functions-staging.azure.com",
        "https://functions-next.azure.com"
      ],
      "metadata": {
        "description": "This is a URL that will be allowed to call your function"
      }
    },
    "appSettings": {
      "type": "secureObject"
    },
    "hostingPlanResourceId": {
      "type": "string"
    },
    "virtualNetworkSubnetId": {
      "type": "string",
      "defaultValue": "None"
    },
    "workSpaceResourceId": {
      "type": "string",
      "defaultValue": "workspaceID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace"
      }
    },
    "publicNetworkAccess": {
      "type": "string",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ]
    }
  },
  "variables": {
    "function_identity_resource_id": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.Web/sites/', parameters('functionAppName'), '/providers/Microsoft.ManagedIdentity/Identities/default')]",
    "vnetIntegratedFunctionProperties": {
      "serverFarmId": "[parameters('hostingPlanResourceId')]",
      "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
      "httpsOnly": true,
      "siteConfig": {
        "appSettings": "[parameters('appSettings').settings]",
        "use32BitWorkerProcess": false,
        "cors": {
          "allowedOrigins": "[parameters('corsAllowURL')]",
          "supportCredentials": false
        },
        "netFrameworkVersion": "[parameters('dotnetFrameworkVersion')]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "ipSecurityRestrictions": [
          {
            "ipAddress": "AzureFrontDoor.Backend",
            "action": "Allow",
            "tag": "ServiceTag",
            "priority": 100,
            "name": "frontdoor"
          },
          {
            "ipAddress": "Any",
            "action": "Deny",
            "priority": 2147483647,
            "name": "Deny all",
            "description": "Deny all access"
          }
        ],
        "ipSecurityRestrictionsDefaultAction": "Deny"
      },
      "name": "[parameters('functionAppName')]",
      "clientAffinityEnabled": false,
      "virtualNetworkSubnetId": "[parameters('virtualNetworkSubnetId')]",
      "vnetRouteAllEnabled": true
    },
    "functionProperties": {
      "serverFarmId": "[parameters('hostingPlanResourceId')]",
      "httpsOnly": true,
      "siteConfig": {
        "appSettings": "[parameters('appSettings').settings]",
        "use32BitWorkerProcess": false,
        "cors": {
          "allowedOrigins": "[parameters('corsAllowURL')]",
          "supportCredentials": false
        },
        "netFrameworkVersion": "[parameters('dotnetFrameworkVersion')]"
      },
      "name": "[parameters('functionAppName')]",
      "clientAffinityEnabled": false
    }
  },
  "resources": [
    {
      "name": "[parameters('functionAppName')]",
      "type": "Microsoft.Web/sites",
      "location": "[parameters('location')]",
      "apiVersion": "2022-03-01",
      "kind": "functionapp",
      "dependsOn": [],
      "identity": "[parameters('functionIdentities')]",
      "properties": "[if(equals(parameters('virtualNetworkSubnetId'),'None'),variables('functionProperties'),variables('vnetIntegratedFunctionProperties'))]",
      "resources": [
        {
          "type": "providers/diagnosticSettings",
          "name": "[concat('Microsoft.Insights/', concat(parameters('functionAppName'),'-Diagnostics'))]",
          "dependsOn": [
            "[parameters('functionAppName')]"
          ],
          "apiVersion": "2017-05-01-preview",
          "properties": {
            "name": "[concat(parameters('functionAppName'),'Diagnostics')]",
            "workspaceId": "[parameters('workSpaceResourceId')]",
            "logAnalyticsDestinationType": "Dedicated",
            "logs": [
              {
                "category": "FunctionAppLogs",
                "categoryGroup": null,
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              }
            ],
            "metrics": [
              {
                "category": "AllMetrics",
                "enabled": true,
                "retentionPolicy": {
                  "enabled": false,
                  "days": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "name": "OutputDefaultIdentiyResourceid",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "parameters": {
          "identity_resource_id": {
            "value": "[variables('function_identity_resource_id')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "identity_resource_id": {
              "type": "string"
            }
          },
          "resources": [],
          "outputs": {
            "functionObjectId": {
              "type": "string",
              "value": "[reference(parameters('identity_resource_id'), '2018-11-30').principalId]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "functionObjectId": {
      "type": "string",
      "value": "[reference('OutputDefaultIdentiyResourceid').outputs.functionObjectId.value]"
    },
    "functionResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
    }
  }
}
