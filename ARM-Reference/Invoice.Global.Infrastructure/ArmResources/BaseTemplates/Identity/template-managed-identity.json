{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "managedIdentityName": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location"
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "Nothing",
      "metadata": {
        "description": "The name of the Keyvault where to store the secrets"
      }
    }
  },
  "variables": {
    "identity_resource_id": "[concat(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/', parameters('managedIdentityName')))]"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2018-11-30",
      "name": "[parameters('managedIdentityName')]",
      "location": "[parameters('location')]",
      "tags": {
      }
    },
    {
      "condition": "[not(equals(parameters('keyVaultName'), 'Nothing'))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "name": "[concat(parameters('keyVaultName'), '/', concat('kv-',parameters('managedIdentityName'),'-PrincipalId'))]",
      "apiVersion": "2018-02-14",
      "dependsOn": [
        "[concat('Microsoft.ManagedIdentity/userAssignedIdentities/', parameters('managedIdentityName'))]"
      ],
      "properties": {
        "value": "[reference(variables('identity_resource_id'), '2018-11-30').principalId]"
      }
    },
    {
      "condition": "[not(equals(parameters('keyVaultName'), 'Nothing'))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "name": "[concat(parameters('keyVaultName'), '/', concat('kv-',parameters('managedIdentityName'),'-ClientId'))]",
      "apiVersion": "2018-02-14",
      "dependsOn": [
        "[concat('Microsoft.ManagedIdentity/userAssignedIdentities/', parameters('managedIdentityName'))]"
      ],
      "properties": {
        "value": "[reference(variables('identity_resource_id'), '2018-11-30').clientId]"
      }
    }
  ],
  "outputs": {
    "managedIdentityObjectId": {
      "type": "string",
      "value": "[reference(variables('identity_resource_id'), '2018-11-30').principalId]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference(variables('identity_resource_id'), '2018-11-30').clientId]"
    }
  }
}
