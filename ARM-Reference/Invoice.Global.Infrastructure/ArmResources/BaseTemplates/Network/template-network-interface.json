{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "networkInterfaceName": {
      "type": "String"
    },
    "location": {
      "type": "String"
    },
    "virtualNetworkId": {
      "type": "String",
      "metadata": {
        "description": "The resource id of the Virtual Network that will be used"
      }
    },
    "virtualNetworkSubnetName": {
      "type": "String",
      "metadata": {
        "description": "the Virtual Network Subnet Name that will be used"
      }
    },
    "enableAcceleratedNetworking": {
      "type": "bool",
      "defaultValue": false
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2020-11-01",
      "name": "[parameters('networkInterfaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[concat(parameters('virtualNetworkId'), '/subnets/',parameters('virtualNetworkSubnetName'))]"
              }
            }
          }
        ],
        "enableAcceleratedNetworking": "[parameters('enableAcceleratedNetworking')]"
      }
    }
  ],
  "outputs": {
    "ipAddress": {
      "type": "string",
      "value": "[reference(parameters('networkInterfaceName')).ipConfigurations[0].properties.privateIPAddress]"
    }
  }
}
