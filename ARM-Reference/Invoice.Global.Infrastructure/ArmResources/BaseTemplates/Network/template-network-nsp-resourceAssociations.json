{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "nspName": {
      "type": "string",
      "defaultValue": "invdevnspcommon"
    },
    "nspProfileName": {
      "type": "string",
      "defaultValue": "Default"
    },
    "associationDetails": {
      "type": "array",
      "metadata": {
        "description": "Array of rules to be created",
        "sample": [
          {
            "associationName": "theAssociationName",
            "privateLinkResourceId": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON/providers/Microsoft.KeyVault/vaults/invdevkvcommon"
          },
          {
            "associationName": "theAssociationName",
            "privateLinkResourceId": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON/providers/Microsoft.KeyVault/vaults/invdevkvcommon"
          }
        ]
      }
    }
  },
  "resources": [
    {
      "condition": "[not(equals(parameters('associationDetails')[copyIndex()].associationName,'None'))]",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', parameters('nspName'), parameters('associationDetails')[copyIndex()].associationName)]",
      "type": "Microsoft.Network/networkSecurityPerimeters/resourceAssociations",
      "dependsOn": [],
      "properties": {
        "privateLinkResource": "[createObject('id', parameters('associationDetails')[copyIndex()].privateLinkResourceId)]",
        "profile": "[createObject('id', resourceId('Microsoft.Network/networkSecurityPerimeters/profiles', parameters('nspName'), parameters('nspProfileName')))]"
      },
      "copy": {
        "name": "createAssociationsLoop",
        "count": "[length(parameters('associationDetails'))]"
      }
    }
  ],
  "outputs": {}
}