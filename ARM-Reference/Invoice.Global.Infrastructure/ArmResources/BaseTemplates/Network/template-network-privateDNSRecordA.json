{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "privateDNSZoneName": {
      "type": "string",
      "metadata": {
        "description": "The name of the zone, for example, contoso.com. The label and top-level domain (TLD) can contain alphanumeric characters, underscores, and dashes, and must be separated using a period."
      }
    },
    "dnsRecordName": {
      "type": "string",
      "metadata": {
        "description": "The name of the resource to be added. i.e the function Name"
      }
    },
    "ipAddress": {
      "type": "string",
      "metadata": {
        "description": "The Ip address of the resource "
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Network/privateDnsZones/A",
      "apiVersion": "2018-09-01",
      "name": "[concat(parameters('privateDNSZoneName'), '/',parameters('dnsRecordName'))]",
      "dependsOn": [
      ],
      "properties": {
        "ttl": 3600,
        "aRecords": [
          {
            "ipv4Address": "[parameters('ipAddress')]"
          }
        ]
      }
    }
  ]
}