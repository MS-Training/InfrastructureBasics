{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "privateDNSZoneName": {
      "type": "string",
      "metadata": {
        "description": "The name of the zone, for example, contoso.com. The label and top-level domain (TLD) can contain alphanumeric characters, underscores, and dashes, and must be separated using a period."
      }
    },
    "virtualNetworkResourceId": {
      "type": "string",
      "metadata": {
        "description": "The Full Resource Id of the Virtual Network that will be associated to this DNS Zone"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "apiVersion": "2024-06-01",
      "type": "Microsoft.Network/privateDnsZones",
      "name": "[parameters('privateDNSZoneName')]",
      "location": "global",
      "properties": {}
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[concat(parameters('privateDNSZoneName'), '/', take(uniqueString(parameters('privateDNSZoneName'),parameters('virtualNetworkResourceId')),13))]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', parameters('privateDNSZoneName'))]"
      ],
      "properties": {
        "registrationEnabled": false,
        "resolutionPolicy": "NxDomainRedirect",
        "virtualNetwork": {
          "id": "[parameters('virtualNetworkResourceId')]"
        }
      }
    }
  ]
}