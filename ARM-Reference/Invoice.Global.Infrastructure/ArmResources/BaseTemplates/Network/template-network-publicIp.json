{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "publicIpName": {
      "type": "string",
      "metadata": {
        "description": "Name of Public IP"
      }
    },
    "domainNameLabel": {
      "type": "string",
      "metadata": {
        "description": "Name domain label to be used"
      }
    },
    "location": {
      "type": "String",
      "defaultValue": "[resourceGroup().location]"
    },
    "skuTier": {
      "type": "string",
      "defaultValue": "Regional"
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard"
    },
    "ipTagName": {
      "type": "string",
      "defaultValue": "APInvoiceServicesTest"
    }
  },
  "variables": {
  },
  "resources": [
    {
      "apiVersion": "2023-04-01",
      "type": "Microsoft.Network/publicIPAddresses",
      "name": "[parameters('publicIpName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('skuName')]",
        "tier": "[parameters('skuTier')]"
      },
      "properties": {
        "dnsSettings": {
          "domainNameLabel": "[tolower(parameters('domainNameLabel'))]"
        },
        "publicIPAllocationMethod": "Static",
        "ipTags": [
          {
            "ipTagType": "FirstPartyUsage",
            "tag": "[concat('/',parameters('ipTagName'))]"
          }
        ]
      },
      "tags": {}
    }
  ],
  "outputs": {
    "publicIpResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIpName'))]"
    },
    "managementIpFQDN": {
      "value": "[reference(parameters('publicIpName')).dnsSettings.fqdn]",
      "type": "string"
    }
  }
}