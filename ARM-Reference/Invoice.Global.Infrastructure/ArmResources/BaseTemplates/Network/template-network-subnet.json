{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "virtualNetworkName": {
      "type": "string",
      "metadata": {
        "description": "Name of the VNET to add a subnet to"
      }
    },
    "subnetName": {
      "type": "string",
      "metadata": {
        "description": "Name of the subnet to add"
      }
    },
    "natGatewayResourceId": {
      "type": "string",
      "metadata": {
        "description": "The ResourceId of the NatGateway to be used by this subnet"
      }
    },
    "subnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/24",
      "metadata": {
        "description": "Address space of the subnet to add"
      }
    },
    "delegations": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Address space of the subnet to add"
      }
    },
    "serviceEndpoints": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "A list of service endpoints"
      }
    },
    "privateEndpointNetworkPolicies": {
      "type": "string",
      "defaultValue": "Disabled",
      "metadata": {
        "description": "privateEndpointNetworkPolicies for the subnet"
      }
    },
    "privateLinkServiceNetworkPolicies": {
      "type": "string",
      "defaultValue": "Enabled",
      "metadata": {
        "description": "privateLinkServiceNetworkPolicies for the subnet"
      }
    },
    "defaultOutboundAccess": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "defaultOutboundAccess for the subnet"
      }
    }
  },
  "variables": {
    "nsgResourceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.Network/networkSecurityGroups/',parameters('subnetName'), 'nsg')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2021-05-01",
      "name": "[format('{0}/{1}', parameters('virtualNetworkName'), parameters('subnetName'))]",
      "properties": {
        "addressPrefix": "[parameters('subnetAddressPrefix')]",
        "networkSecurityGroup": {
          "id": "[variables('nsgResourceId')]"
        },
        "natGateway": {
          "id": "[parameters('natGatewayResourceId')]"
        },
        "defaultOutboundAccess": "[parameters('defaultOutboundAccess')]",
        "privateEndpointNetworkPolicies": "[parameters('privateEndpointNetworkPolicies')]",
        "privateLinkServiceNetworkPolicies": "[parameters('privateLinkServiceNetworkPolicies')]",
        "delegations": "[parameters('delegations')]",
        "serviceEndpoints": "[parameters('serviceEndpoints')]"
      }
    }
  ]
}