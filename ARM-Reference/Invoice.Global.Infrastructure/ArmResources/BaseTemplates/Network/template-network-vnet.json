{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "virtualNetworkName": {
      "type": "string",
      "metadata": {
        "description": "Virtual network name"
      }
    },
    "virtualNetworkAddressPrefix": {
      "type": "string",
      "defaultValue": "172.20.0.0/16",
      "metadata": {
        "description": "The IP Address Prefix of the Network"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "enableDDoSProtection": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "enable if you have a DDoS protection plan created"
      }
    },
    "dDoSProtectionPlanResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The Resource id of the DDoS Protection Plan if enableDDoSProtection is true"
      }
    }
  },
  "variables": {
    "dDoSProperties": {
      "addressSpace": {
        "addressPrefixes": [
          "[parameters('virtualNetworkAddressPrefix')]"
        ]
      },
      "subnets": [],
      "enableDdosProtection": "[parameters('enableDDoSProtection')]",
      "ddosProtectionPlan": {
        "id": "[parameters('dDoSProtectionPlanResourceId')]"
      }
    },
    "properties": {
      "addressSpace": {
        "addressPrefixes": [
          "[parameters('virtualNetworkAddressPrefix')]"
        ]
      },
      "subnets": []
    }
  },
  "resources": [
    {
      "name": "[parameters('virtualNetworkName')]",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2019-09-01",
      "location": "[parameters('location')]",
      "properties": "[if(parameters('enableDDoSProtection'),variables('dDoSProperties'),variables('properties'))]"
    }
  ]
}