{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "wafPolicyName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure WAF policy for Azure Front Door. The name cannot have special characters or spaces."
      }
    },
    "rateLimitThreshold": {
      "type": "int",
      "metadata": {
        "description": "Rate limit threshold value for rate limit custom rule."
      }
    }
  },
  "variables": {
    "frontDoorWafName": "[parameters('wafPolicyName')]",
    "managedRuleSets": [
      {
        "ruleSetType": "Microsoft_BotManagerRuleSet",
        "ruleSetVersion": "1.1"
      }
    ],
    "GlobalRateLimitRule": {
      "action": "Block",
      "enabledState": "Enabled",
      "matchConditions": [
        {
          "matchValue": [
            "0.0.0.0/0"
          ],
          "matchVariable": "SocketAddr",
          "negateCondition": false,
          "operator": "IPMatch",
          "transforms": []
        }
      ],
      "name": "GlobalRateLimitRule",
      "priority": 100,
      "rateLimitDurationInMinutes": 5,
      "rateLimitThreshold": "[parameters('rateLimitThreshold')]",
      "ruleType": "RateLimitRule"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/FrontDoorWebApplicationFirewallPolicies",
      "apiVersion": "2024-02-01",
      "name": "[variables('frontDoorWafName')]",
      "location": "Global",
      "sku": {
        "name": "Premium_AzureFrontDoor"
      },
      "properties": {
        "managedRules": {
          "managedRuleSets": "[variables('managedRuleSets')]"
        },
        "customRules": {
          "rules": [
            "[variables('GlobalRateLimitRule')]"
          ]
        },
        "policySettings": {
          "enabledState": "Enabled",
          "mode": "Detection",
          "requestBodyCheck": "Enabled",
          "customBlockResponseStatusCode": 403,
          "javascriptChallengeExpirationInMinutes": 30
        }
      }
    }
  ],
  "outputs": {
    "frontDoorWafId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/FrontDoorWebApplicationFirewallPolicies', variables('frontDoorWafName'))]"
    }
  }
}