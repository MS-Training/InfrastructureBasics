{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "redisCacheName": {
      "type": "String"
    },
    "firewallRuleName": {
      "type": "string",
      "defaultValue": "defaultRuleName",
      "metadata": {
        "description": "The name of the firewall rule"
      }
    },
    "ipRangeDetails": {
      "type": "object",
      "defaultValue": {
        "startIP": "172.201.169.192",
        "endIP": "172.201.169.208"
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.Cache/Redis/firewallRules",
      "apiVersion": "2024-04-01-preview",
      "name": "[concat(parameters('redisCacheName'), '/', parameters('firewallRuleName'))]",
      "dependsOn": [],
      "properties": "[parameters('ipRangeDetails')]"
    }
  ],
  "outputs": {
    "redisResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/Redis', parameters('redisCacheName'))]"
    }
  }
}