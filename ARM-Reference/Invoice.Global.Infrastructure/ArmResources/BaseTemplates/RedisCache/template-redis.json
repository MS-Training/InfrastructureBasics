{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceNames": {
      "type": "Object",
      "defaultValue": {},
      "metadata": {
        "description": "The name of the Keyvault where to store the secrets"
      }
    },
    "redisCacheName": {
      "type": "String"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location of the data factory. "
      }
    },
    "redisVersion": {
      "type": "string",
      "defaultValue": "6"
    },
    "skuCapacity": {
      "type": "int",
      "defaultValue": 1
    },
    "skuFamily": {
      "type": "string",
      "defaultValue": "C"
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard"
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled"
    },
    "workspaceId": {
      "type": "string",
      "defaultValue": "workspaceID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace "
      }
    }
  },
  "variables": {
    "redisCacheId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.Cache/Redis/',parameters('redisCacheName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Cache/Redis",
      "apiVersion": "2021-06-01",
      "name": "[parameters('redisCacheName')]",
      "location": "[parameters('location')]",
      "properties": {
        "redisVersion": "[parameters('redisVersion')]",
        "minimumTlsVersion": "1.2",
        "sku": {
          "name": "[parameters('skuName')]",
          "family": "[parameters('skuFamily')]",
          "capacity": "[parameters('skuCapacity')]"
        },
        "enableNonSslPort": false,
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "redisConfiguration": {}
      },
      "resources": [
        {
          "type": "providers/diagnosticSettings",
          "name": "[concat('Microsoft.Insights/', concat(parameters('redisCacheName'),'-Diagnostics'))]",
          "dependsOn": [
            "[parameters('redisCacheName')]"
          ],
          "apiVersion": "2021-05-01-preview",
          "properties": {
            "name": "[concat(parameters('redisCacheName'),'Diagnostics')]",
            "workspaceId": "[parameters('workspaceId')]",
            "logAnalyticsDestinationType": "Dedicated",
            "logs": [
              {
                "category": "ConnectedClientList",
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              }
            ],
            "metrics": [
              {
                "category": "AllMetrics",
                "enabled": true,
                "retentionPolicy": {
                  "enabled": false,
                  "days": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "condition": "[not(empty(parameters('resourceNames')))]",
      "name": "[concat('AddRedisSecrets-',parameters('redisCacheName'),'-ToKeyvault')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat('Microsoft.Cache/Redis/', parameters('redisCacheName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault-secrets', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          },
          "secretsObject": {
            "value": {
              "secrets": [
                {
                  "secretName": "[concat('kv-',parameters('redisCacheName'),'-PrimaryKey')]",
                  "secretValue": "[listKeys(variables('redisCacheId'),'2021-06-01').PrimaryKey]"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "redisResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/Redis', parameters('redisCacheName'))]"
    }
  }
}