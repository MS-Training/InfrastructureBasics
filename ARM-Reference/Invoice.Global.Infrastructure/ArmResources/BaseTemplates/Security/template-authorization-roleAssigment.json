{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceIdToAddAccessTo": {
      "type": "string",
      "metadata": {
        "description": "The resourceId where the access needs to be added to"
      }
    },
    "ObjectIdToGrantAccess": {
      "type": "string",
      "metadata": {
        "description": "Specifies the object ID of a user, service principal or security group in the Azure Active Directory tenant for the vault. The object ID must be unique for the list of access policies. Get it by using Get-AzADUser or Get-AzADServicePrincipal cmdlets."
      }
    },
    "roleDefinitionObjectId": {
      "type": "string",
      "metadata": {
        "description": "The Guid Object id of he role definition"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(concat(parameters('resourceIdToAddAccessTo'),parameters('ObjectIdToGrantAccess'),parameters('roleDefinitionObjectId')))]",
      "scope": "[parameters('resourceIdToAddAccessTo')]",
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', parameters('roleDefinitionObjectId'))]",
        "principalId": "[parameters('ObjectIdToGrantAccess')]"
      }
    }
  ],
  "outputs": {
  }
}