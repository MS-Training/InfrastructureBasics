{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "serviceBusNamespace": {
      "type": "string",
      "metadata": {
        "description": "Name of the Service Bus namespace"
      }
    },
    "serviceBusSkuName": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Basic",
        "Standard",
        "Premium"
      ],
      "metadata": {
        "description": "The messaging tier for the Service Bus namespace"
      }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Enable public network access to the namespace"
      }
    },
    "disableLocalAuth": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Disable local authentication methods (SAS keys)"
      }
    },
    "zoneRedundant": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable zone redundancy for the namespace (Premium tier only)"
      }
    },
    "workSpaceResourceId": {
      "type": "string",
      "defaultValue": "workspaceID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace"
      }
    }
  },
  "variables": {
    "isPremiumTier": "[equals(parameters('serviceBusSkuName'), 'Premium')]"
  },
  "resources": [
    {
      "comments": "Creation of the Service Bus Namespace and Diagnostics.",
      "apiVersion": "2024-01-01",
      "name": "[parameters('serviceBusNamespace')]",
      "type": "Microsoft.ServiceBus/Namespaces",
      "location": "[resourceGroup().location]",
      "sku": {
        "name": "[parameters('serviceBusSkuName')]",
        "tier": "[parameters('serviceBusSkuName')]"
      },
      "properties": {      
        "minimumTlsVersion": "1.2",
        "premiumMessagingPartitions": "[if(variables('isPremiumTier'), 1, 0)]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "disableLocalAuth": "[parameters('disableLocalAuth')]",
        "zoneRedundant": "[if(variables('isPremiumTier'), parameters('zoneRedundant'), false())]"
      },
      "resources": [
        {
          "comments": "Creates the default Diagnostics Workspace for the Service Bus Namespace being created.",
          "type": "providers/diagnosticSettings",
          "name": "[concat('Microsoft.Insights/', concat(parameters('serviceBusNamespace'),'-Diagnostics'))]",
          "dependsOn": [
            "[parameters('serviceBusNamespace')]"
          ],
          "apiVersion": "2021-05-01-preview",
          "properties": {
            "name": "[concat(parameters('serviceBusNamespace'),'Diagnostics')]",
            "workspaceId": "[parameters('workSpaceResourceId')]",
            "logAnalyticsDestinationType": "Dedicated",
            "logs": [
              {
                "category": "OperationalLogs",
                "categoryGroup": null,
                "enabled": true,
                "retentionPolicy": {
                  "days": 0,
                  "enabled": false
                }
              }
            ],
            "metrics": [
              {
                "category": "AllMetrics",
                "enabled": true,
                "retentionPolicy": {
                  "enabled": false,
                  "days": 0
                }
              }
            ]
          }
        }
      ]
    }
  ]
}