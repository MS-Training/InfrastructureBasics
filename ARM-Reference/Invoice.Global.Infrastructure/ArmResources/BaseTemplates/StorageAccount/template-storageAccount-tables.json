{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage Account in which blob container needs to be deployed"
      }
    },
    "tableNames": {
      "type": "array",
      "metadata": {
        "description": "Table name which needs to be deployed"
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "name": "[concat(parameters('storageAccountName'), '/default/', parameters('tableNames')[copyIndex('copyTables')])]",
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2022-05-01",
      "copy": {
        "name": "copyTables",
        "count": "[length(parameters('tableNames'))]"
      },
      "dependsOn": [],
      "properties": {}
    }
  ]
}