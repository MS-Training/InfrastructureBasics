{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmName": {
      "type": "string",
      "metadata": {
        "description": "Name of the VM"
      }
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Number of VMs to deploy"
      }
    },
    "driveConfig": {
      "type": "String",
      "defaultValue": "-DriveString E:200,O:200,T:200,H:200,M:100 -OSAllocationUnitSize 65536",
      "metadata": {
        "description": "DriveString Is composed of the Drive letter plus the size of the Virtual Disk in GB, OSAllocationUnitSize is the way the drive will be formatted"
      }
    },
    "serviceAccount": {
      "minLength": 1,
      "type": "String",
      "defaultValue": "redmond\\mssoadev",
      "metadata": {
        "description": "Account for domain joining, ex. redmond\\serviceaccount"
      }
    },
    "serviceAccountPassword": {
      "minLength": 1,
      "type": "SecureString",
      "metadata": {
        "description": "Password for domain joining"
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "The name of the storage account that will be use for cluster witness "
      }
    },
    "witnessSaAccessKey": {
      "minLength": 1,
      "type": "String",
      "metadata": {
        "description": "the access key to the storage account"
      }
    },
    "vmExtensionName": {
      "type": "string",
      "defaultValue": "CustomScriptExtension",
      "metadata": {
        "description": "Extension name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "The region where the VM is deployed"
      }
    },
    "powershellFileName": {
      "type": "string",
      "defaultValue": "-Verbose",
      "metadata": {
        "description": "This is the name of the PowerShell File that will be executed example createConfig.ps1. This File should be part of Scripts folder in the blob"
      }
    },
    "powershellFileBlobUrl": {
      "type": "string"
    }
  },
  "variables": {
    "powershellFileExecution": "powershell.exe -ExecutionPolicy Unrestricted -File ./Scripts/",
    "apiVersion": "2019-07-01",
    "powershellParameters": "[concat( '-ClusterName ', parameters('vmName'),
                                      ' -VMName ', parameters('vmName'), 
                                      ' -InstanceCount ',parameters('numberOfInstances') ,
                                      ' -saName ',parameters('storageAccountName'),
                                      ' -accessKey ','\"',parameters('witnessSaAccessKey'),'\"',
                                      ' -ClusterSetupAccount ',parameters('serviceAccount'),
                                      ' -ClusterSetupPassword ','\"',parameters('serviceAccountPassword'),'\" ', 
                                      parameters('driveConfig'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "name": "[concat(parameters('vmName'),'1/', parameters('vmExtensionName'))]",
      "apiVersion": "[variables('apiVersion')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.7",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "[parameters('powershellFileBlobUrl')]"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat(variables('powershellFileExecution'), parameters('powershellFileName'), ' ', variables('powershellParameters'))]"
        }
      }
    }
  ]
}
