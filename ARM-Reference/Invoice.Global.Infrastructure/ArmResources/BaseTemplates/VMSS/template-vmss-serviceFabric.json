{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "scaleSetName": {
      "type": "string",
      "defaultValue": "Cluster",
      "metadata": {
        "description": "Name of your cluster - Between 3 and 23 characters. Letters and numbers only"
      }
    },
    "scaleSetRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "localAdminUserName": {
      "type": "string",
      "defaultValue": "ITSVC0",
      "metadata": {
        "description": "Remote desktop user Id"
      }
    },
    "localAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Remote desktop user password. Must be a strong password"
      }
    },
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "workspaceResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics Resource Group Name"
      }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "The resource id of a user assigned managed Identity"
      }
    },
    "vmImagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsServer",
      "metadata": {
        "description": "VM image Publisher"
      }
    },
    "vmImageOffer": {
      "type": "string",
      "defaultValue": "WindowsServer",
      "metadata": {
        "description": "VM image offer"
      }
    },
    "vmImageSku": {
      "type": "string",
      "defaultValue": "2022-Datacenter",
      "metadata": {
        "description": "VM image SKU"
      }
    },
    "vmImageVersion": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "VM image version"
      }
    },
    "storageAccountType": {
      "type": "string",
      "allowedValues": [
        "Standard_LRS",
        "Standard_GRS",
        "Premium_LRS"
      ],
      "defaultValue": "Standard_LRS",
      "metadata": {
        "description": "Replication option for the VM image storage account"
      }
    },
    "enableAutomaticOSUpgrade": {
      "type": "bool",
      "defaultValue": true
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 3,
      "metadata": {
        "description": "Instance count for node type"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_D2_v3"
    },
    "virtualNetwork": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name for the VirtualNetwork"
      }
    },
    "vnetResourceGroup": {
      "type": "string",
      "defaultValue": "ERNetwork-DB",
      "metadata": {
        "description": "Name for the Resource Group that contains VirtualNetwork"
      }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "Subnet1",
      "metadata": {
        "description": "Name for the subnet"
      }
    },
    "loadBalancerName": {
      "type": "string"
    },
    "clusterEndpoint": {
      "type": "string"
    },
    "nodeTypeRef": {
      "type": "string"
    },
    "durabilityLevel": {
      "type": "string"
    },
    "subnetAddressPrefix": {
      "type": "string"
    },
    "certificateCommonNames": {
      "type": "string"
    },
    "certificateKeyvaultUrlList": {
      "type": "array"
    },
    "codeIntegrityMode": {
      "type": "string",
      "defaultValue": "enforce"
    },
    "gcsGenevaAccount": {
      "type": "string",
      "defaultValue": "InvoiceGeneva"
    },
    "gcsConfigVersion": {
      "type": "string",
      "defaultValue": "1.4"
    },
    "gcsEnvironment": {
      "type": "string",
      "defaultValue": "DiagnosticsPROD"
    },
    "gcsNamespace": {
      "type": "string",
      "defaultValue": "InvoiceGene"
    },
    "gscMonitoringRegion": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "gcsMonitoringRole": {
      "type": "string",
      "defaultValue": "InvoiceGene"
    }
  },
  "variables": {
    "nicName": "[tolower(concat(parameters('scaleSetName'),'nic'))]",
    "overProvision": false,
    "vnetSubscriptionid": "[subscription().subscriptionId]",
    "vnetId": "[concat('/subscriptions/',variables('vnetSubscriptionid'),'/resourceGroups/',parameters('vnetResourceGroup'),'/providers/Microsoft.Network/virtualnetworks/',parameters('virtualNetwork'))]",
    "subnetName": "[parameters('subnetName')]",
    "subnetRef": "[concat(variables('vnetId'), '/subnets/', variables('subnetName'))]",
    "publicLblresourceId": "[resourceId('Microsoft.Network/loadBalancers',parameters('loadBalancerName'))]",
    "publicLblBackEndPoolId": "[concat(variables('publicLblresourceId'),'/backendAddressPools/',parameters('scaleSetName'),'Nodes')]",
    "internalLoadBalancerName": "[tolower(concat(parameters('loadBalancerName'),'internal'))]",
    "privateLblresourceId": "[resourceId('Microsoft.Network/loadBalancers',variables('internalLoadBalancerName'))]",
    "privateLblBackEndPoolId": "[concat(variables('privateLblresourceId'),'/backendAddressPools/',parameters('scaleSetName'),'Nodes')]",
    "lblRemoteDesktopNatRule": "[concat(variables('publicLblresourceId'),'/inboundNatPools/RemoteDesktopRule')]",
    "powershellFileExecution": "powershell.exe -ExecutionPolicy Unrestricted -File ./Scripts/",
    "imageReferenceConfigs": {
      "publicGalleryImageConfig": {
        "publisher": "[parameters('vmImagePublisher')]",
        "offer": "[parameters('vmImageOffer')]",
        "sku": "[parameters('vmImageSku')]",
        "version": "[parameters('vmImageVersion')]"
      },
      "privateGalleryImageConfig": {
        "sharedGalleryImageId": "[concat('/sharedGalleries/WINDOWSSERVER.DotNet.1P/images/',parameters('vmImageSku'),'/versions/',parameters('vmImageVersion'))]"
      }
    }
  },
  "resources": [
    {
      "apiVersion": "2021-11-01",
      "type": "Microsoft.Compute/virtualMachineScaleSets",
      "name": "[parameters('scaleSetName')]",
      "location": "[parameters('scaleSetRegion')]",
      "dependsOn": [
      ],
      "identity": {
        "type": "SystemAssigned, UserAssigned",
        "userAssignedIdentities": {
          "[parameters('userAssignedIdentityResourceId')]": {}
        }
      },
      "properties": {
        "overprovision": "[variables('overProvision')]",
        "upgradePolicy": {
          "automaticOSUpgradePolicy": {
            "enableAutomaticOSUpgrade": "[parameters('enableAutomaticOSUpgrade')]"
          },
          "mode": "Automatic"
        },
        "virtualMachineProfile": {
          "extensionProfile": {
            "extensions": [
              {
                "name": "GenevaMonitoring",
                "properties": {
                  "publisher": "Microsoft.Azure.Geneva",
                  "type": "GenevaMonitoring",
                  "typeHandlerVersion": "2.0",
                  "enableAutomaticUpgrade": true,
                  "autoUpgradeMinorVersion": true,
                  "protectedSettings": {},
                  "settings": {
                    "configurations": [
                      {
                        "ServiceArguments": {
                          "Version": "1.0"
                        },
                        "UserArguments": {
                          "GcsGenevaAccount": "[parameters('gcsGenevaAccount')]",
                          "GcsAuthIdType": "AuthMSIToken",
                          "ManagedIdentity": "[concat('object_id#', reference(parameters('userAssignedIdentityResourceId'), '2018-11-30').principalId)]",
                          "LocalPath": "C:\\Monitoring_1",
                          "GenevaConfigVersion": "[parameters('gcsConfigVersion')]",
                          "GcsEnvironment": "[parameters('gcsEnvironment')]",
                          "GcsNamespace": "[parameters('gcsNamespace')]",
                          "GcsRegion": "[parameters('gscMonitoringRegion')]"
                        },
                        "ConstantVariables": {
                          "MONITORING_TENANT": "[parameters('scaleSetName')]",
                          "MONITORING_DATACENTER": "[parameters('gscMonitoringRegion')]",
                          "MONITORING_ROLE": "[parameters('gcsMonitoringRole')]",
                          "AZSECPACK_CODEINTEGRITY_ENFORCE": "[parameters('codeIntegrityMode')]"
                        },
                        "ExpandVariables": {
                          "MONITORING_ROLE_INSTANCE": "%COMPUTERNAME%"
                        }
                      }
                    ]
                  }
                }
              },
              {
                "name": "KVVMExtensionForWindows",
                "properties": {
                  "publisher": "Microsoft.Azure.KeyVault",
                  "type": "KeyVaultForWindows",
                  "typeHandlerVersion": "1.0",
                  "enableAutomaticUpgrade": true,
                  "autoUpgradeMinorVersion": true,
                  "settings": {
                    "secretsManagementSettings": {
                      "pollingIntervalInS": "3600",
                      "certificateStoreName": "MY",
                      "linkOnRenewal": false,
                      "certificateStoreLocation": "LocalMachine",
                      "requireInitialSync": true,
                      "observedCertificates": "[parameters('certificateKeyvaultUrlList')]"
                    },
                    "authenticationSettings": {
                      "msiEndpoint": "http://169.254.169.254/metadata/identity/oauth2/token",
                      "msiClientId": "[reference(parameters('userAssignedIdentityResourceId'), '2018-11-30').clientId]"
                    }
                  },
                  "provisionAfterExtensions": [
                    "GenevaMonitoring"
                  ]
                }
              },
              {
                "name": "ServiceFabric",
                "properties": {
                  "type": "ServiceFabricNode",
                  "autoUpgradeMinorVersion": false,
                  "publisher": "Microsoft.Azure.ServiceFabric",
                  "settings": {
                    "clusterEndpoint": "[parameters('clusterEndpoint')]",
                    "nodeTypeRef": "[tolower(parameters('nodeTypeRef'))]",
                    "dataPath": "D:\\SvcFab",
                    "durabilityLevel": "[parameters('durabilityLevel')]",
                    "nicPrefixOverride": "[parameters('subnetAddressPrefix')]",
                    "certificate": {
                      "commonNames": [
                        "[parameters('certificateCommonNames')]"
                      ]
                    }
                  },
                  "typeHandlerVersion": "1.1",
                  "provisionAfterExtensions": [
                    "KVVMExtensionForWindows"
                  ]
                }
              },
              {
                "name": "Microsoft.Azure.Security.AntimalwareSignature.AntimalwareConfiguration",
                "properties": {
                  "autoUpgradeMinorVersion": true,
                  "enableAutomaticUpgrade": true,
                  "publisher": "Microsoft.Azure.Security.AntimalwareSignature",
                  "type": "AntimalwareConfiguration",
                  "typeHandlerVersion": "2.0",
                  "settings": {},
                  "provisionAfterExtensions": [
                    "ServiceFabric"
                  ]
                }
              },
              {
                "name": "CodeIntegrityAgent",
                "properties": {
                  "autoUpgradeMinorVersion": true,
                  "enableAutomaticUpgrade": true,
                  "publisher": "Microsoft.Azure.Security.WindowsCodeIntegrity",
                  "type": "CodeIntegrityAgent",
                  "typeHandlerVersion": "1.0",
                  "settings": {},
                  "provisionAfterExtensions": [
                    "Microsoft.Azure.Security.AntimalwareSignature.AntimalwareConfiguration"
                  ]
                }
              }
            ]
          },
          "networkProfile": {
            "networkInterfaceConfigurations": [
              {
                "name": "[concat(variables('nicName'), '-0')]",
                "properties": {
                  "ipConfigurations": [
                    {
                      "name": "[concat(variables('nicName'),'-',0)]",
                      "properties": {
                        "loadBalancerBackendAddressPools": [
                          {
                            "id": "[variables('publicLblBackEndPoolId')]"
                          },
                          {
                            "id": "[variables('privateLblBackEndPoolId')]"
                          }
                        ],
                        "loadBalancerInboundNatPools": [
                          {
                            "id": "[variables('lblRemoteDesktopNatRule')]"
                          }
                        ],
                        "subnet": {
                          "id": "[variables('subnetRef')]"
                        }
                      }
                    }
                  ],
                  "primary": true
                }
              }
            ]
          },
          "osProfile": {
            "adminPassword": "[parameters('localAdminPassword')]",
            "adminUsername": "[parameters('localAdminUsername')]",
            "computernamePrefix": "[parameters('scaleSetName')]",
            "windowsConfiguration": {
              "enableAutomaticUpdates": false
            }
          },
          "storageProfile": {
            "imageReference": "[variables('imageReferenceConfigs').privateGalleryImageConfig]",
            "osDisk": {
              "caching": "ReadWrite",
              "createOption": "FromImage",
              "managedDisk": {
                "storageAccountType": "[parameters('StorageAccountType')]"
              }
            }
          },
          "securityProfile": {
            "securityType": "TrustedLaunch",
            "uefiSettings": {
              "secureBootEnabled": true,
              "vTpmEnabled": true
            }
          }
        }
      },
      "sku": {
        "name": "[parameters('vmSize')]",
        "capacity": "[parameters('numberOfInstances')]",
        "tier": "Standard"
      },
      "tags": {
        "azcertinstaller_msinternalcertstore": "true",
        "azsecpack": "prod"
      }
    }
  ],
  "outputs": {
    "vmssIdentityObjectId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Compute/virtualMachineScaleSets', parameters('scaleSetName')), '2022-03-01', 'full').identity.principalId]"
    },
    "vmssResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Compute/virtualMachineScaleSets', parameters('scaleSetName'))]"
    }
  }
}