{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "loadBalancerName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Load Balancer"
      }
    },
    "location": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Thw Location of the Load Balancer"
      }
    },
    "virtualNetworkSubnetReferenceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name for the VirtualNetwork"
      }
    },
    "sessionPersistence": {
      "type": "string",
      "defaultValue": "SourceIP"
    },
    "enableFloatingIp": {
      "type": "bool",
      "defaultValue": true
    },
    "loadBalancingRuleName": {
      "type": "string",
      "defaultValue": "lbrule"
    },
    "backEndPort": {
      "type": "int",
      "defaultValue": 1433
    },
    "frontEndPort": {
      "type": "int",
      "defaultValue": 1433
    }
  },
  "variables": {
  },
  "resources": [
    {
      "name": "[toupper(parameters('loadBalancerName'))]",
      "apiVersion": "2020-05-01",
      "type": "Microsoft.Network/loadBalancers",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "dependsOn": [
      ],
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "LoadBalancerFrontEnd",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[parameters('virtualNetworkSubnetReferenceId')]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "BackendPool1"
          }
        ],
        "loadBalancingRules": [
          {
            "properties": {
              "frontendIPConfiguration": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/frontendIPConfigurations/LoadBalancerFrontend')]"
              },
              "backendAddressPool": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/backendAddressPools/BackendPool1')]"
              },
              "probe": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/probes/lbprobe')]"
              },
              "protocol": "All",
              "frontendPort": "[parameters('frontEndPort')]",
              "backendPort": "[parameters('backEndPort')]",
              "enableFloatingIP": "[parameters('enableFloatingIp')]",
              "loadDistribution": "[parameters('sessionPersistence')]",
              "enableTcpReset": false,
              "idleTimeoutInMinutes": 4,
              "disableOutboundSnat": false
            },
            "name": "[parameters('loadBalancingRuleName')]"
          }
        ],
        "probes": [
          {
            "properties": {
              "protocol": "Tcp",
              "port": 50001,
              "intervalInSeconds": 15,
              "numberOfProbes": 2
            },
            "name": "lbprobe"
          }
        ]
      }
    }
  ],
  "outputs": {
  }
}
