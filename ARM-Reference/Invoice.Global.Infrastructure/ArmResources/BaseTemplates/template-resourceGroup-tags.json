{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "type": "string",
      "maxLength": 6,
      "metadata": {
        "description": "Abbreviation string to define the environment i.e dev, int, ppe, prd"
      }
    },
    "componentId": {
      "defaultValue": "f97fb69f-f120-474f-8c62-3bffec8a6bdb",
      "type": "String",
      "metadata": {
        "description": "The Component id. i.e f97fb69f-f120-474f-8c62-3bffec8a6bdb"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "type": "Microsoft.Resources/tags",
      "name": "default",
      "apiVersion": "2019-10-01",
      "dependsOn": [],
      "properties": {
        "tags": {
          "ComponentID": "[parameters('componentId')]",
          "Env": "[if(contains(tolower(parameters('environment')),'prd'),'Production','Pre-Production')]"
        }
      }
    }
  ]
}
