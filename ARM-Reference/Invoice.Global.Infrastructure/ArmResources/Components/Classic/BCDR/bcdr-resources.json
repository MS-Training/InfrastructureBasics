{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "condition": "[parameters('settings').BCDRResources.createLoadBalancers]",
      "name": "[concat(parameters('resourceNames').baseName, parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].serverTag,'-createLBLs')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[toupper(concat(parameters('resourceNames').baseResourceGroupName, parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].serverTag,'-',parameters('resourceNames').serviceLayer))]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createLoadBalancers",
        "count": "[length(parameters('settings').BCDRResources.loadBalancedComponents)]"
      },
      "dependsOn": [],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VirtualMachine-template-ilb', '/versions/v1')]"
        },
        "parameters": {
          "loadBalancerName": {
            "value": "[toupper(concat(parameters('resourceNames').baseName,parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].serverTag, parameters('resourceNames').environment, 'lblha'))]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "virtualNetworkSubnetReferenceId": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].vnetResourceGroupName,'/providers/Microsoft.Network/virtualnetworks/',parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].lbVnetName,'/subnets/Subnet-1')]"
          },
          "sessionPersistence": {
            "value": "[if(equals(toupper(parameters('settings').BCDRResources.loadBalancedComponents [copyIndex()].serverTag),'IIS'),'SourceIP','Default')]"
          },
          "enableFloatingIp": {
            "value": false
          },
          "backEndPort": {
            "value": 0
          },
          "frontEndPort": {
            "value": 0
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').BCDRResources.createAvSets]",
      "name": "[concat(parameters('resourceNames').baseName, parameters('settings').BCDRResources.avsetComponentList [copyIndex()],'-createAvSet')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[toupper(concat(parameters('resourceNames').baseResourceGroupName, parameters('settings').BCDRResources.avsetComponentList [copyIndex()],'-',parameters('resourceNames').serviceLayer))]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createAvSetLoop",
        "count": "[length(parameters('settings').BCDRResources.avsetComponentList)]"
      },
      "dependsOn": [],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VirtualMachine-template-avset', '/versions/v1')]"
        },
        "parameters": {
          "availabilitySetName": {
            "value": "[toupper(concat(parameters('resourceNames').baseName, parameters('settings').BCDRResources.avsetComponentList [copyIndex()],parameters('resourceNames').environment))]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
