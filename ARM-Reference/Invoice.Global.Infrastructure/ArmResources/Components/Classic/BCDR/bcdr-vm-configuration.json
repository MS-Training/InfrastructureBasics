{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmList": {
      "type": "array"
    },
    "vmResourceGroupName": {
      "type": "string"
    },
    "clusterType": {
      "type": "string",
      "defaultValue": "None"
    },
    "clusterRoleName": {
      "type": "string",
      "defaultValue": "None"
    },
    "lblname": {
      "type": "string",
      "defaultValue": "None"
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "name": "[concat(parameters('vmList') [copyIndex()],'-InstallExtensions')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('vmResourceGroupName')]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "InstallExtensions",
        "count": "[length(parameters('vmList'))]"
      },
      "dependsOn": [],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Classic-bcdr-vm-extensions', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[parameters('vmList') [copyIndex()]]"
          },
          "vmRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').vmEncryptionKeyVaultName]"
          },
          "keyVaultResourceGroup": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "diagnosticsStorageAccountName": {
            "value": "[parameters('resourceNames').diagnosysStorageAccountName]"
          },
          "diagnosticsResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "isS2DCluster": {
            "value": "[if(equals(toupper(parameters('clusterType')),'S2D'),true(),false())]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmList') [copyIndex()],'-RunScripts')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('vmResourceGroupName')]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "InstallExtensions",
        "count": "[length(parameters('vmList'))]"
      },
      "dependsOn": [
        "[concat(parameters('vmList') [copyIndex()],'-InstallExtensions')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Classic-bcdr-vm-scripts', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[parameters('vmList') [copyIndex()]]"
          },
          "vmResourceGroupName": {
            "value": "[parameters('vmResourceGroupName')]"
          },
          "vmRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "workspaceId": {
            "reference": {
              "keyVault": {
                "id": "[parameters('resourceNames').appKeyVaultId]"
              },
              "secretName": "[concat('kv-',parameters('resourceNames').workspaceName,'-WorkSpaceId')]"
            }
          },
          "workspaceKey": {
            "reference": {
              "keyVault": {
                "id": "[parameters('resourceNames').appKeyVaultId]"
              },
              "secretName": "[concat('kv-',parameters('resourceNames').workspaceName,'-WorkSpaceKey')]"
            }
          },
          "cseoAutomationDSCServerUrl": {
            "reference": {
              "keyVault": {
                "id": "[parameters('resourceNames').appKeyVaultId]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCServerUrl]"
            }
          },
          "cseoAutomationDSCRegistrationKey": {
            "reference": {
              "keyVault": {
                "id": "[parameters('resourceNames').appKeyVaultId]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCRegistrationKey]"
            }
          },
          "isCluster": {
            "value": "[if(equals(toupper(parameters('clusterType')),'NONE'),false(),true())]"
          },
          "clusterRoleName": {
            "value": "[parameters('clusterRoleName')]"
          },
          "lblName": {
            "value": "[parameters('lblName')]"
          },
          "resourceNames": {
            "value": "[parameters('resourceNames')]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
