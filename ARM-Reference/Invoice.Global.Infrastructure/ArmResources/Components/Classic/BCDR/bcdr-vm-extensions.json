{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    
    "vmName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "vmRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the KeyVault to place the volume encryption key"
      }
    },
    "keyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group of the KeyVault"
      }
    },
    "diagnosticsStorageAccountName": {
      "type": "string",
      "minLength": 3
    },
    "diagnosticsResourceGroupName": {
      "type": "string",
      "minLength": 3
    },
    "isS2DCluster": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "This Flag is only used to create S2D Cluster. If you want to create an S2D Cluster look at component Domain Servers as sample otherwise leave this as No its default value"
      }
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/"
  },
  "resources": [
    {
      "name": "[concat(parameters('vmName'),'-GuestConfiguration')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-guest-configuration', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),'-AddDiskEncryption')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat(parameters('vmName'),'-GuestConfiguration')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-disk-encryption', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          },
          "keyVaultResourceGroup": {
            "value": "[parameters('keyVaultResourceGroup')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "volumeType": {
            "value": "[if(parameters('isS2DCluster'),'OS','All')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "name": "[concat(parameters('vmName'),'-IaaSDiagnostics')]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat(parameters('vmName'),'-AddDiskEncryption')]"
      ],
      "properties": {
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-log-IaaSDiagnostics', '/versions/v1')]"
        },
        "mode": "Incremental",
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "applicationDiagnosticsStorageAccountName": {
            "value": "[parameters('DiagnosticsStorageAccountName')]"
          },
          "diagnosticsResourceGroupName": {
            "value": "[parameters('diagnosticsResourceGroupName')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),'-AddAntiMalwareExtension')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat(parameters('vmName'),'-IaaSDiagnostics')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-antimalware', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),'-AddDependencyAgent')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat(parameters('vmName'),'-AddAntiMalwareExtension')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-dependency-agent', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    }
  ]
}