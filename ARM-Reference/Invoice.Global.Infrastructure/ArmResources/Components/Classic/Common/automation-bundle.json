{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "artifactsSaBaseUri": {
      "type": "string"
    },
    "artifactsSaSasToken": {
      "type": "securestring"
    },
    "serviceAccountPassword": {
      "type": "securestring"
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
    "automationAccountConfiguration": {
      "hybridWorkerGroup": "[if(equals(toLower(parameters('settings').automationAccount.hybridWorkerGroup),'dynamic'),
                            concat(parameters('resourceNames').resourceBaseName, 'hwg',tolower(parameters('resourceNames').serviceLayer)),
                            parameters('settings').automationAccount.hybridWorkerGroup)]",
      "variables": [
        {
          "name": "SubscriptionID",
          "value": "[concat('\"',subscription().subscriptionId,'\"')]",
          "description": "SubscriptionID",
          "isEncrypted": false
        }
      ],
      "schedules": {
        "daily": {
          "schedules": [
            {
              "environmentsToDeploy": "prd,prod,ppe,tst,int,dev",
              "name": "Daily_Sample_Schedule",
              "startTime": "06:00",
              "interval": 12,
              "frequency": "hour"
            }
          ]
        },
        "weekly": {
          "schedules": [
            {
              "environmentsToDeploy": "prd,prod,ppe,tst,int,dev",
              "name": "Weekly_Sample_Schedule",
              "startTime": "01:38",
              "interval": 1,
              "frequency": "week",
              "day": [
                "Sunday"
              ]
            }
          ]
        },
        "monthly": {
          "schedules": [
            {
              "environmentsToDeploy": "prd,prod,ppe,tst,int,dev",
              "name": "Monthly_Sample_Schedule",
              "startTime": "04:00",
              "interval": 1,
              "frequency": "month",
              "day": [
                31
              ]
            }
          ]
        }
      },
      "runbooks": {
        "baseUrl": "[concat(parameters('artifactsSaBaseUri'), parameters('resourceNames').scriptsTemplatePath)]",
        "sasToken": "[parameters('artifactsSaSasToken')]",
        "runbooksDetails": [
          {
            "environmentsToDeploy": "prd,prod,ppe,tst,int,dev",
            "name": "BaseVirtualMachineConfiguration",
            "type": "PowerShell",
            "fileExtension": ".ps1"
          }
        ]
      }
    },
    "automationAccountMainModules": [
      {
        "moduleName": "AzureRM.profile",
        "version": "5.8.3"
      },
      {
        "moduleName": "Azure.Storage",
        "version": "4.6.1"
      }
    ],
    "automationAccountModules": [
      {
        "moduleName": "Azure",
        "version": "5.3.0"
      },
      {
        "moduleName": "AzureRM.Automation",
        "version": "6.1.1"
      },
      {
        "moduleName": "AzureRM.Compute",
        "version": "5.9.1"
      },
      {
        "moduleName": "AzureRM.Resources",
        "version": "6.7.3"
      },
      {
        "moduleName": "AzureRM.Sql",
        "version": "4.12.1"
      },
      {
        "moduleName": "AzureRM.Storage",
        "version": "5.2.0"
      },
      {
        "moduleName": "AzureRM.Insights",
        "version": "5.1.5"
      },
      {
        "moduleName": "AzureRM.KeyVault",
        "version": "5.2.1"
      },
      {
        "moduleName": "AzureRM.OperationalInsights",
        "version": "5.0.6"
      }
    ],
    "automationAccountCredentials": [
      {
        "name": "[parameters('settings').automationAccount.runAsAccountCredName]",
        "userName": "[parameters('settings').common.serviceAccount]",
        "password": "[parameters('serviceAccountPassword')]",
        "description": "System Service AcccountPassword"
      }
    ]
  },
  "resources": [
    {
      "name": "createAutomationAccount",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "location": {
            "value": "[if(equals(toupper(parameters('settings').common.logAnalyticsLocation),'EASTUS'),'EastUS2',parameters('settings').common.logAnalyticsLocation)]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          },
          "workspaceId": {
            "value": "[parameters('resourceNames').workspaceId]"
          }
        }
      }
    },
    {
      "name": "LinkLogAnalyticsWithAutoAccount",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'LogAnalytics-template-logAnalytics-linkedServices', '/versions/v1')]"
        },
        "parameters": {
          "workspaceName": {
            "value": "[parameters('resourceNames').workspaceName]"
          },
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').automationAccount.deployVariables]",
      "name": "AddAutomationAccountVariable",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-variable', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "variableDetails": {
            "value": "[variables('automationAccountConfiguration').variables]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').automationAccount.deployRunbooks]",
      "name": "AddRunbook",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-runbook', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "location": {
            "value": "[if(equals(toupper(parameters('settings').common.logAnalyticsLocation),'EASTUS'),'EastUS2',parameters('settings').common.logAnalyticsLocation)]"
          },
          "runbooks": {
            "value": "[variables('automationAccountConfiguration').runbooks]"
          },
          "env": {
            "value": "[parameters('resourceNames').environment]"
          }
        }
      }
    },
    {
      "name": "[concat('deployMainModule-', variables('automationAccountMainModules')[copyIndex()].moduleName, '-',variables('automationAccountMainModules')[copyIndex()].version)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "copy": {
        "name": "deployMainModulesLoop",
        "count": "[length(variables('automationAccountMainModules'))]",
        "mode": "Serial"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-module', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "moduleName": {
            "value": "[variables('automationAccountMainModules')[copyIndex()].moduleName]"
          },
          "moduleVersion": {
            "value": "[variables('automationAccountMainModules')[copyIndex()].version]"
          }
        }
      }
    },
    {
      "name": "[concat('deployModule-', variables('automationAccountModules')[copyIndex()].moduleName,'-',variables('automationAccountModules')[copyIndex()].version)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount",
        "deployMainModulesLoop"
      ],
      "copy": {
        "name": "deployModulesLoop",
        "count": "[length(variables('automationAccountModules'))]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-module', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "moduleName": {
            "value": "[variables('automationAccountModules')[copyIndex()].moduleName]"
          },
          "moduleVersion": {
            "value": "[variables('automationAccountModules')[copyIndex()].version]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').automationAccount.deploySchedules]",
      "name": "AddAutomationAccountSchedules",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-schedule', '/versions/v1')]"
        },
        "parameters": {
          "hybridWorker": {
            "value": "[variables('automationAccountConfiguration').hybridWorkerGroup]"
          },
          "env": {
            "value": "[parameters('resourceNames').environment]"
          },
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "scheduleDetails": {
            "value": "[variables('automationAccountConfiguration').schedules]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').automationAccount.deployCredentials]",
      "name": "[concat('deployAutomationAccountCredentials-', variables('automationAccountCredentials')[copyIndex()].name)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAutomationAccount"
      ],
      "copy": {
        "name": "deployAutomationAccountCredentialsLoop",
        "count": "[length(variables('automationAccountCredentials'))]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AutomationAccount-template-automationAccount-credentials', '/versions/v1')]"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('resourceNames').automationAccountName]"
          },
          "credential": {
            "value": "[variables('automationAccountCredentials')[copyIndex()]]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}