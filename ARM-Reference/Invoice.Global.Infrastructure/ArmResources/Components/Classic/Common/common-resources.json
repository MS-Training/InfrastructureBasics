{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "deploymentFlags": {
      "type": "Object",
      "metadata": {
        "description": "This is the parameter file under parameters folder"
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "factoryTemplatePath": "/Factories/",
    "subnetName": "Subnet-1",
    "serviceGroupNames": [
      "vault"
    ],
    "networkAclIpRules": [
      {
        "comment": "SAW Range IPv4 (legacy) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "207.68.190.32/27"
      },
      {
        "comment": "SAW Range IPv4 range (E3+) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "157.58.216.64/26"
      }
    ],
    "comments": "The keyvault firewall is set to Allow in this file, dont change it. This setting will be set from the release definition. It will open the firewall and at the end of the deployment it will be close."
  },
  "resources": [
    {
      "condition": "[parameters('deploymentFlags').isNewEnvironment]",
      "name": "createApplicationKeyVault",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          },
          "enabledForDiskEncryption": {
            "value": false
          },
          "networkAclDefaultAction": {
            "value": "Allow"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('deploymentFlags').isNewEnvironment]",
      "name": "createVmEncryptionKeyVault",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('resourceNames').vmEncryptionKeyVaultName]"
          },
          "networkAclDefaultAction": {
            "value": "Allow"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          }
        }
      }
    },
    {
      "name": "createLogAnalytics",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'LogAnalytics-template-logAnalytics', '/versions/v1')]"
        },
        "parameters": {
          "workspaceName": {
            "value": "[parameters('resourceNames').workspaceName]"
          },
          "location": {
            "value": "[parameters('settings').common.logAnalyticsLocation]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          },
          "dataRetention": {
            "value": "[parameters('settings').common.logAnalyticsRetentionDays]"
          }
        }
      }
    },
    {
      "name": "addWindowsUpdateSolution",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createLogAnalytics"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'LogAnalytics-template-logAnalytics-solutions', '/versions/v1')]"
        },
        "parameters": {
          "workspaceName": {
            "value": "[parameters('resourceNames').workspaceName]"
          },
          "location": {
            "value": "[parameters('settings').common.logAnalyticsLocation]"
          },
          "solutionProductName": {
            "value": "Updates"
          },
          "publisher": {
            "value": "Microsoft"
          }
        }
      }
    },
    {
      "name": "createManagedIdentity",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Identity-template-managed-identity', '/versions/v1')]"
        },
        "parameters": {
          "managedIdentityName": {
            "value": "[parameters('resourceNames').managedIdentityName]"
          }
        }
      }
    },
    {
      "name": "diagnosysStorageAccount",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'StorageAccount-template-storageAccount', '/versions/v1')]"
        },
        "parameters": {
          "storageAccountName": {
            "value": "[parameters('resourceNames').diagnosysStorageAccountName]"
          },
          "storageSKU": {
            "value": "[parameters('settings').common.storageAccountSKU]"
          },
          "networkAclDefaultAction": {
            "value": "[if(parameters('deploymentFlags').isNewEnvironment,'Allow','Deny')]"
          },
          "allowSharedKeyAccess": {
            "value": false
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          }
        }
      }
    },
    {
      "name": "createAppInsights",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Insights-template-appInsights', '/versions/v1')]"
        },
        "parameters": {
          "appInsightsName": {
            "value": "[parameters('resourceNames').appInsightsName]"
          },
          "location": {
            "value": "[if(equals(tolower(parameters('settings').common.region),'westcentralus'),'centralus',tolower(parameters('settings').common.region))]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          }
        }
      }
    },
    {
      "condition": "[or(parameters('deploymentFlags').isNewEnvironment,parameters('deploymentFlags').deployCommonStorage)]",
      "name": "[concat(parameters('settings').common.storage.storageAccounts[copyIndex('createCommonStorageLoop')].storageAccountName,'-createCommonStorage')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createCommonStorageLoop",
        "count": "[length(parameters('settings').common.storage.storageAccounts)]"
      },
      "dependsOn": [
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-storageaccounts', '/versions/v1')]"
        },
        "parameters": {
          "storageAccount": {
            "value": "[parameters('settings').common.storage.storageAccounts[copyIndex('createCommonStorageLoop')]]"
          },
          "storageAccountBaseName": {
            "value": "[parameters('resourceNames').storageAccountBaseName]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').appKeyVaultName]"
          },
          "keyvaultResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          }
        }
      }
    },
    {
      "name": "AddKeyVaultDiagnostics",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault",
        "createVmEncryptionKeyVault",
        "createLogAnalytics"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault-diagnostics', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": [
              "[parameters('resourceNames').appKeyVaultName]"
            ]
          },
          "workspaceId": {
            "value": "[parameters('resourceNames').workspaceId]"
          },
          "retentionDays": {
            "value": "365"
          }
        }
      }
    },
    {
      "name": "AddUserManagedIdentityToKvAccess",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "createManagedIdentity",
        "createApplicationKeyVault"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.KeyVault/vaults/',parameters('resourceNames').appKeyVaultName)]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference('createManagedIdentity').outputs.managedIdentityObjectId.value]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.keyvaultSecretUserRoleDefinitionObjectId]"
          }
        }
      }
    },
    {
      "condition": "[or(parameters('settings').common.createPrivateEndPoints,parameters('deploymentFlags').isNewEnvironment)]",
      "name": "[concat('createCommonPvtEndPts-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createApplicationKeyVault",
        "createVmEncryptionKeyVault",
        "diagnosysStorageAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-private-endpoints', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "privateEndpointsDetails": {
            "value": [
              {
                "resourceName": "[parameters('resourceNames').appKeyVaultName]",
                "resourceGroupName": "[parameters('resourceNames').commonResourceGroupName]",
                "privateLinkServiceId": "[if(parameters('deploymentFlags').isNewEnvironment,reference('createApplicationKeyVault').outputs.keyVaultResourceId.value,parameters('resourceNames').appKeyVaultId)]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[variables('subnetName')]",
                "serviceGroupNames": "[variables('serviceGroupNames')]",
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "N/A",
                "privateDNSZoneName": "N/A"
              },
              {
                "resourceName": "[parameters('resourceNames').vmEncryptionKeyVaultName]",
                "resourceGroupName": "[parameters('resourceNames').commonResourceGroupName]",
                "privateLinkServiceId": "[if(parameters('deploymentFlags').isNewEnvironment,reference('createVmEncryptionKeyVault').outputs.keyVaultResourceId.value,parameters('resourceNames').vmKeyVaultId)]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[variables('subnetName')]",
                "serviceGroupNames": "[variables('serviceGroupNames')]",
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "N/A",
                "privateDNSZoneName": "N/A"
              },
              {
                "resourceName": "[parameters('resourceNames').diagnosysStorageAccountName]",
                "resourceGroupName": "[parameters('resourceNames').commonResourceGroupName]",
                "privateLinkServiceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').commonResourceGroupName,'/providers/Microsoft.Storage/storageAccounts/',parameters('resourceNames').diagnosysStorageAccountName)]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[variables('subnetName')]",
                "serviceGroupNames": [ "blob" ],
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "N/A",
                "privateDNSZoneName": "N/A"
              }
            ]
          }
        }
      }
    },
    {
      "condition": "[or(parameters('settings').common.createPrivateEndPoints,parameters('deploymentFlags').isNewEnvironment)]",
      "name": "[concat(parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].storageAccountName,'-createSaPvtEndPts')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createSaPvtEndPtsLoop",
        "count": "[length(parameters('settings').common.storage.storageAccounts)]"
      },
      "dependsOn": [
        "[concat('createCommonPvtEndPts-', parameters('date'))]",
        "createCommonStorageLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-private-endpoints', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "privateEndpointsDetails": {
            "value": [
              {
                "resourceName": "[concat(if(equals(tolower(parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].storageAccountName),'dynamic'),
                                             concat(parameters('resourceNames').storageAccountBaseName,parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].tag),
                                             parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].storageAccountName),
                                          if(equals(parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].numberOfInstances,1),'', copyindex(1)))]",
                "resourceGroupName": "[parameters('resourceNames').commonResourceGroupName]",
                "privateLinkServiceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').commonResourceGroupName,'/providers/Microsoft.Storage/storageAccounts/',concat(if(equals(tolower(parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].storageAccountName),'dynamic'),
                                                                                                                                                                                                                                  concat(parameters('resourceNames').storageAccountBaseName,parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].tag),
                                                                                                                                                                                                                                  parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].storageAccountName),
                                                                                                                                                                                                                                if(equals(parameters('settings').common.storage.storageAccounts[copyIndex('createSaPvtEndPtsLoop')].numberOfInstances,1),'', copyindex(1))))]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[variables('subnetName')]",
                "serviceGroupNames": [ "blob" ],
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "N/A",
                "privateDNSZoneName": "N/A"
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "appKeyVaultResourceId": {
      "type": "string",
      "value": "[if(parameters('deploymentFlags').isNewEnvironment,reference('createApplicationKeyVault').outputs.keyVaultResourceId.value,'Nothing')]"
    }
  }
}
