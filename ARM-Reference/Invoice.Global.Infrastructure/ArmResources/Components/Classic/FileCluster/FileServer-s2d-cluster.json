{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "artifactsSaBaseUri": {
      "type": "string"
    },
    "artifactsSaSasToken": {
      "type": "securestring"
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "appKeyVaultId": {
      "type": "string",
      "metadata": {
        "description": "This is the resourceId of the Keyvault where the application secrets are stored"
      }
    }
  },
  "variables": {
    "deploymentDriver": false,
    "vmBaseName": "[toupper(concat(parameters('resourceNames').baseName, parameters('settings').FileCluster.serverTag, parameters('resourceNames').environment))]",
    "loadBalancerName": "[toupper(concat(variables('vmBaseName'), 'lbl'))]",
    "armTemplateURI": "[parameters('artifactsSaBaseUri')]",
    "armTemplatesSasToken": "[parameters('artifactsSaSasToken')]",
    "numberOfInstances": "[parameters('settings').FileCluster.numberOfInstances]",
    "serviceAccount": "[parameters('settings').common.serviceAccount]",
    "listenerName": "[concat(variables('vmBaseName'),toupper(parameters('settings').FileCluster.listenerNamePostFix))]",
    "lblProbePort": "50001",
    "listOfScripts": [
      {
        "powershellFileName": "DownloadFilesFromStorageAccount.ps1",
        "powershellParameters": "[concat('-fileNameList ', '\"','AddFileServerRoleTask.ps1','\"',
                                        ' -storageAccountUri ',parameters('artifactsSaBaseUri'),parameters('resourceNames').scriptsTemplatePath,
                                        ' -SASToken ', '\"',parameters('artifactsSaSasToken'),'\"' )]",
        "isExecute": true
      }
    ]
  },
  "resources": [
    {
      "name": "createFileServers",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-vm-domainJoined', '/versions/v1')]"
        },
        "parameters": {
          "CSEOAutomationDSCRegistrationKey": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCRegistrationKey]"
            }
          },
          "CSEOAutomationDSCServerUrlKeyVault": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCServerUrl]"
            }
          },
          "CSEOSasToken": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOSasToken]"
            }
          },
          "armTemplatesSasToken": {
            "value": "[variables('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[variables('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[variables('vmBaseName')]"
          },
          "userAssignedIdentityResourceId": {
            "value": "[parameters('resourceNames').manageIdentityResourceId]"
          },
          "AvailabilitySetName": {
            "value": "[variables('vmBaseName')]"
          },
          "numberOfInstances": {
            "value": "[variables('numberOfInstances')]"
          },
          "localAdminPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.localAdminPassword]"
            }
          },
          "Domain": {
            "value": "[parameters('settings').FileCluster.domain]"
          },
          "domainJoinUserName": {
            "value": "[variables('serviceAccount')]"
          },
          "domainJoinPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "localAdmins": {
            "value": "[parameters('settings').common.localAdminsRedmond]"
          },
          "vmSize": {
            "value": "[parameters('settings').FileCluster.vmSize]"
          },
          "imagePublisher": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.Windows.imagePublisher]"
          },
          "imageOffer": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.Windows.imageOffer]"
          },
          "sku": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.Windows.sku.latest]"
          },
          "StorageAccountType": {
            "value": "[parameters('settings').FileCluster.StorageAccountType]"
          },
          "osDiskSizeGB": {
            "value": "[parameters('settings').FileCluster.osDiskSizeGB]"
          },
          "dataDiskCount": {
            "value": "[parameters('settings').FileCluster.dataDiskCount]"
          },
          "dataDiskSizeGB": {
            "value": "[parameters('settings').FileCluster.dataDiskSizeGB]"
          },
          "driveConfig": {
            "value": "[parameters('settings').FileCluster.driveConfig]"
          },
          "virtualNetwork": {
            "value": "[parameters('settings').FileCluster.virtualNetwork]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('settings').FileCluster.vnetResourceGroupName]"
          },
          "bootDiagnosysStorageAccountName": {
            "value": "[parameters('resourceNames').diagnosysStorageAccountName]"
          },
          "bootDiagnosticsResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "workspaceName": {
            "value": "[parameters('resourceNames').workspaceName]"
          },
          "workspaceResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').vmEncryptionKeyVaultName]"
          },
          "keyVaultResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "isFirstDeployment": {
            "value": "[parameters('settings').FileCluster.isFirstDeployment]"
          },
          "isS2DCluster": {
            "value": true
          },
          "AcceleratedNetworking": {
            "value": "[parameters('settings').FileCluster.acceleratedNetworking]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),'-BuildCluster')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "dependsOn": [
        "createFileServers"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId,'template-domainJoined-vm-cluster-configuration', '/versions/v1')]"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[variables('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[variables('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[variables('vmBaseName')]"
          },
          "vmRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "numberOfInstances": {
            "value": "[variables('numberOfInstances')]"
          },
          "ListenerName": {
            "value": "[variables('listenerName')]"
          },
          "driveConfig": {
            "value": "[parameters('settings').FileCluster.driveConfig]"
          },
          "loadBalancerName": {
            "value": "[variables('loadBalancerName')]"
          },
          "virtualNetworkName": {
            "value": "[parameters('settings').FileCluster.virtualNetwork]"
          },
          "vnetResourceGroupName": {
            "value": "[parameters('settings').FileCluster.vnetResourceGroupName]"
          },
          "serviceAccount": {
            "value": "[variables('serviceAccount')]"
          },
          "serviceAccountPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "backEndIpAddresses": {
            "value": "[reference('createFileServers','2019-10-01').outputs.vmIpAddresses.value]"
          },
          "isFirstDeployment": {
            "value": "[parameters('settings').FileCluster.isFirstDeployment]"
          },
          "isS2DCluster": {
            "value": true
          },
          "isHALoadBalancer": {
            "value": true
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureFileServerDirectories')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ConfigureFileServerDirectoriesLoop",
        "count": "[variables('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat(variables('vmBaseName'),'-BuildCluster')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VMExtensions-template-vm-extension-ps-script', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "powershellFileName": {
            "value": "CreateSharedFolders.ps1"
          },
          "powershellParameters": {
            "value": "[concat('-Paths ',parameters('settings').FileCluster.directories, ' -Accounts ',parameters('settings').FileCluster.sharesNTFSAccounts )]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('artifactsSaBaseUri'), parameters('resourceNames').scriptsTemplatePath, 'CreateSharedFolders.ps1', parameters('artifactsSaSasToken'))]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'), copyindex(1),'-ExecuteMultipleScripts')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ExecuteMultipleScriptsLoop",
        "count": "[variables('numberOfInstances')]"
      },
      "dependsOn": [
        "ConfigureFileServerDirectoriesLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-powershell-executer', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[concat(variables('vmBaseName'),copyIndex(1))]"
          },
          "vmRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "listOfScripts": {
            "value": "[variables('listOfScripts')]"
          },
          "resourceNames": {
            "value": "[parameters('resourceNames')]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),'-Add-Cluster-Roles')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "ExecuteMultipleScriptsLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VMExtensions-template-vm-extension-ps-script-with-secret', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(variables('vmBaseName'),1)]"
          },
          "powershellFileName": {
            "value": "CreateFileServerRole.ps1"
          },
          "powershellParameters": {
            "value": "[concat(' -ILBStaticIP ', if(parameters('settings').FileCluster.isFirstDeployment,
                                                 reference(concat(variables('vmBaseName'),'-BuildCluster')).outputs.ILBStaticIP.value,
                                                 reference(resourceid('Microsoft.Network/loadBalancers',concat(variables('loadBalancerName'),'HA')),'2020-07-01').frontendIPConfigurations[0].properties.privateIPAddress),
                              ' -clusterRoleName ', variables('ListenerName'),
                              ' -ClusterSetupAccount ', parameters('settings').common.serviceAccount)]"
          },
          "secretParameterName": {
            "value": "ClusterSetupPassword"
          },
          "secretParameterValue": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "powershellFileBlobUrl": {
            "value": "[concat(variables('armTemplateURI'), parameters('resourceNames').scriptsTemplatePath, 'CreateFileServerRole.ps1', variables('armTemplatesSasToken'))]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').FileCluster.isFirstDeployment]",
      "name": "[concat(variables('vmBaseName'),'-SetClusterIPResource')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').fileServerResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat(variables('vmBaseName'),'-Add-Cluster-Roles')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VMExtensions-template-vm-extension-ps-script', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(variables('vmBaseName'),1)]"
          },
          "powershellFileName": {
            "value": "SetClusterIPResources.ps1"
          },
          "powershellParameters": {
            "value": "[concat('-ProbePort ',variables('lblProbePort'),
                              ' -ClusterRoleName ',variables('ListenerName'),
                              ' -ILBStaticIP ', if(parameters('settings').FileCluster.isFirstDeployment,
                                                  reference(concat(variables('vmBaseName'),'-BuildCluster')).outputs.ILBStaticIP.value,
                                                  reference(resourceid('Microsoft.Network/loadBalancers',concat(variables('loadBalancerName'),'HA')),'2020-07-01').frontendIPConfigurations[0].properties.privateIPAddress))]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(variables('armTemplateURI'), parameters('resourceNames').scriptsTemplatePath, 'SetClusterIPResources.ps1', variables('armTemplatesSasToken'))]"
          }
        }
      }
    }
  ]
}