{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "artifactsSaBaseUri": {
      "type": "string"
    },
    "artifactsSaSasToken": {
      "type": "securestring"
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "appKeyVaultId": {
      "type": "string",
      "metadata": {
        "description": "This is the resourceId of the Keyvault where the application secrets are stored"
      }
    }
  },
  "variables": {
    "deploymentDriver": false,
    "vmBaseName": "[toupper(concat(parameters('resourceNames').baseName, parameters('settings').MainSQLCluster.serverTag, parameters('resourceNames').environment))]",
    "DeploymentGroupAgentArgs": "[concat('-DeploymentGroupName ',parameters('settings').common.DeploymentGroupName,' -DeploymentGroupTag ',parameters('settings').MainSQLCluster.serverTag)]",
    "loadBalancerName": "[toupper(concat(variables('vmBaseName'), 'lbl'))]",
    "armTemplateURI": "[parameters('artifactsSaBaseUri')]",
    "armTemplatesSasToken": "[parameters('artifactsSaSasToken')]",
    "numberOfInstances": "[parameters('settings').MainSQLCluster.numberOfInstances]",
    "serviceAccount": "[parameters('settings').common.serviceAccount]",
    "listenerName": "[concat(variables('vmBaseName'),toupper(parameters('settings').MainSQLCluster.listenerNamePostFix))]",
    "SQLPostScriptList": [
      {
        "powershellFileName": "SetSQLDirectories.ps1",
        "powershellParameters": "[concat('-Accounts ',parameters('settings').common.sqlNTFSAccountList, ' -SQLDriveList ', parameters('settings').MainSQLCluster.sqlDriveList)]",
        "isExecute": "[if(parameters('settings').MainSQLCluster.isFirstDeployment, true(), false())]"
      },
      {
        "powershellFileName": "EnableSQLIntransitEncryption.ps1",
        "powershellParameters": "[concat('-SQLServiceAccount ',parameters('settings').common.SQLServiceAccount)]",
        "isExecute": "[if(parameters('settings').MainSQLCluster.isFirstDeployment, true(), false())]"
      },
      {
        "powershellFileName": "PostSQLServerConfiguration.ps1",
        "powershellParameters": "[concat('-StartupParameters ', '\"-T634,-T1118,-T1222,-T2467,-T2505,-T3605,-T7451,-T8004,-T8026,-T9347,-T9348\"', ' -EnableDtc $true')]",
        "isExecute": "[if(parameters('settings').MainSQLCluster.isFirstDeployment, true(), false())]"
      }
    ]
  },
  "resources": [
    {
      "name": "createSqlServers",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sqlResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-vm-domainJoined', '/versions/v1')]"
        },
        "parameters": {
          "CSEOAutomationDSCRegistrationKey": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCRegistrationKey]"
            }
          },
          "CSEOAutomationDSCServerUrlKeyVault": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOAutomationDSCServerUrl]"
            }
          },
          "CSEOSasToken": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.CSEOSasToken]"
            }
          },
          "armTemplatesSasToken": {
            "value": "[variables('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[variables('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[variables('vmBaseName')]"
          },
          "userAssignedIdentityResourceId": {
            "value": "[parameters('resourceNames').manageIdentityResourceId]"
          },
          "AvailabilitySetName": {
            "value": "[variables('vmBaseName')]"
          },
          "numberOfInstances": {
            "value": "[variables('numberOfInstances')]"
          },
          "localAdminPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.localAdminPassword]"
            }
          },
          "Domain": {
            "value": "[parameters('settings').MainSQLCluster.domain]"
          },
          "domainJoinUserName": {
            "value": "[variables('serviceAccount')]"
          },
          "domainJoinPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "localAdmins": {
            "value": "[parameters('settings').common.localAdminsRedmond]"
          },
          "vmSize": {
            "value": "[parameters('settings').MainSQLCluster.vmSize]"
          },
          "imagePublisher": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.SQL.imagePublisher]"
          },
          "imageOffer": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.SQL.imageOffer.latest]"
          },
          "sku": {
            "value": "[parameters('settings').common.commonVMConfig.OSImages.SQL.sku]"
          },
          "StorageAccountType": {
            "value": "[parameters('settings').MainSQLCluster.StorageAccountType]"
          },
          "osDiskSizeGB": {
            "value": "[parameters('settings').MainSQLCluster.osDiskSizeGB]"
          },
          "dataDiskCount": {
            "value": "[parameters('settings').MainSQLCluster.dataDiskCount]"
          },
          "dataDiskSizeGB": {
            "value": "[parameters('settings').MainSQLCluster.dataDiskSizeGB]"
          },
          "driveConfig": {
            "value": "[parameters('settings').MainSQLCluster.driveConfig]"
          },
          "virtualNetwork": {
            "value": "[parameters('settings').MainSQLCluster.virtualNetwork]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('settings').MainSQLCluster.vnetResourceGroupName]"
          },
          "SQLAdmins": {
            "value": "[parameters('settings').common.sqlAdmins]"
          },
          "SQLServerAccount": {
            "value": "[parameters('settings').common.SQLServiceAccount]"
          },
          "SQLServerPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.SQLServiceAccountPassword]"
            }
          },
          "bootDiagnosysStorageAccountName": {
            "value": "[parameters('resourceNames').diagnosysStorageAccountName]"
          },
          "bootDiagnosticsResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "workspaceName": {
            "value": "[parameters('resourceNames').workspaceName]"
          },
          "workspaceResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "keyVaultName": {
            "value": "[parameters('resourceNames').vmEncryptionKeyVaultName]"
          },
          "keyVaultResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "isFirstDeployment": {
            "value": "[parameters('settings').MainSQLCluster.isFirstDeployment]"
          },
          "isS2DCluster": {
            "value": false
          },
          "AcceleratedNetworking": {
            "value": "[parameters('settings').MainSQLCluster.acceleratedNetworking]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureSqlDirectories')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sqlResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ConfigureSqlDirectoriesLoop",
        "count": "[variables('numberOfInstances')]"
      },
      "dependsOn": [
        "createSqlServers"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VMExtensions-template-vm-extension-ps-script', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "powershellFileName": {
            "value": "CreateSharedFolders.ps1"
          },
          "powershellParameters": {
            "value": "[concat('-Paths ',parameters('settings').MainSQLCluster.directories, ' -Accounts ',parameters('settings').MainSQLCluster.sharesNTFSAccounts )]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('artifactsSaBaseUri'), parameters('resourceNames').scriptsTemplatePath, 'CreateSharedFolders.ps1', parameters('artifactsSaSasToken'))]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),'-Build-SQL-OA-Cluster')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sqlResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "ConfigureSqlDirectoriesLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId,'template-domainJoined-vm-cluster-configuration', '/versions/v1')]"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[variables('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[variables('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[variables('vmBaseName')]"
          },
          "vmRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "numberOfInstances": {
            "value": "[variables('numberOfInstances')]"
          },
          "ListenerName": {
            "value": "[variables('listenerName')]"
          },
          "loadBalancerName": {
            "value": "[variables('loadBalancerName')]"
          },
          "virtualNetworkName": {
            "value": "[parameters('settings').MainSQLCluster.virtualNetwork]"
          },
          "vnetResourceGroupName": {
            "value": "[parameters('settings').MainSQLCluster.vnetResourceGroupName]"
          },
          "serviceAccount": {
            "value": "[variables('serviceAccount')]"
          },
          "serviceAccountPassword": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.serviceAccountPassword]"
            }
          },
          "backEndIpAddresses": {
            "value": "[reference('createSqlServers','2019-10-01').outputs.vmIpAddresses.value]"
          },
          "isFirstDeployment": {
            "value": "[parameters('settings').MainSQLCluster.isFirstDeployment]"
          },
          "isHALoadBalancer": {
            "value": true
          },
          "AcceleratedNetworking": {
            "value": "[parameters('settings').MainSQLCluster.acceleratedNetworking]"
          }
        }
      }
    },
    {
      "name": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureAOSQLServer')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sqlResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ConfigureAOSQLServerLoop",
        "count": "[variables('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat(variables('vmBaseName'),'-Build-SQL-OA-Cluster')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-post-vmcreation-sql-configuration', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "vmName": {
            "value": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "settings": {
            "value": "[parameters('settings')]"
          },
          "SQLPostScriptList": {
            "value": "[variables('SQLPostScriptList')]"
          },
          "resourceNames": {
            "value": "[parameters('resourceNames')]"
          },
          "sQLTTDEMasterKeyPwd": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.sQLTTDEMasterKeyPwd]"
            }
          },
          "sQLTDECertBackupPwd": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.sQLTDECertBackupPwd]"
            }
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').MainSQLCluster.isDeploymentGroupAgent]",
      "name": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)),'-DeploymentGroupAgent')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sqlResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "DeploymentGroupAgentLoop",
        "count": "[variables('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureAOSQLServer')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'VMExtensions-template-vm-extension-ps-script-with-secret', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(variables('vmBaseName'),if(equals(variables('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "powershellFileName": {
            "value": "SetupADOConfig.ps1"
          },
          "powershellParameters": {
            "value": "[variables('DeploymentGroupAgentArgs')]"
          },
          "secretParameterName": {
            "value": "DeploymentGroupToken"
          },
          "secretParameterValue": {
            "reference": {
              "keyVault": {
                "id": "[parameters('appKeyVaultId')]"
              },
              "secretName": "[parameters('settings').secretManager.secretReferences.DeploymentGroupToken]"
            }
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('artifactsSaBaseUri'), parameters('resourceNames').scriptsTemplatePath, 'SetupADOConfig.ps1', parameters('artifactsSaSasToken'))]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
