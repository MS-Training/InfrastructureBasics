{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
  },
  "resources": [
    {
      "name": "createGlobalDeploymentKeyVault",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').globalResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('resourceNames').globalKeyVaultName]"
          },
          "enabledForDiskEncryption": {
            "value": false
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
