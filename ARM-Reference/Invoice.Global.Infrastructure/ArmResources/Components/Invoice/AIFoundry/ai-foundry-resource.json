{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
    "AiFoundryName": "[tolower(concat(parameters('resourceNames').aiFoundryBaseName,parameters('settings').common.tag))]",
    "baseModelsArray": [
      {
        "deploymentName": "[parameters('settings').aiFoundry.deploymentModelConfig.gpt41.deploymentName]",
        "modelName": "[parameters('settings').aiFoundry.deploymentModelConfig.gpt41.modelName]",
        "capacity": "[int(parameters('settings').aiFoundry.deploymentModelConfig.gpt41.capacity)]",
        "sku": "[parameters('settings').aiFoundry.deploymentModelConfig.gpt41.sku]",
        "version": "[parameters('settings').aiFoundry.deploymentModelConfig.gpt41.version]"
      }
    ],
    "customModelArray": "[if(and(contains(parameters('settings').aiFoundry.deploymentModelConfig, 'customModel'), not(empty(parameters('settings').aiFoundry.deploymentModelConfig.customModel.deploymentName))), createArray(createObject('deploymentName', parameters('settings').aiFoundry.deploymentModelConfig.customModel.deploymentName, 'modelName', parameters('settings').aiFoundry.deploymentModelConfig.customModel.modelName, 'capacity', int(parameters('settings').aiFoundry.deploymentModelConfig.customModel.capacity), 'sku', parameters('settings').aiFoundry.deploymentModelConfig.customModel.sku, 'version', parameters('settings').aiFoundry.deploymentModelConfig.customModel.version)), createArray())]",
    "openAIModelsArray": "[concat(variables('baseModelsArray'), variables('customModelArray'))]"
  },
  "resources": [
    {
      "name": "createAzureAIFoundry",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-cognitive-service', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('AiFoundryName')]"
          },
          "managedIdentities": {
            "value": {
              "type": "UserAssigned",
              "userAssignedIdentities": {
                "[parameters('resourceNames').commonManagedIdentityResourceId]": {}
              }
            }
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "kind": {
            "value": "AIServices"
          },
          "defaultAction": {
            "value": "Allow"
          },
          "defaultProjectName": {
            "value": "[parameters('settings').aiFoundry.projectName]"
          }
        }
      }
    },
    {
      "name": "createDefenderForAISettings",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createAzureAIFoundry"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-defender-for-ai', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('AiFoundryName')]"
          }
        }
      }
    },
    {
      "name": "createAIModels",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "createDefenderForAISettings"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-ai-models', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('AiFoundryName')]"
          },
          "openAIModels": {
            "value": "[variables('openAIModelsArray')]"
          }
        }
      }
    },
    {
      "name": "AddUserManagedIdentityToAzureAIFoundry",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "createAIModels"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.CognitiveServices/accounts/',variables('AiFoundryName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(parameters('resourceNames').commonManagedIdentityResourceId, '2018-11-30').principalId]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.cognitiveServicesUserRoleDefinitionObjectId]"
          }
        }
      }
    }
  ],
  "outputs": {}
}