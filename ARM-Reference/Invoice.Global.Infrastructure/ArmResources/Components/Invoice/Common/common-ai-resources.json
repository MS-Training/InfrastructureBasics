{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "deploymentFlags": {
      "type": "Object",
      "metadata": {
        "description": "This is the parameter file under parameters folder"
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "networkAclIpRulesConfig": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    }
  },
  "variables": {
    "cognitiveServiceName": "[tolower(concat(parameters('resourceNames').cognitiveServiceBaseName,parameters('settings').common.tag))]",
    "openAIServiceName": "[tolower(concat(parameters('resourceNames').openAIServiceBaseName,parameters('settings').common.tag))]"
  },
  "resources": [
    {
      "name": "createCognitiveService",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-cognitive-service', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('cognitiveServiceName')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "ipRules": {
            "value": "[if(contains(tolower(parameters('resourceNames').environment),'dev'),parameters('networkAclIpRulesConfig').lowerEnvsAllowList,
                       if(contains(tolower(parameters('resourceNames').environment),'tst'),parameters('networkAclIpRulesConfig').lowerEnvsAllowList,
                       if(contains(tolower(parameters('resourceNames').environment),'prd'),parameters('networkAclIpRulesConfig').productionAllowList,parameters('networkAclIpRulesConfig').nothing)))]"
          }
        }
      }
    },
    {
      "name": "AddUserManagedIdentityToConitiveServiceAccess",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "createCognitiveService"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.CognitiveServices/accounts/',variables('cognitiveServiceName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(parameters('resourceNames').commonManagedIdentityResourceId, '2018-11-30').principalId]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.cognitiveServicesUserRoleDefinitionObjectId]"
          }
        }
      }
    },
    {
      "name": "createOpenAIService",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-cognitive-service', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('openAIServiceName')]"
          },
          "location": {
            "value": "[if(equals(tolower(parameters('settings').common.region),'southcentralus'), 'northcentralus', tolower(parameters('settings').common.region))]"
          },
          "kind": {
            "value": "OpenAI"
          },
          "defaultAction": {
            "value": "Allow"
          }
        }
      }
    },
    {
      "name": "deployModels",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'AI-template-cognitive-service', '/versions/v1')]"
        },
        "parameters": {
          "cognitiveServiceName": {
            "value": "[variables('openAIServiceName')]"
          },
          "openAIModels": {
            "value": [
              {
                "deploymentName": "text-embedding-ada-002",
                "modelName": "text-embedding-ada-002",
                "capacity": "[parameters('settings').common.openAIModelsConfig.textEmbeddingAda002.capacity]",
                "sku": "[parameters('settings').common.openAIModelsConfig.textEmbeddingAda002.sku]",
                "version": "[parameters('settings').common.openAIModelsConfig.textEmbeddingAda002.version]"
              },
              {
                "deploymentName": "gpt-4o",
                "modelName": "gpt-4o",
                "capacity": "[parameters('settings').common.openAIModelsConfig.gpt4o.capacity]",
                "sku": "[parameters('settings').common.openAIModelsConfig.gpt4o.sku]",
                "version": "[parameters('settings').common.openAIModelsConfig.gpt4o.version]"
              },
              {
                "deploymentName": "gpt-4o-agent",
                "modelName": "gpt-4o",
                "capacity": "[parameters('settings').common.openAIModelsConfig.gpt4oAgent.capacity]",
                "sku": "[parameters('settings').common.openAIModelsConfig.gpt4oAgent.sku]",
                "version": "[parameters('settings').common.openAIModelsConfig.gpt4oAgent.version]"
              }
            ]
          }
        }
      }
    },
    {
      "name": "AddUserManagedIdentityToAzureOpenAIAccess",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "createOpenAIService"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.CognitiveServices/accounts/',variables('openAIServiceName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(parameters('resourceNames').commonManagedIdentityResourceId, '2018-11-30').principalId]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.cognitiveServicesUserRoleDefinitionObjectId]"
          }
        }
      }
    }
  ],
  "outputs": {}
}