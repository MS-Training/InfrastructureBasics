                      "autoDeleteOnIdle": "P10675199DT2H48M5.4775807S",
                      "enablePartitioning": false,
                      "enableExpress": false
                    },
                    "subscriptions": [
                      {
                        "name": "tpsubsapel.invoice",
                        "filterRules": [
                          {
                            "name": "EventType",
                            "comments": "The properties object below contains example values.",
                            "properties": {
                              "action": {},
                              "filterType": "SqlFilter",
                              "sqlFilter": {
                                "sqlExpression": "user.EventType LIKE('%.Invoice.%.v1.%')",
                                "compatibilityLevel": 20
                              }
                            }
                          }
                        ],
                        "properties": {
                          "isClientAffine": false,
