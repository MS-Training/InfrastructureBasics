{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dotnetFrameworkVersion": {
      "type": "string",
      "defaultValue": "v8.0",
      "metadata": {
        "description": "The .NET Framework version that you want to use for the function app."
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "storageConnectionString": {
      "type": "securestring"
    },
    "appInsightsInstrumentationKey": {
      "type": "securestring"
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "commonKeyvaultName": "[tolower(concat(parameters('resourceNames').keyVaultBaseName,parameters('settings').common.tag))]",
    "commonKeyvaultSecrets_uri": "[concat('@Microsoft.KeyVault(SecretUri=https://', variables('commonKeyvaultName'), '.vault.azure.net/secrets/')]",
    "functionAppName": "[concat(parameters('resourceNames').functionAppBaseName,parameters('settings').invoiceDocService.tag)]",
    "storageAccountName": "[concat('stinvcdoc',if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'scusprod',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'eustest','dev')),'01')]",
    "managedIdentityName": "[tolower(concat(parameters('resourceNames').managedIdentityBaseName,parameters('settings').common.tag))]",
    "functionIdentities": {
      "type": "SystemAssigned, UserAssigned",
      "userAssignedIdentities": {
        "[parameters('resourceNames').commonManagedIdentityResourceId]": {}
      }
    },
    "functionSettings": {
      "settings": [
        {
          "name": "ServiceBus:ConnectionString",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'),concat(parameters('resourceNames').legacyResourceNames.serviceBusName,'-ServiceBusConnectionString/)'))]"
        },
        {  "name": "GlobalApplicationServiceBus__fullyQualifiedNamespace",
           "value": "[concat(parameters('resourceNames').legacyResourceNames.serviceBusName,'.servicebus.windows.net')]"
        },
        {
          "name": "AzureStorage:StorageAccountName",
          "value": "[variables('storageAccountName')]"
        },
        {
          "name": "CosmosDb:ConnectionString",
          "value": "[concat('https://cosmos-invoicecentral-document-', if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'prod-scus',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'test-eastus','dev')), '.documents.azure.com:443/')]"
        },
        {
          "name": "ServiceBus:InternalTopicName",
          "value": "document.internal.events"
        },
        {
          "name": "ServiceBus:InvoiceExternalTopicName",
          "value": "invoice.events"
        },
        {
          "name": "ServiceBus:DocumentsTopicName",
          "value": "document.events"
        },
        {
          "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
          "value": "[if(parameters('settings').invoiceDocService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "AzureWebJobsDashboard",
          "value": "[if(parameters('settings').invoiceDocService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "AzureWebJobsStorage",
          "value": "[if(parameters('settings').invoiceDocService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
          "value": "[parameters('appInsightsInstrumentationKey')]"
        },
        {
          "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
          "value": "[concat('InstrumentationKey=', parameters('appInsightsInstrumentationKey'))]"
        },
        {
          "name": "CommonUserAssignedManagedIdentity",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'),  'kv-', variables('managedIdentityName') , '-ClientId', '/)')]"
        },
        {
          "name": "WEBSITE_CONTENTSHARE",
          "value": "[toLower(variables('functionAppName'))]"
        },
        {
          "name": "FUNCTIONS_EXTENSION_VERSION",
          "value": "~4"
        },
        {
          "name": "WEBSITE_NODE_DEFAULT_VERSION",
          "value": "~12"
        },
        {
          "name": "FUNCTIONS_WORKER_RUNTIME",
          "value": "dotnet-isolated"
        },
        {
          "name": "WEBSITE_LOAD_USER_PROFILE",
          "value": "1"
        },
        {
          "name": "WEBSITE_RUN_FROM_PACKAGE",
          "value": "1"
        },
        {
          "name": "WEBSITE_CONTENTOVERVNET",
          "value": "1"
        },
        {
          "name": "Environment",
          "value": "[parameters('resourceNames').environment]"
        },
        {
          "name": "ClientSQl:SqlDatabaseServerName",
          "value": "[concat(parameters('resourceNames').legacyResourceNames.invoiceSQLServerName,'.database.windows.net')]"
        },
        {
          "name": "ClientSQl:SqlDataBaseName",
          "value": "InvoiceCentral"
        },
        {
          "name": "AddPOEDocumentToAzureSqlFlag",
          "value": "[parameters('settings').invoiceDocService.addPOEDocumentToAzureSql]"
        },
        {
          "name":  "Sentinel",
          "value":  "0"
        },
        {
          "name":  "ServiceTree:ComponentId",
          "value":  "8f82b513-1151-41fe-8abf-361190eb7912"
        },
        {
          "name":  "ServiceTree:ComponentName",
          "value":  "Invoice Services"
        },
        {
          "name":  "ServiceTree:Service",
          "value":  "Invoice"
        },
        {
          "name":  "ServiceTree:ServiceLine",
          "value":  "Payments"
        },
        {
          "name":  "ServiceTree:ServiceOffering",
          "value":  "Finance"
        },
        {
          "name":  "AzureAd:TenantId",
          "value":  "72f988bf-86f1-41af-91ab-2d7cd011db47"
        },
        {
          "name":  "AzureAd:Instance",
          "value":  "https://login.microsoftonline.com/"
        },
        {
          "name":  "AzureAd:ClientId",
          "value":  "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'b4b0bc61-1770-449a-91e7-52549a6730aa','a300bfe8-9846-49a5-8b77-780ad35929d3')]"
        },
        {
          "name":  "AzureStorage:PrimaryContainer",
          "value":  "default"
        },
        {
          "name":  "AzureStorage:SecondaryContainer",
          "value":  "two"
        },
        {
          "name":  "CosmosDb:DatabaseId",
          "value":  "InvoiceDocumentMetadata"
        },
        {
          "name":  "CosmosDb:DocumentCollectionContainerId",
          "value":  "DocumentCollectionContainer"
        },
        {
          "name":  "CosmosDb:DocumentMetadataContainerId",
          "value":  "DocumentMetadataContainer"
        },
        {
          "name":  "CosmosDb:ThreatScanContainerId",
          "value":  "ThreatScanResultContainer"
        },
        {
          "name":  "SharePoint:SiteUrl",
          "value":  "[concat('https://microsoft.sharepoint.com/teams/',if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'MSInvoice_PoeDocumentRepository/DocumentsVIII',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'MSInvoice_PoeDocumentRepository/Docs','MSInvoice_DevPoeDocs')))]"
        },
        {
          "name":  "SharePoint:Library",
          "value":  "Documents"
        },
        {
          "name":  "Sonar:Endpoint",
          "value":  "https://mse-ds-prod-us.daas.microsoft.com/sonarapi"
        },
        {
          "name":  "Sonar:Scopes",
          "value":  "https://mse-ds-prod-us.daas.microsoft.com/.default"
        },
        {
          "name":  "Sonar:TenantName",
          "value":  "invoice"
        },
        {
          "name":  "Sonar:RetryCount",
          "value":  "10"
        },
        {
          "name":  "Sonar:RetryTimeoutInSeconds",
          "value":  "60"
        },
        {
          "name":  "Sonar:StatusPollingTimeoutInSeconds",
          "value": "18000"
        },
        {
          "name":  "Sonar:StatusPollingIntervalInSeconds",
          "value": "30"
        },
        {
          "name":  "Testing:HelloWorldAppSetting",
          "value":  "This is a delightful test in the dev environment!"
        }
      ]
    },
    "cosmosDbAccountName": "[concat(parameters('resourceNames').cosmosDbBaseName,parameters('settings').invoiceDocService.tag)]",
    "singleLocation": [
      {
        "locationName": "[parameters('settings').common.region]",
        "failoverPriority": 0,
        "isZoneRedundant": false
      }
    ],
    "geoLocations": [
      {
        "locationName": "[parameters('settings').common.region]",
        "failoverPriority": 0,
        "isZoneRedundant": false
      },
      {
        "locationName": "[parameters('settings').common.secondaryRegion]",
        "failoverPriority": 1,
        "isZoneRedundant": false
      }
    ],
    "cosmosDbIpRules": [
      {
        "ipAddressOrRange": "157.58.216.64/26"
      },
      {
        "ipAddressOrRange": "207.68.190.32/27"
      }
    ]
  },
  "resources": [
    {
      "name": "[concat('createFunctionApp-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').invoiceDocServiceResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-function-network-integrated', '/versions/v1')]"
        },
        "parameters": {
          "dotnetFrameworkVersion": {
            "value": "[parameters('dotnetFrameworkVersion')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "functionIdentities": {
            "value": "[variables('functionIdentities')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "functionAppName": {
            "value": "[variables('functionAppName')]"
          },
          "functionDelagatedSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[1].subnetName]"
          },
          "functionPrivateEndpointSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[2].subnetName]"
          },
          "functionSettings": {
            "value": "[variables('functionSettings')]"
          },
          "hostingPlanResourceId": {
            "value": "[parameters('resourceNames').functionsHostingPlanResourceId]"
          },
          "componentTag": {
            "value": "[parameters('settings').invoiceDocService.tag]"
          },
          "componentResourceGroupName": {
            "value": "[parameters('resourceNames').invoiceDocServiceResourceGroupName]"
          },
          "commonResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "networkResourceGroupName": {
            "value": "[parameters('resourceNames').commonNetworkResourceGroupName]"
          },
          "commonVirtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          },
          "commonKeyvaultName": {
            "value": "[variables('commonKeyvaultName')]"
          },
          "commonWorkSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          },
          "publicNetworkAccess": {
            "value": "[parameters('settings').common.publicNetworkAccess]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.keyvaultSecretUserRoleDefinitionObjectId]"
          }
        }
      }
    },
    {
      "condition": false,
      "name": "[concat('createCosmosDbNetworkIntegrated-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').invoiceDocServiceResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-cosmosdb-network-integrated', '/versions/v1')]"
        },
        "parameters": { 
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "accountName": {
            "value": "[variables('cosmosDbAccountName')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "enableFreeTier": {
            "value": false
          },
          "enableAnalyticalStorage": {
            "value": false
          },
          "cosmosAPIType": {
            "value": "GlobalDocumentDB"
          },
          "geoLocationConfiguration": {
            "value": "[if(contains(parameters('resourceNames').environment,'dev'),variables('singleLocation'),variables('geoLocations'))]"
          },
          "ipRules": {
            "value": "[variables('cosmosDbIpRules')]"
          },
          "workSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          },
          "keyVaultName": {
            "value": "[variables('commonKeyvaultName')]"
          },
          "keyvaultResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "commonVirtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          },
          "cosmosDbPrivateEndpointSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[3].subnetName]"
          },
          "networkResourceGroupName": {
            "value": "[parameters('resourceNames').commonNetworkResourceGroupName]"
          },
          "componentTag": {
            "value": "[parameters('settings').invoiceDocService.tag]"
          }
        }
      }
    },
    {
      "condition": false,
      "comments": "This will be used once the storage accounts are migrated",
      "name": "[concat('createDocumentStoragePersmissions-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('settings').invoiceDocService.docStorageResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[concat('createFunctionApp-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',parameters('settings').invoiceDocService.docStorageSubscriptionId,'/resourceGroups/',parameters('settings').invoiceDocService.docStorageResourceGroupName,'/providers/Microsoft.Storage/storageAccounts/',parameters('settings').invoiceDocService.docStorageAccountName)]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(concat('createFunctionApp-', parameters('date'))).outputs.functionObjectId.value]"
          },
          "roleDefinitionObjectId": {
            "value": "ba92f5b4-2d11-453d-a403-e96b0029c9fe"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
