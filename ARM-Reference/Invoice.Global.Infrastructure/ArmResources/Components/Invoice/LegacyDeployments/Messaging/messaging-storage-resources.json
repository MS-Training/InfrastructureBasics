{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "This name of the storage account"
      }
    },
    "storageAccountResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "This name of the resource group where the storage account is located"
      }
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "networkAclIpRules": [
      {
        "comment": "SAW Range IPv4 (legacy) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "207.68.190.32/27"
      },
      {
        "comment": "SAW Range IPv4 range (E3+) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "157.58.216.64/26"
      },
      {
        "comment": "Express Route - Quincy (West US 2)",
        "value": "104.44.112.128/25"
      },
      {
        "comment": "Express Route -	Des Moines (Central US)",
        "value": "104.44.111.128/26"
      },
      {
        "comment": "Express Route -	Quincy (West US 2) 2",
        "value": "157.58.30.128/25"
      }
    ],
    "networkAclVirtualNetworkRules": {
      "dev": [
        {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON-NETWORK/providers/Microsoft.Network/virtualNetworks/invdevvnetcommon-network/subnets/functionDelegation",
          "action": "Allow"
        }
      ],
      "tst": [
        {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-TST-COMMON-NETWORK/providers/Microsoft.Network/virtualNetworks/invtstvnetcommon-network/subnets/functionDelegation",
          "action": "Allow"
        },
        {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-TSTSCU-COMMON-NETWORK/providers/Microsoft.Network/virtualNetworks/invtstscuvnetcommon-network/subnets/functionDelegation",
          "action": "Allow"
        }
      ],
      "prd": [
        {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV1-PRD-COMMON-NETWORK/providers/Microsoft.Network/virtualNetworks/inv1prdvnetcommon-network/subnets/functionDelegation",
          "action": "Allow"
        },
        {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV1-PRDWEU-COMMON-NETWORK/providers/Microsoft.Network/virtualNetworks/inv1prdweuvnetcommon-network/subnets/functionDelegation",
          "action": "Allow"
        }
      ],
      "nothing": []
    }
  },
  "resources": [
    {
      "name": "[concat('createMessagingStorage-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('storageAccountResourceGroup')]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'StorageAccount-template-storageAccount', '/versions/v1')]"
        },
        "parameters": {
          "storageAccountName": {
            "value": "[parameters('storageAccountName')]"
          },
          "storageSKU": {
            "value": "[if(contains(tolower(parameters('storageAccountResourceGroup')),'-prod-'),'Standard_RAGRS','Standard_LRS')]"
          },
          "networkAclDefaultAction": {
            "value": "Deny"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          },
          "networkAclVirtualNetworkRules": {
            "value": "[if(contains(tolower(parameters('storageAccountResourceGroup')),'-dev-'),variables('networkAclVirtualNetworkRules').dev, 
                      if(contains(tolower(parameters('storageAccountResourceGroup')),'-test-'),variables('networkAclVirtualNetworkRules').tst,
                      if(contains(tolower(parameters('storageAccountResourceGroup')),'-prod-'),variables('networkAclVirtualNetworkRules').prd,variables('networkAclVirtualNetworkRules').nothing)))]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
