{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dotnetFrameworkVersion": {
      "type": "string",
      "defaultValue": "v8.0",
      "metadata": {
        "description": "The .NET Framework version that you want to use for the function app."
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "storageConnectionString": {
      "type": "securestring"
    },
    "appInsightsInstrumentationKey": {
      "type": "securestring"
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/",
    "commonKeyvaultName": "[tolower(concat(parameters('resourceNames').keyVaultBaseName,parameters('settings').common.tag))]",
    "commonKeyvaultSecrets_uri": "[concat('@Microsoft.KeyVault(SecretUri=https://', variables('commonKeyvaultName'), '.vault.azure.net/secrets/')]",
    "storageAccountName": "[concat(parameters('resourceNames').storageAccountBaseName, parameters('settings').invoiceNotifyService.tag)]",
    "functionAppName": "[concat(parameters('resourceNames').functionAppBaseName,parameters('settings').invoiceNotifyService.tag)]",
    "functionIdentities": {
      "type": "SystemAssigned, UserAssigned",
      "userAssignedIdentities": {
        "[parameters('resourceNames').commonManagedIdentityResourceId]": {}
      }
    },
    "functionSettings": {
      "settings": [
        {
          "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
          "value": "[if(parameters('settings').invoiceNotifyService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "WEBSITE_RUN_FROM_PACKAGE",
          "value": "1"
        },
        {
          "name": "AzureWebJobsDashboard",
          "value": "[if(parameters('settings').invoiceNotifyService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "AzureWebJobsStorage",
          "value": "[if(parameters('settings').invoiceNotifyService.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "MeoGetStatusTriggerTime",
          "value": "0 */3 * * * *"
        },        
        {
          "name": "MeoApiUrl",
          "value": "[parameters('settings').invoiceNotifyService.meoApiUrl]"
        },       
        {
          "name": "AzureAd:ClientId",
          "value": "[parameters('settings').invoiceNotifyService.meoClientId]"
        },        
        {
          "name": "AzureAd:TenantId",
          "value": "[parameters('settings').invoiceNotifyService.MeoTenantId]"
        },
        {
          "name": "MeoResource",
          "value": "[parameters('settings').invoiceNotifyService.meoResource]"
        },
        {
          "name": "ManagedIdentityClientId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'0afd4cef-5be6-4fb3-90aa-8871951baf2e',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'5660f47a-4325-41a5-82d0-d0f01530dec8','4765a484-55b4-4d40-8593-2ca83fdf1640'))]"
        },
        {
          "name": "StorageAccountName",
          "value": "[concat(parameters('resourceNames').storageAccountBaseName, parameters('settings').invoiceNotifyService.tag)]"
        },
        {
          "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
          "value": "[parameters('appInsightsInstrumentationKey')]"
        },
        {
          "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
          "value": "[concat('InstrumentationKey=', parameters('appInsightsInstrumentationKey'))]"
        },
        {
          "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
          "value": "~2"
        },
        {
          "name": "WEBSITE_CONTENTSHARE",
          "value": "[toLower(variables('functionAppName'))]"
        },
        {
          "name": "FUNCTIONS_EXTENSION_VERSION",
          "value": "~4"
        },
        {
          "name": "WEBSITE_NODE_DEFAULT_VERSION",
          "value": "8.11.1"
        },
        {
          "name": "WEBSITE_LOAD_CERTIFICATES",
          "value": "*"
        },
        {
          "name": "FUNCTIONS_WORKER_RUNTIME",
          "value": "dotnet-isolated"
        },
        {
          "name": "AZURE_FUNCTIONS_ENVIRONMENT",
          "value": "[toUpper(parameters('resourceNames').environment)]"
        },
        {
          "name": "Environment",
          "value": "[parameters('resourceNames').environment]"
        },
        {
          "name": "dotnetFrameworkVersion",
          "value": "v8.0"
        }      
      ]
    },
    "networkAclIpRules": [
      {
        "comment": "SAW Range IPv4 (legacy) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "207.68.190.32/27"
      },
      {
        "comment": "SAW Range IPv4 range (E3+) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "157.58.216.64/26"
      }
    ]
  },
  "resources": [
    {
      "name": "[concat('createFunctionApp-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').invoiceNotifyServiceResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-function-network-integrated', '/versions/v1')]"
        },
        "parameters": {
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "functionIdentities": {
            "value": "[variables('functionIdentities')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "functionAppName": {
            "value": "[variables('functionAppName')]"
          },
          "functionDelagatedSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[1].subnetName]"
          },
          "functionPrivateEndpointSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[2].subnetName]"
          },
          "functionSettings": {
            "value": "[variables('functionSettings')]"
          },
          "hostingPlanResourceId": {
            "value": "[parameters('resourceNames').functionsHostingPlanResourceId]"
          },
          "componentTag": {
            "value": "[parameters('settings').invoiceNotifyService.tag]"
          },
          "componentResourceGroupName": {
            "value": "[parameters('resourceNames').invoiceNotifyServiceResourceGroupName]"
          },
          "commonResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "networkResourceGroupName": {
            "value": "[parameters('resourceNames').commonNetworkResourceGroupName]"
          },
          "commonVirtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          },
          "commonKeyvaultName": {
            "value": "[variables('commonKeyvaultName')]"
          },
          "commonWorkSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          },
          "publicNetworkAccess": {
            "value": "[parameters('settings').common.publicNetworkAccess]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.keyvaultSecretUserRoleDefinitionObjectId]"
          },
          "dotnetFrameworkVersion": {
            "value": "v8.0"
          }
        }
      }
    },
    {
      "name": "CreateNotifyStorageAccount",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'StorageAccount-template-storageAccount', '/versions/v1')]"
        },
        "parameters": {
          "StorageAccountName": {
            "value": "[variables('storageAccountName')]"
          },
          "storageSKU": {
            "value": "[parameters('settings').invoiceNotifyService.storageAccountSKU]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "networkAclDefaultAction": {
            "value": "Deny"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          },
          "allowSharedKeyAccess": {
            "value": false
          }
        }
      }
    },
    {
      "name": "CreateTablesforNotifyStorageAccount",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [ "CreateNotifyStorageAccount" ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'StorageAccount-template-storageAccount-tables', '/versions/v1')]"
        },
        "parameters": {
          "StorageAccountName": {
            "value": "[variables('StorageAccountName')]"
          },
          "tableNames": {
            "value": [ "MEONotificationStatus", "MEONotificationArchive" ]
          }
        }
      }
    },
    {
      "name": "CreateNotifyStorageAccountPvtEndPts",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').invoiceNotifyServiceResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "CreateTablesforNotifyStorageAccount"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-private-endpoints', '/versions/v1')]"
        },
        "parameters": {
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "createDNSRecords": {
            "value": true
          },
          "addPrivateEndPointPrefix": {
            "value": true
          },
          "privateEndpointsDetails": {
            "value": [
              {
                "resourceName": "[variables('StorageAccountName')]",
                "resourceGroupName": "[parameters('resourceNames').invoiceNotifyServiceResourceGroupName]",
                "privateLinkServiceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').invoiceNotifyServiceResourceGroupName,'/providers/Microsoft.Storage/storageAccounts/',variables('StorageAccountName'))]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[parameters('settings').commonNetwork.subnets[3].subnetName]",
                "serviceGroupNames": [ "blob" ],
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "[parameters('resourceNames').commonNetworkResourceGroupName]",
                "privateDNSZoneName": "privatelink.blob.core.windows.net"
              },
              {
                "resourceName": "[variables('StorageAccountName')]",
                "resourceGroupName": "[parameters('resourceNames').invoiceNotifyServiceResourceGroupName]",
                "privateLinkServiceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').invoiceNotifyServiceResourceGroupName,'/providers/Microsoft.Storage/storageAccounts/',variables('StorageAccountName'))]",
                "virtualNetworkId": "[parameters('resourceNames').commonVirtualNetworkResourceId]",
                "virtualNetworkSubnetName": "[parameters('settings').commonNetwork.subnets[3].subnetName]",
                "serviceGroupNames": [ "table" ],
                "location": "[parameters('settings').common.region]",
                "networkResourceGroupName": "[parameters('resourceNames').commonNetworkResourceGroupName]",
                "privateDNSZoneName": "privatelink.table.core.windows.net"
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
