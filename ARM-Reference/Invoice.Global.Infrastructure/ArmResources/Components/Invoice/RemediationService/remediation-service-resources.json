{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "storageConnectionString": {
      "type": "securestring"
    },
    "appInsightsInstrumentationKey": {
      "type": "securestring"
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "commonKeyvaultName": "[tolower(concat(parameters('resourceNames').keyVaultBaseName,parameters('settings').common.tag))]",
    "commonKeyvaultSecrets_uri": "[concat('@Microsoft.KeyVault(SecretUri=https://', variables('commonKeyvaultName'), '.vault.azure.net/secrets/')]",
    "functionAppName": "[concat(parameters('resourceNames').functionAppBaseName,parameters('settings').remediation.tag)]",
    "managedIdentityName": "[tolower(concat(parameters('resourceNames').managedIdentityBaseName,parameters('settings').common.tag))]",
    "functionIdentities": {
      "type": "SystemAssigned, UserAssigned",
      "userAssignedIdentities": {
        "[parameters('resourceNames').commonManagedIdentityResourceId]": {}
      }
    },
    "functionSettings": {
      "settings": [
        {
          "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
          "value": "[parameters('appInsightsInstrumentationKey')]"
        },
        {
          "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
          "value": "[concat('InstrumentationKey=', parameters('appInsightsInstrumentationKey'))]"
        },
        {
          "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
          "value": "~2"
        },
        {
          "name": "AZURE_FUNCTIONS_ENVIRONMENT",
          "value": "[toUpper(parameters('resourceNames').environment)]"
        },
        {
          "name": "AzureAd:Audience",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'d166948e-6976-40a2-b1b6-1aa04caf9865','f88f9168-ee25-4b6a-b45b-e87d2bd6adca')]"
        },
        {
          "name": "AzureAd:ClientCertificates:0:KeyVaultCertificateName",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'aad-remediation-invoice-microsoft-com','int-aad-remediation-invoice-microsoft-com')]"
        },
        {
          "name": "AzureAd:ClientCertificates:0:KeyVaultUrl",
          "value": "[concat('https://',variables('commonKeyvaultName'), '.vault.azure.net/')]"
        },
        {
          "name": "AzureAd:ClientCertificates:0:SourceType",
          "value": "KeyVault"
        },
        {
          "name": "AzureAd:ClientId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'bb015c8d-1f86-4346-86ab-dd77e9409d2f','8e926fbe-f133-42c7-8b2b-a69ef1f3212c')]"
        },
        {
          "name": "AzureAd:Instance",
          "value": "https://login.microsoftonline.com/"
        },
        {
          "name": "AzureAd:SendX5C",
          "value": "true"
        },
        {
          "name": "AzureAd:TenantId",
          "value": "[subscription().tenantId]"
        },
        {
          "name": "AzureSignalRConnectionString",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'), parameters('settings').remediation.tag ,'-AzureSignalRConnectionString/)')]"
        },
        {
          "name": "AzureWebJobsDashboard",
          "value": "[if(parameters('settings').remediation.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "GlobalApplicationServiceBus__fullyQualifiedNamespace",
          "value": "[concat(parameters('resourceNames').legacyResourceNames.serviceBusName,'.servicebus.windows.net')]"
        },
        {
          "name": "AzureWebJobsServiceBus",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'), concat(parameters('resourceNames').legacyResourceNames.serviceBusName,'-ServiceBusConnectionString/)'))]"
        },
        {
          "name": "AzureWebJobsStorage",
          "value": "[if(parameters('settings').remediation.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "CosmosDBConnection__accountEndpoint",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'https://remediationservice.documents.azure.com:443/',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'https://remediationservicetest.documents.azure.com:443/','https://remediationservicedev.documents.azure.com:443/'))]"
        },
        {
          "name": "CosmosDBConnection__credential",
          "value": "managedidentity"
        },
        {
          "name": "Environment",
          "value": "[parameters('resourceNames').environment]"
        },
        {
          "name": "ExpectedServiceBusMessageType",
          "value": "event.creationfailure.v1"
        },
        {
          "name": "FileAttachmentSubscriptionName",
          "value": "invoicecopy.fileattachmentmonitor.v1"
        },
        {
          "name": "FUNCTIONS_EXTENSION_VERSION",
          "value": "~4"
        },
        {
          "name": "FUNCTIONS_WORKER_RUNTIME",
          "value": "dotnet-isolated"
        },
        {
          "name": "InvoiceCopySubscriptionName",
          "value": "invoice.requiredinvoicecopy.v1"
        },
        {
          "name": "InvoiceCopyTopicName",
          "value": "invoicecopy.events"
        },
        {
          "name": "LUISKey",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'),'LUISKey/)')]"
        },
        {
          "name": "LUISAppId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'82d26325-032c-4ddf-842c-002ac0b2fc92','ab1286aa-3ade-450d-8553-5bb282513a6b')]"
        },
        {
          "name": "LuisPredictionEndpoint",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'https://remediation.cognitiveservices.azure.com/','https://remediationtest.cognitiveservices.azure.com/')]"
        },
        {
          "name": "MaxRetryCount",
          "value": "3"
        },
        {
          "name": "Remediation_Cosmos_Collection",
          "value": "Requests"
        },
        {
          "name": "Remediation_Cosmos_DB",
          "value": "RemediationService"
        },
        {
          "name": "Remediation_CosmosDb_ConnectionString",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'https://remediationservice.documents.azure.com:443/',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'https://remediationservicetest.documents.azure.com:443/','https://remediationservicedev.documents.azure.com:443/'))]"
        },
        {
          "name": "RemediationTaskHubName",
          "value": "RemediationTaskHub"
        },
        {
          "name": "RetryInterval",
          "value": "5"
        },
        {
          "name": "ServiceTreeComponentId",
          "value": "8f82b513-1151-41fe-8abf-361190eb7912"
        },
        {
          "name": "ServiceTreeComponentName",
          "value": "Remediation Service"
        },
        {
          "name": "ServiceTreeService",
          "value": "Invoice"
        },
        {
          "name": "ServiceTreeServiceLine",
          "value": "Payments"
        },
        {
          "name": "ServiceTreeServiceOffering",
          "value": "Finance"
        },
        {
          "name": "SignalRHubName",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'sr-ic-remsrvc',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'sr-ic-remsrvc-test','sr-ic-remsrvc-dev'))]"
        },
        {
          "name": "SignalRConnectionString",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'),'SignalRConnectionString/)')]"
        },
        {
          "name": "SubscriptionName",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'remediation.prod',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'remediation.test','remediation.dev'))]"
        },
        {
          "name": "TopicName",
          "value": "invoice.events"
        },
        {
          "name": "UserAssignedManagedIdentityClientId",
          "value": "[concat(variables('commonKeyvaultSecrets_uri'),  'kv-', variables('managedIdentityName') , '-ClientId', '/)')]"
        },
        {
          "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
          "value": "[if(parameters('settings').remediation.isFirstDeployment, parameters('storageConnectionString'), concat(variables('commonKeyvaultSecrets_uri'), 'kv-', parameters('resourceNames').functionsStorageAccountName, '-ConnectionString', '/)'))]"
        },
        {
          "name": "WEBSITE_CONTENTOVERVNET",
          "value": "1"
        },
        {
          "name": "WEBSITE_CONTENTSHARE",
          "value": "[toLower(variables('functionAppName'))]"
        },
        {
          "name": "WEBSITE_LOAD_CERTIFICATES",
          "value": "*"
        },
        {
          "name": "WEBSITE_NODE_DEFAULT_VERSION",
          "value": "8.11.1"
        },
        {
          "name": "WEBSITE_RUN_FROM_PACKAGE",
          "value": "1"
        },
        {
          "name": "AzureFoundry_Project_ConnectionString",
          "value": "[concat('https://', tolower(concat(parameters('resourceNames').aiFoundryBaseName,parameters('settings').common.tag)), '.services.ai.azure.com/api/projects/Invoice-Agents')]"
        },
        {
          "name": "AzureFoundry_Agent_Model",
          "value": "[parameters('settings').aiFoundry.deploymentModelConfig.gpt41.modelName]"
        },
        {
          "name": "AppInsights_UI_WorkspaceId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'c842f1e5-8fc4-4bfd-a1e7-40253c91748e',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'c842f1e5-8fc4-4bfd-a1e7-40253c91748e','9d9c312a-0915-449c-8ef6-9d89e6cb8b34'))]"
        },
        {
          "name": "AppInsights_SF_US_WorkspaceId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'92822a79-d77b-45a2-98ed-0719d2486dab',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'4f0babf7-e016-4ad5-bea0-d5d856a72228','d7474215-3762-442c-a2d7-9c94d1e4c2bb'))]"
        },
        {
          "name": "AppInsights_SF_EU_WorkspaceId",
          "value": "[if(contains(toUpper(parameters('resourceNames').environment),'PRD'),'bc2bfb0a-05d3-45b7-a0f3-bf3e7fce0942',if(contains(toUpper(parameters('resourceNames').environment),'TST'),'ffdb1771-1a97-4869-b2c7-7d7a5e68801a','d7474215-3762-442c-a2d7-9c94d1e4c2bb'))]"
        },
        {
          "name": "CosmosAgentReportContainerId",
          "value": "AgentReport"
        },
        {
          "name": "CosmosAgentAnalyzationContainerId",
          "value": "AgentAnalyzation"
        }
      ]
    },
    "cosmosDbAccountName": "[concat(parameters('resourceNames').cosmosDbBaseName,parameters('settings').remediation.tag)]",
    "singleLocation": [
      {
        "locationName": "[parameters('settings').common.region]",
        "failoverPriority": 0,
        "isZoneRedundant": false
      }
    ],
    "geoLocations": [
      {
        "locationName": "[parameters('settings').common.region]",
        "failoverPriority": 0,
        "isZoneRedundant": false
      },
      {
        "locationName": "[parameters('settings').common.secondaryRegion]",
        "failoverPriority": 1,
        "isZoneRedundant": false
      }
    ],
    "cosmosDbIpRules": [
      {
        "ipAddressOrRange": "157.58.216.64/26"
      },
      {
        "ipAddressOrRange": "207.68.190.32/27"
      }
    ]
  },
  "resources": [
    {
      "name": "[concat('createFunctionApp-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').remediationResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-function-network-integrated', '/versions/v1')]"
        },
        "parameters": {
          "dotnetFrameworkVersion": {
            "value": "[parameters('settings').remediation.functionSettings.dotnetFrameworkVersion]"
          },
          "functionIdentities": {
            "value": "[variables('functionIdentities')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "functionAppName": {
            "value": "[variables('functionAppName')]"
          },
          "functionDelagatedSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[1].subnetName]"
          },
          "functionPrivateEndpointSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[2].subnetName]"
          },
          "functionSettings": {
            "value": "[variables('functionSettings')]"
          },
          "hostingPlanResourceId": {
            "value": "[parameters('resourceNames').functionsHostingPlanResourceId]"
          },
          "componentTag": {
            "value": "[parameters('settings').remediation.tag]"
          },
          "componentResourceGroupName": {
            "value": "[parameters('resourceNames').remediationResourceGroupName]"
          },
          "commonResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "networkResourceGroupName": {
            "value": "[parameters('resourceNames').commonNetworkResourceGroupName]"
          },
          "commonVirtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          },
          "commonKeyvaultName": {
            "value": "[variables('commonKeyvaultName')]"
          },
          "commonWorkSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          },
          "publicNetworkAccess": {
            "value": "[parameters('settings').common.publicNetworkAccess]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.keyvaultSecretUserRoleDefinitionObjectId]"
          }
        }
      }
    },
    {
      "condition": false,
      "name": "[concat('createCosmosDbNetworkIntegrated-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').remediationResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'template-cosmosdb-network-integrated', '/versions/v1')]"
        },
        "parameters": {
          "templatespecsBaseResourceId": {
            "value": "[parameters('resourceNames').templatespecsBaseResourceId]"
          },
          "accountName": {
            "value": "[variables('cosmosDbAccountName')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "enableFreeTier": {
            "value": false
          },
          "enableAnalyticalStorage": {
            "value": false
          },
          "cosmosAPIType": {
            "value": "GlobalDocumentDB"
          },
          "geoLocationConfiguration": {
            "value": "[if(contains(parameters('resourceNames').environment,'dev'),variables('singleLocation'),variables('geoLocations'))]"
          },
          "ipRules": {
            "value": "[variables('cosmosDbIpRules')]"
          },
          "workSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          },
          "keyVaultName": {
            "value": "[variables('commonKeyvaultName')]"
          },
          "keyvaultResourceGroupName": {
            "value": "[parameters('resourceNames').commonResourceGroupName]"
          },
          "commonVirtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          },
          "cosmosDbPrivateEndpointSubnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[3].subnetName]"
          },
          "networkResourceGroupName": {
            "value": "[parameters('resourceNames').commonNetworkResourceGroupName]"
          },
          "componentTag": {
            "value": "[parameters('settings').remediation.tag]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
