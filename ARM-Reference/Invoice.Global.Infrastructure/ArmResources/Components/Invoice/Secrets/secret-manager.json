{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "deploymentFlags": {
      "type": "Object",
      "metadata": {
        "description": "This is the parameter file under parameters folder"
      }
    },
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "setRBACKevaultPermissions": {
      "type": "bool",
      "defaultValue": false
    }
  },
  "variables": {
    "keyVaultName": "[tolower(concat(parameters('resourceNames').KeyVaultBaseName,parameters('settings').common.tag))]"
  },
  "resources": [
    {
      "condition": "[or(parameters('deploymentFlags').deploySecrets,parameters('deploymentFlags').isNewEnvironment)]",
      "name": "addResourcesSecrets",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonResourceGroupName]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault-secrets', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[variables('keyVaultName')]"
          },
          "secretsObject": {
            "value": {
              "secrets": "[parameters('settings').secretManager.secrets.secretList]"
            }
          }
        }
      }
    },
    {
      "condition": "[and(not(parameters('setRBACKevaultPermissions')),or(parameters('deploymentFlags').setAppKeyVaultPermissions,parameters('deploymentFlags').isNewEnvironment))]",
      "name": "[concat(copyindex(1),'-AddPermToAADObjectId-', parameters('settings').secretManager.permissions.accountList[copyIndex()].objectId)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "AddPermissionsLoop",
        "mode": "serial",
        "count": "[length(parameters('settings').secretManager.permissions.accountList)]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'KeyVault-template-keyVault-permissions', '/versions/v1')]"
        },
        "parameters": {
          "keyVaultName": {
            "value": "[variables('keyVaultName')]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[parameters('settings').secretManager.permissions.accountList[copyIndex()].objectId]"
          }
        }
      }
    },
    {
      "condition": "[and(parameters('setRBACKevaultPermissions'),or(parameters('deploymentFlags').setAppKeyVaultPermissions,parameters('deploymentFlags').isNewEnvironment))]",
      "name": "[concat(copyindex(1),'-AddRBACPermToAADObjectId-', parameters('settings').secretManager.permissions.accountList[copyIndex()].objectId)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "AddRBACPermissionsLoop",
        "mode": "serial",
        "count": "[length(parameters('settings').secretManager.permissions.accountList)]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.KeyVault/vaults/',variables('keyVaultName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[parameters('settings').secretManager.permissions.accountList[copyIndex()].objectId]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('settings').secretManager.permissions.accountList[copyIndex()].roleDefinitionObjectId]"
          }
        }
      }
    }
  ],
  "outputs": {
    "commonKeyVaultResourceId": {
      "type": "string",
      "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.KeyVault/vaults/',variables('keyVaultName'))]"
    }
  }
}
