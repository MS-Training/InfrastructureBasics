      "kind": "AzurePowerShell",
      "properties": {
        "azPowerShellVersion": "14.0",
        "timeout": "PT2H",
        "cleanupPreference": "Always",
        "retentionInterval": "P1D",
        "forceUpdateTag": "[parameters('date')]",
        "arguments": "[format('-tenantId \"{0}\" -subscriptionId \"{1}\" -resourceGroupName \"{2}\" -parallelExecutions \"{3}\"', subscription().tenantId, subscription().subscriptionId, resourceGroup().name, 5)]",
        "scriptContent": "param([string] $tenantId, [string] $subscriptionId, [string] $resourceGroupName, [int] $parallelExecutions) Set-AzContext -Tenant $tenantId -Subscription $subscriptionId; $vmssList = Get-AzVmss -ResourceGroupName $resourceGroupName; foreach ($vmss in $vmssList) { if ($vmss.Tags.ContainsKey('azcertinstaller_msinternalcertstore')) { $vmssName = $vmss.Name; Write-Host \"Processing VMSS: $($vmssName)\"; $instances = Get-AzVmssVM -ResourceGroupName $resourceGroupName -VMScaleSetName $vmssName; $instances | ForEach-Object -Parallel { $vmId = $_.InstanceId; Write-Host \"Processing Instance: $($vmId)\"; Invoke-AzVmssVMRunCommand -ResourceGroupName $using:resourceGroupName -VMScaleSetName $using:vmssName -InstanceId $vmId -CommandId 'RunPowerShellScript' -ScriptString 'C:\\Windows\\System32\\config\\systemprofile\\AppData\\Local\\AzureSecurityPack\\AzCertInstaller.cmd'; } -ThrottleLimit $parallelExecutions; }}"
      }
