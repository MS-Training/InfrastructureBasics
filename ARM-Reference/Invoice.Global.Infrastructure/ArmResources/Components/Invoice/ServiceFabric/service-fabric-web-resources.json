{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "appKeyVaultId": {
      "type": "string",
      "metadata": {
        "description": "This is the resourceId of the Keyvault where the application secrets are stored"
      }
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "clusterName": "[concat(parameters('resourceNames').sfClusterBaseName,toLower(parameters('settings').sfWebServices.tag))]",
    "backendPoolSubnetResourceId": "[concat(parameters('resourceNames').commonVirtualNetworkResourceId, '/subnets/', parameters('settings').commonNetwork.subnets[0].subnetName)]",
    "nodeTypesConfig": [
      {
        "name": "[tolower(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag)]",
        "applicationPorts": {
          "endPort": "30000",
          "startPort": "20000"
        },
        "clientConnectionEndpointPort": "19000",
        "durabilityLevel": "[parameters('settings').sfWebServices.scaleSetsDetails[0].durabilityLevel]",
        "ephemeralPorts": {
          "endPort": "65534",
          "startPort": "49152"
        },
        "httpGatewayEndpointPort": "19080",
        "isPrimary": true,
        "vmInstanceCount": "[parameters('settings').sfWebServices.scaleSetsDetails[0].numberOfInstances]"
      }
    ],
    "WebNodesIpName": "[tolower(concat(parameters('resourceNames').publicIpBaseName,parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,'mgmt'))]",
    "invoiceApiIpName": "[tolower(concat(parameters('resourceNames').publicIpBaseName,'-api'))]",
    "invoiceUiApiIpName": "[tolower(concat(parameters('resourceNames').publicIpBaseName,'-uiapi'))]",
    "invoiceUmsIpName": "[tolower(concat(parameters('resourceNames').publicIpBaseName,'-ums'))]",
    "internalInvoiceIpName": "[tolower(concat(parameters('resourceNames').publicIpBaseName,'-internal'))]",

    "appBackEndPoolName": "[tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'Nodes'))]",
    "appLoadBalancerId": "[resourceId('Microsoft.Network/loadBalancers',tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'lbl')))]",
    "appInternalLoadBalancerId": "[resourceId('Microsoft.Network/loadBalancers',tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'lblinternal')))]",

    "appIPAddressNameList": [
      "[variables('invoiceApiIpName')]",
      "[variables('invoiceUiApiIpName')]",
      "[variables('invoiceUmsIpName')]"
    ],

    "appLoadBalancerReferences": {
      "frontEnd": {
        "managementIp": "[concat(variables('appLoadBalancerId'),'/frontendIPConfigurations/',variables('WebNodesIpName'))]",
        "invoiceIpAPI": "[concat(variables('appLoadBalancerId'),'/frontendIPConfigurations/',variables('invoiceApiIpName'))]",
        "invoiceIpUIAPI": "[concat(variables('appLoadBalancerId'),'/frontendIPConfigurations/',variables('invoiceUiApiIpName'))]",
        "invoiceIpUMS": "[concat(variables('appLoadBalancerId'),'/frontendIPConfigurations/',variables('invoiceUmsIpName'))]",
        "internalIpInvoice": "[concat(variables('appInternalLoadBalancerId'),'/frontendIPConfigurations/',variables('internalInvoiceIpName'))]"
      },
      "backEnd": "[concat(variables('appLoadBalancerId'),'/backendAddressPools/',variables('appBackEndPoolName'))]",
      "internalBackEnd": "[concat(variables('appInternalLoadBalancerId'),'/backendAddressPools/',variables('appBackEndPoolName'))]",
      "probes": {
        "invoiceApiProbe": "[concat(variables('appLoadBalancerId'),'/probes/invoiceApiProbe')]",
        "invoiceUiApiProbe": "[concat(variables('appLoadBalancerId'),'/probes/invoiceUiApiProbe')]",
        "invoiceUmsProbe": "[concat(variables('appLoadBalancerId'),'/probes/invoiceUmsProbe')]",
        "internalInvoiceApiProbe": "[concat(variables('appInternalLoadBalancerId'),'/probes/invoiceApiProbe')]",
        "internalInvoiceUiApiProbe": "[concat(variables('appInternalLoadBalancerId'),'/probes/invoiceUiApiProbe')]",
        "internalInvoiceUmsProbe": "[concat(variables('appInternalLoadBalancerId'),'/probes/invoiceUmsProbe')]",
        "fabricGatewayProbe": "[concat(variables('appLoadBalancerId'),'/probes/fabricGatewayProbe')]",
        "fabricHttpGatewayProbe": "[concat(variables('appLoadBalancerId'),'/probes/fabricHttpGatewayProbe')]"
      }
    },

    "loadBalancersConfiguration": [
      {
        "description": "WebNodes",
        "name": "[tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'lbl'))]",
        "frontendIPConfigurations": [
          {
            "name": "[variables('WebNodesIpName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('WebNodesIpName'))]"
              }
            }
          },
          {
            "name": "[variables('invoiceApiIpName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('invoiceApiIpName'))]"
              }
            }
          },
          {
            "name": "[variables('invoiceUiApiIpName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('invoiceUiApiIpName'))]"
              }
            }
          },
          {
            "name": "[variables('invoiceUmsIpName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('invoiceUmsIpName'))]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "[variables('appBackEndPoolName')]"
          }
        ],
        "loadBalancingRules": [
          {
            "name": "invoiceAPI",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').backEnd]"
              },
              "frontendPort": 443,
              "backendPort": 8080,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.invoiceIpAPI]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.invoiceApiProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUIAPI",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').backEnd]"
              },
              "frontendPort": 443,
              "backendPort": 8668,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.invoiceIpUIAPI]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.invoiceUiApiProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUMS",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').backEnd]"
              },
              "frontendPort": 443,
              "backendPort": 8715,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.invoiceIpUMS]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.invoiceUmsProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "fabricGateway",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').backEnd]"
              },
              "frontendPort": 19000,
              "backendPort": 19000,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.managementIp]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.fabricGatewayProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "fabricHttpGateway",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').backEnd]"
              },
              "backendPort": 19080,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.managementIp]"
              },
              "frontendPort": 19080,
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.fabricHttpGatewayProbe]"
              },
              "protocol": "tcp"
            }
          }
        ],
        "probes": [
          {
            "name": "invoiceApiProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8080,
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUiApiProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8668,
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUmsProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8715,
              "protocol": "tcp"
            }
          },
          {
            "name": "fabricGatewayProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 19000,
              "protocol": "tcp"
            }
          },
          {
            "name": "fabricHttpGatewayProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 19080,
              "protocol": "tcp"
            }
          }
        ],
        "inboundNatPools": [
          {
            "name": "RemoteDesktopRule",
            "properties": {
              "backendPort": 3389,
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.managementIp]"
              },
              "frontendPortRangeEnd": 4500,
              "frontendPortRangeStart": 3389,
              "protocol": "tcp"
            }
          }
        ]
      },
      {
        "description": "[tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'lblinternal'))]",
        "name": "[tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[0].scaleSetTag,parameters('resourceNames').environment,'lblinternal'))]",
        "frontendIPConfigurations": [
          {
            "name": "[variables('internalInvoiceIpName')]",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[variables('backendPoolSubnetResourceId')]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "[variables('appBackEndPoolName')]"
          }
        ],
        "loadBalancingRules": [
          {
            "name": "invoiceAPI",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').internalBackEnd]"
              },
              "frontendPort": 8080,
              "backendPort": 8080,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.internalIpInvoice]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.internalInvoiceApiProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUIAPI",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').internalBackEnd]"
              },
              "frontendPort": 8668,
              "backendPort": 8668,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.internalIpInvoice]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.internalInvoiceUiApiProbe]"
              },
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUMS",
            "properties": {
              "backendAddressPool": {
                "id": "[variables('appLoadBalancerReferences').internalBackEnd]"
              },
              "frontendPort": 8715,
              "backendPort": 8715,
              "enableFloatingIP": "false",
              "frontendIPConfiguration": {
                "id": "[variables('appLoadBalancerReferences').frontEnd.internalIpInvoice]"
              },
              "idleTimeoutInMinutes": "5",
              "probe": {
                "id": "[variables('appLoadBalancerReferences').probes.internalInvoiceUmsProbe]"
              },
              "protocol": "tcp"
            }
          }
        ],
        "probes": [
          {
            "name": "invoiceApiProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8080,
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUiApiProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8668,
              "protocol": "tcp"
            }
          },
          {
            "name": "invoiceUmsProbe",
            "properties": {
              "intervalInSeconds": 5,
              "numberOfProbes": 2,
              "port": 8715,
              "protocol": "tcp"
            }
          }
        ],
        "inboundNatPools": []
      }
    ],

    "nsgRules": [
      {
        "name": "allowInternalReleaseAgents",
        "properties": {
          "description": "allow Internal Release Agents application port 19000",
          "protocol": "*",
          "sourcePortRange": "*",
          "destinationPortRange": "19000",
          "destinationAddressPrefix": "*",
          "access": "Allow",
          "priority": 2002,
          "direction": "Inbound",
          "sourcePortRanges": [],
          "destinationPortRanges": [],
          "sourceAddressPrefixes": ["52.188.252.52","52.188.252.55","20.125.158.88","20.125.158.91"],
          "destinationAddressPrefixes": []
        },
        "comments": "allow Internal Release Agents application port 19000"
      },
      {
        "name": "allowInvoiceApi",
        "properties": {
          "access": "Allow",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "8080",
          "direction": "Inbound",
          "priority": 2003,
          "protocol": "*",
          "sourceAddressPrefix": "AzureFrontDoor.Backend",
          "sourcePortRange": "*"
        },
        "comments": "allow public to InvoiceApi"
      },
      {
        "name": "allowInvoiceUiApi",
        "properties": {
          "access": "Allow",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "8668",
          "direction": "Inbound",
          "priority": 2005,
          "protocol": "*",
          "sourceAddressPrefix": "AzureFrontDoor.Backend",
          "sourcePortRange": "*"
        },
        "comments": "allow public to InvoiceUiApi"
      },
      {
        "name": "allowInternalInvoiceToUms",
        "properties": {
          "description": "allow public application port 5 UMS",
          "protocol": "*",
          "sourcePortRange": "*",
          "destinationPortRange": "8715",
          "destinationAddressPrefix": "*",
          "access": "Allow",
          "priority": 2006,
          "direction": "Inbound",
          "sourcePortRanges": [],
          "destinationPortRanges": [],
          "sourceAddressPrefixes": "[split(parameters('settings').sfWebServices.nsgConfiguration.allowInternalInvoiceToUmsList,',')]",
          "destinationAddressPrefixes": []
        },
        "comments": "allow public to UMS"
      },
      {
        "name": "allowInvoiceUms",
        "properties": {
          "access": "Allow",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "8715",
          "direction": "Inbound",
          "priority": 2007,
          "protocol": "*",
          "sourceAddressPrefix": "AzureFrontDoor.Backend",
          "sourcePortRange": "*"
        },
        "comments": "allow public to UMS"
      },
      {
        "name": "allowAPIMToWebAndUiApi",
        "properties": {
          "description": "allow traffic from APIM to Web and UI API",
          "protocol": "*",
          "sourcePortRange": "*",
          "destinationAddressPrefix": "*",
          "access": "Allow",
          "priority": 2008,
          "direction": "Inbound",
          "sourcePortRanges": [],
          "destinationPortRanges": [ "8080", "8668" ],
          "sourceAddressPrefixes": "[split(parameters('settings').sfWebServices.nsgConfiguration.allowedAPIMIPList,',')]",
          "destinationAddressPrefixes": []
        },
        "comments": "allows traffic from APIM to Web and UI API"
      },
      {
        "name": "allowInvoiceTagsToServices",
        "properties": {
          "description": "allow public application port 5 UMS",
          "protocol": "*",
          "sourcePortRange": "*",
          "destinationAddressPrefix": "*",
          "access": "Allow",
          "priority": 2010,
          "direction": "Inbound",
          "sourcePortRanges": [],
          "destinationPortRanges": [ "8080", "8668", "8715" ],
          "sourceAddressPrefix": "[concat('APInvoiceServices',if(contains(parameters('resourceNames').environment,'prd'),'','Test'))]",
          "destinationAddressPrefixes": []
        },
        "comments": "allow APInvoice Tag to UMS"
      },
      {
        "name": "allowSvcFabHttpsPortal",
        "properties": {
          "access": "Deny",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "19080",
          "direction": "Inbound",
          "priority": 3900,
          "protocol": "*",
          "sourceAddressPrefix": "*",
          "sourcePortRange": "*"
        },
        "comments": "allow port used to access the fabric cluster web portal"
      },
      {
        "name": "allowSvcFabClient",
        "properties": {
          "access": "Deny",
          "destinationAddressPrefix": "*",
          "destinationPortRange": "19000",
          "direction": "Inbound",
          "priority": 3910,
          "protocol": "*",
          "sourceAddressPrefix": "*",
          "sourcePortRange": "*"
        },
        "comments": "allow port used by the fabric client (includes powershell)"
      }
    ]
  },
  "resources": [
    {
      "comments": "IMPORTANT: This resource depends on the common network Azure Front Door to exist",
      "condition": false,
      "name": "[concat('createAPIMPublicEndPoint-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'factory-front-door-public-endpoint-publisher', '/versions/v1')]"
        },
        "parameters": {
          "settings": {
            "value": "[parameters('settings')]"
          },
          "resourceNames": {
            "value": "[parameters('resourceNames')]"
          },
          "cdnProfileName": {
            "value": "[parameters('resourceNames').primaryCdnProfileName]"
          },
          "cdnProfileOriginGroupName": {
            "value": "apim-origin-group"
          },
          "cdnProfileOriginGroupOriginName": {
            "value": "[concat(parameters('resourceNames').baseName,parameters('resourceNames').environment,'apim')]"
          },
          "hostName": {
            "value": "[concat('invp',take(parameters('resourceNames').environment,3),parameters('settings').common.region,'-01.regional.azure-api.net')]"
          },
          "originHostHeader": {
            "value": "[concat('invp',take(parameters('resourceNames').environment,3),parameters('settings').common.region,'-01.regional.azure-api.net')]"
          },
          "enforceCertificateNameCheck": {
            "value": false
          },
          "probePath": {
            "value": "/probe"
          },
          "probeProtocol": {
            "value": "Https"
          },
          "probeRequestType": {
            "value": "GET"
          },
          "afdEndPointName": {
            "value": "[tolower(concat(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[0].mainServiceName,parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[0].serviceRoleName,parameters('resourceNames').environment))]"
          },
          "routeName": {
            "value": "apim-route"
          },
          "customDomains": {
            "value": [
              {
                "id": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').commonNetworkResourceGroupName,'/providers/Microsoft.Cdn/profiles/',parameters('resourceNames').primaryCdnProfileName,'/customdomains/',replace(tolower(concat(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[0].mainServiceName,'.',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[0].serviceRoleName,'.',parameters('resourceNames').environment,'.',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[0].domainName)),'.','-'))]"
              }
            ]
          },
          "originGroupResourceId": {
            "value": {
              "id": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('resourceNames').commonNetworkResourceGroupName,'/providers/Microsoft.Cdn/profiles/',parameters('resourceNames').primaryCdnProfileName,'/origingroups/','apim-origin-group')]"
            }
          },
          "ruleSets": {
            "value": []
          },
          "supportedProtocols": {
            "value": [ "Http", "Https" ]
          },
          "patternsToMatch": {
            "value": [
              "/*"
            ]
          }
        }
      }
    },
    {
      "name": "[concat('CreateApplicationIps-',variables('appIPAddressNameList')[copyIndex()])]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sfWebResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CreateApplicationIpsLoop",
        "count": "[length(variables('appIPAddressNameList'))]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-publicIp', '/versions/v1')]"
        },
        "parameters": {
          "publicIpName": {
            "value": "[variables('appIPAddressNameList')[copyIndex()]]"
          },
          "domainNameLabel": {
            "value": "[variables('appIPAddressNameList')[copyIndex()]]"
          },
          "ipTagName": {
            "value": "[if(contains(toupper(parameters('resourceNames').environment),'PRD'),'APInvoiceServices','APInvoiceServicesTest')]"
          }
        }
      }
    },
    {
      "name": "[concat('CreateManagementIps-',parameters('settings').sfWebServices.scaleSetsDetails[copyIndex()].scaleSetTag,parameters('resourceNames').environment)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sfWebResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CreateManagementIpsLoop",
        "count": "[length(parameters('settings').sfWebServices.scaleSetsDetails )]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-publicIp', '/versions/v1')]"
        },
        "parameters": {
          "publicIpName": {
            "value": "[tolower(concat(parameters('resourceNames').publicIpBaseName,parameters('settings').sfWebServices.scaleSetsDetails[copyIndex()].scaleSetTag,'mgmt'))]"
          },
          "domainNameLabel": {
            "value": "[tolower(concat(parameters('settings').sfWebServices.scaleSetsDetails[copyIndex()].scaleSetTag,parameters('resourceNames').environment))]"
          },
          "ipTagName": {
            "value": "[if(contains(toupper(parameters('resourceNames').environment),'PRD'),'APInvoiceServices','APInvoiceServicesTest')]"
          }
        }
      }
    },
    {
      "name": "[concat('CreateLoadBalancer-',variables('loadBalancersConfiguration')[copyIndex()].description)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').sfWebResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CreateLoadBalancersLoop",
        "count": "[length(variables('loadBalancersConfiguration'))]"
      },
      "dependsOn": [
        "CreateManagementIpsLoop",
        "CreateApplicationIpsLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-loadBalancer', '/versions/v1')]"
        },
        "parameters": {
          "loadBalancerName": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].name]"
          },
          "loadBalancerRegion": {
            "value": "[parameters('settings').common.region]"
          },
          "frontendIPConfigurations": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].frontendIPConfigurations]"
          },
          "backendAddressPools": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].backendAddressPools]"
          },
          "loadBalancingRules": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].loadBalancingRules]"
          },
          "probes": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].probes]"
          },
          "inboundNatPools": {
            "value": "[variables('loadBalancersConfiguration')[copyIndex()].inboundNatPools]"
          }
        }
      }
    },
    {
