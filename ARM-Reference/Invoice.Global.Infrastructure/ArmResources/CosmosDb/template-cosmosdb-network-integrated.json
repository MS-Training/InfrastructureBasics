{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "accountName": {
      "type": "string",
      "metadata": {
        "description": "The name of the function app that you wish to create."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Cosmos DB account."
      }
    },
    "enableFreeTier": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Specifies the if you would like to use the free tier for Cosmos."
      }
    },
    "enableAnalyticalStorage": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Specifies the if you would like to enable Azure Synapse."
      }
    },
    "cosmosAPIType": {
      "type": "string",
      "defaultValue": "GlobalDocumentDB",
      "metadata": {
        "description": "MongoDB,GlobalDocumentDB "
      }
    },
    "defaultConsistencyLevel": {
      "type": "string",
      "defaultValue": "Session",
      "allowedValues": [
        "Eventual",
        "ConsistentPrefix",
        "Session",
        "BoundedStaleness",
        "Strong"
      ],
      "metadata": {
        "description": "The default consistency level of the Cosmos DB account."
      }
    },
    "geoLocationConfiguration": {
      "type": "array",
      "metadata": {
        "description": "Array of objects Regions for Cosmos Db to be Replicated"
      }
    },
    "ipRules": {
      "type": "array",
      "metadata": {
        "description": "an array with all the ipRules"
      }
    },
    "apiCapability": {
      "type": "string",
      "defaultValue": "Nothing",
      "allowedValues": [
        "Nothing",
        "EnableGremlin",
        "EnableCassandra",
        "EnableTable"
      ],
      "metadata": {
        "description": "This is use to passed a value to enable SQL API api capabilities like table API"
      }
    },
    "maxStalenessPrefix": {
      "type": "int",
      "defaultValue": 100,
      "minValue": 10,
      "maxValue": 2147483647,
      "metadata": {
        "description": "Max stale requests. Required for BoundedStaleness. Valid ranges, Single Region: 10 to 1000000. Multi Region: 100000 to 1000000."
      }
    },
    "maxIntervalInSeconds": {
      "type": "int",
      "defaultValue": 5,
      "minValue": 5,
      "maxValue": 86400,
      "metadata": {
        "description": "Max lag time (seconds). Required for BoundedStaleness. Valid ranges, Single Region: 5 to 84600. Multi Region: 300 to 86400."
      }
    },
    "workSpaceResourceId": {
      "type": "string",
      "defaultValue": "workspaceID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace "
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Keyvault where to store the secrets"
      }
    },
    "keyvaultResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the keyvault resource group"
      }
    },
    "commonVirtualNetworkResourceId": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource id of the common virtual network"
      }
    },
    "cosmosDbPrivateEndpointSubnetName": {
      "type": "string",
      "metadata": {
        "description": "The name of the subnet that will be use to host the fucntion private endpoint"
      }
    },
    "networkResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource Group where network resources are placed"
      }
    },
    "componentTag": {
      "type": "string",
      "metadata": {
        "description": "3 to 6 letters to abbreviate the component name"
      }
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
    "cosmosdbNICName": "[concat(parameters('accountName'),'nic1')]",
    "serviceGroupNames": [
      "Sql"
    ]
  },
  "resources": [
    {
      "name": "[concat('createCosmosDBAccount-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Cosmos-template-cosmosdb-accounts', '/versions/v1')]"
        },
        "parameters": {
          "accountName": {
            "value": "[parameters('accountName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "enableFreeTier": {
            "value": "[parameters('enableFreeTier')]"
          },
          "enableAnalyticalStorage": {
            "value": "[parameters('enableAnalyticalStorage')]"
          },
          "cosmosAPIType": {
            "value": "[parameters('cosmosAPIType')]"
          },
          "defaultConsistencyLevel": {
            "value": "[parameters('defaultConsistencyLevel')]"
          },
          "geoLocationConfiguration": {
            "value": "[parameters('geoLocationConfiguration')]"
          },
          "ipRules": {
            "value": "[parameters('IpRules')]"
          },
          "apiCapability": {
            "value": "[parameters('apiCapability')]"
          },
          "maxStalenessPrefix": {
            "value": "[parameters('maxStalenessPrefix')]"
          },
          "maxIntervalInSeconds": {
            "value": "[parameters('maxIntervalInSeconds')]"
          },
          "workSpaceResourceId": {
            "value": "[parameters('workSpaceResourceId')]"
          },
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          },
          "keyvaultResourceGroupName": {
            "value": "[parameters('keyvaultResourceGroupName')]"
          }
        }
      }
    },
    {
      "name": "[concat('createPrivateEndPointCDB-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat('createCosmosDBAccount-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateEndPoint', '/versions/v1')]"
        },
        "parameters": {
          "privateEndpointName": {
            "value": "[concat(parameters('accountName'),'pvtep')]"
          },
          "customNetworkInterfaceName": {
            "value": "[variables('cosmosdbNICName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "privateLinkServiceId": {
            "value": "[reference(concat('createCosmosDBAccount-', parameters('date'))).outputs.cosmosDbResourceId.value]"
          },
          "virtualNetworkId": {
            "value": "[parameters('commonVirtualNetworkResourceId')]"
          },
          "virtualNetworkSubnetName": {
            "value": "[parameters('cosmosDbPrivateEndpointSubnetName')]"
          },
          "serviceGroupNames": {
            "value": "[variables('serviceGroupNames')]"
          }
        }
      }
    },
    {
      "name": "[concat('create',parameters('componentTag'),'CosmosDbDNSRecordA-', copyindex(1), parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('networkResourceGroupName')]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CosmosDbDNSRecordALoop",
        "count": "[add(length(parameters('geoLocationConfiguration')),1)]"
      },
      "dependsOn": [
        "[concat('createPrivateEndPointCDB-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateDNSRecordA', '/versions/v1')]"
        },
        "parameters": {
          "privateDNSZoneName": {
            "value": "privatelink.documents.azure.com"
          },
          "dnsRecordName": {
            "value": "[reference(concat('createPrivateEndPointCDB-', parameters('date'))).outputs.privateEndPointIpConfiguration.value[copyindex()].properties.privateLinkConnectionProperties.requiredMemberName]"
          },
          "ipAddress": {
            "value": "[reference(concat('createPrivateEndPointCDB-', parameters('date'))).outputs.privateEndPointIpConfiguration.value[copyindex()].properties.privateIPAddress]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
