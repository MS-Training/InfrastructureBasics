{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "settings": {
      "type": "secureObject",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "resourceNames": {
      "type": "Object",
      "metadata": {
        "description": "This is coming from the parameter File under Parameters"
      }
    },
    "cdnProfileName": {
      "type": "string",
      "metadata": {
        "description": "Specify the Name of the CDN Profile"
      }
    },
    "cdnProfileOriginGroupName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Origin group, This will be used to map the back end compute"
      }
    },
    "probeIntervalInSeconds": {
      "type": "int",
      "defaultValue": 240,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probePath": {
      "type": "string",
      "defaultValue": "/",
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probeProtocol": {
      "type": "string",
      "defaultValue": "Http",
      "allowedValues": [
        "Http",
        "Https",
        "NotSet"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "probeRequestType": {
      "type": "string",
      "defaultValue": "GET",
      "allowedValues": [
        "GET",
        "HEAD",
        "NotSet"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "additionalLatencyInMilliseconds": {
      "type": "int",
      "defaultValue": 50,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "sampleSize": {
      "type": "int",
      "defaultValue": 4,
      "metadata": {
        "description": "Send and receive timeout on forwarding request to the origin. When timeout is reached, the request fails and returns."
      }
    },
    "successfulSamplesRequired": {
      "type": "int",
      "defaultValue": 3,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "sessionAffinityState": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Disabled",
        "Enabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "trafficRestorationTimeToHealedOrNewEndpointsInMinutes": {
      "type": "int",
      "defaultValue": 10,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups?pivots=deployment-language-arm-template"
      }
    },
    "afdEndPointName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Azure FrontDoor Endpoint."
      }
    },
    "routeName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Route, in this case we use the service name."
      }
    },
    "customDomains": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template",
        "sample": [
          {
            "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON-NETWORK/providers/Microsoft.Cdn/profiles/invdevfdcommon/customdomains/invoice-services-dev-microsoft-com"
          }
        ]
      }
    },
    "originGroupResourceId": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template",
        "sample": {
          "id": "/subscriptions/3fc9f1b6-c8f9-454a-a29d-426ffe58dbed/resourceGroups/RG-630-INV-DEV-COMMON-NETWORK/providers/Microsoft.Cdn/profiles/invdevfdcommon/origingroups/sapel-origin-group"
        }

      }
    },
    "ruleSets": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "An array that contain a list of rule sets, https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "supportedProtocols": {
      "type": "array",
      "defaultValue": [
        "Http",
        "Https"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "patternsToMatch": {
      "type": "array",
      "defaultValue": [
        "/api/sapel/*"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "forwardingProtocol": {
      "type": "string",
      "defaultValue": "HttpsOnly",
      "allowedValues": [
        "HttpOnly",
        "HttpsOnly",
        "MatchRequest"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "linkToDefaultDomain": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "httpsRedirect": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "enabledState": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/afdendpoints/routes?pivots=deployment-language-arm-template"
      }
    },
    "cdnProfileOriginGroupOriginName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Origin resource."
      }
    },
    "hostName": {
      "type": "string",
      "metadata": {
        "description": "example the host name of an function app that will be our backend"
      }
    },
    "originHostHeader": {
      "type": "string",
      "metadata": {
        "description": "example the host name of an function app that will be our backend"
      }
    },
    "enforceCertificateNameCheck": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    },
    "originWeight": {
      "type": "int",
      "defaultValue": 1000,
      "metadata": {
        "description": "See ARM documentation https://learn.microsoft.com/en-us/azure/templates/microsoft.cdn/profiles/origingroups/origins?pivots=deployment-language-arm-template"
      }
    }
  },
  "variables": {
    "comments": "if you are deploying a global front door, consider to deploy this whole templete only to the primary region"
  },
  "resources": [
    {
      "condition": "[parameters('settings').common.isPrimaryRegion]",
      "name": "[concat('CreateAzureFrontDoorOriginGroup-', parameters('cdnProfileOriginGroupName'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-originGroup', '/versions/v1')]"
        },
        "parameters": {
          "cdnProfileName": {
            "value": "[parameters('cdnProfileName')]"
          },
          "cdnProfileOriginGroupName": {
            "value": "[parameters('cdnProfileOriginGroupName')]"
          },
          "probeIntervalInSeconds": {
            "value": "[parameters('probeIntervalInSeconds')]"
          },
          "probePath": {
            "value": "[parameters('probePath')]"
          },
          "probeProtocol": {
            "value": "[parameters('probeProtocol')]"
          },
          "probeRequestType": {
            "value": "[parameters('probeRequestType')]"
          },
          "additionalLatencyInMilliseconds": {
            "value": "[parameters('additionalLatencyInMilliseconds')]"
          },
          "sampleSize": {
            "value": "[parameters('sampleSize')]"
          },
          "successfulSamplesRequired": {
            "value": "[parameters('successfulSamplesRequired')]"
          },
          "sessionAffinityState": {
            "value": "[parameters('sessionAffinityState')]"
          },
          "trafficRestorationTimeToHealedOrNewEndpointsInMinutes": {
            "value": "[parameters('trafficRestorationTimeToHealedOrNewEndpointsInMinutes')]"
          }
        }
      }
    },
    {
      "name": "[concat('CreateAzureFrontDoorOriginGroupOrigin-', parameters('cdnProfileOriginGroupOriginName'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').primaryCommonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[concat('CreateAzureFrontDoorOriginGroup-', parameters('cdnProfileOriginGroupName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-originGroup-origin', '/versions/v1')]"
        },
        "parameters": {
          "cdnProfileName": {
            "value": "[parameters('cdnProfileName')]"
          },
          "cdnProfileOriginGroupName": {
            "value": "[parameters('cdnProfileOriginGroupName')]"
          },
          "cdnProfileOriginGroupOriginName": {
            "value": "[parameters('cdnProfileOriginGroupOriginName')]"
          },
          "hostName": {
            "value": "[parameters('hostName')]"
          },
          "originHostHeader": {
            "value": "[parameters('originHostHeader')]"
          },
          "enforceCertificateNameCheck": {
            "value": "[parameters('enforceCertificateNameCheck')]"
          },
          "weight": {
            "value": "[parameters('originWeight')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').common.isPrimaryRegion]",
      "name": "[concat('CreateAzureFrontDoorRoute-', parameters('routeName'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[concat('CreateAzureFrontDoorOriginGroup-', parameters('cdnProfileOriginGroupName'))]",
        "[concat('CreateAzureFrontDoorOriginGroupOrigin-', parameters('cdnProfileOriginGroupOriginName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-afdEndPoint-route', '/versions/v1')]"
        },
        "parameters": {
          "cdnProfileName": {
            "value": "[parameters('cdnProfileName')]"
          },
          "afdEndPointName": {
            "value": "[parameters('afdEndPointName')]"
          },
          "routeName": {
            "value": "[parameters('routeName')]"
          },
          "customDomains": {
            "value": "[parameters('customDomains')]"
          },
          "originGroupResourceId": {
            "value": "[parameters('originGroupResourceId')]"
          },
          "ruleSets": {
            "value": "[parameters('ruleSets')]"
          },
          "supportedProtocols": {
            "value": "[parameters('supportedProtocols')]"
          },
          "patternsToMatch": {
            "value": "[parameters('patternsToMatch')]"
          },
          "forwardingProtocol": {
            "value": "[parameters('forwardingProtocol')]"
          },
          "linkToDefaultDomain": {
            "value": "[parameters('linkToDefaultDomain')]"
          },
          "httpsRedirect": {
            "value": "[parameters('httpsRedirect')]"
          },
          "enabledState": {
            "value": "[parameters('enabledState')]"
          }
        }
      }
    }
  ],
  "outputs": {
  }
}
