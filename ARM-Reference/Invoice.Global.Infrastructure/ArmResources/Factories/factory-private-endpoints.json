{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "privateEndpointsDetails": {
      "type": "array",
      "metadata": {
        "description": [
          {
            "resourceName": "keyvaultname",
            "resourceGroupName": "keyvaultResourceGroupName",
            "privateLinkServiceId": "/subscriptions/b7aae6f6-5584-47ce-89ce-26e555b74a4//resourceGroups/samplergname/providers/Microsoft.KeyVault/vaults/keyvaultname",
            "virtualNetworkId": "/subscriptions/b7aae6f6-5584-47ce-89ce-26e555b74a4/resourceGroups/samplergname/providers/Microsoft.Network/virtualNetworks/virtualNetworkName",
            "virtualNetworkSubnetName": "sampleSubnetName",
            "serviceGroupNames": [ "vault" ],
            "location": "theLocation",
            "networkResourceGroupName": "leave Blank If createDNSRecords is false",
            "privateDNSZoneName": "leave Blank If createDNSRecords is false"
          },
          {
            "resourceName": "storageAccountName",
            "resourceGroupName": "sotorageResourceGroupName",
            "privateLinkServiceId": "/subscriptions/b7aae6f6-5584-47ce-89ce-26e555b74a4//resourceGroups/samplergname/providers/Microsoft.KeyVault/vaults/storageAccountName",
            "virtualNetworkId": "/subscriptions/b7aae6f6-5584-47ce-89ce-26e555b74a4/resourceGroups/samplergname/providers/Microsoft.Network/virtualNetworks/virtualNetworkName",
            "virtualNetworkSubnetName": "sampleSubnetName",
            "serviceGroupNames": [ "storage" ],
            "location": "theLocation",
            "networkResourceGroupName": "leave Blank If createDNSRecords is false",
            "privateDNSZoneName": "leave Blank If createDNSRecords is false"
          }
        ]
      }
    },
    "createDNSRecords": {
      "type": "bool",
      "defaultValue": false
    },
    "addPrivateEndPointPrefix": {
      "type": "bool",
      "defaultValue": false
    },
    "date": {
      "type": "string",
      "defaultValue": "[utcNow()]"
    }
  },
  "variables": {
  },
  "resources": [
    {
      "name": "[take(concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,'-PvtEndPoint-',copyindex(1), parameters('date')),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('privateEndpointsDetails') [copyIndex()].resourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createPvtEndPointsLoop",
        "mode": "serial",
        "count": "[length(parameters('privateEndpointsDetails'))]"
      },
      "dependsOn": [],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateEndPoint', '/versions/v1')]"
        },
        "parameters": {
          "privateEndpointName": {
            "value": "[concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,if(parameters('addPrivateEndPointPrefix'),parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0],''),'pvtep')]"
          },
          "customNetworkInterfaceName": {
            "value": "[concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,if(parameters('addPrivateEndPointPrefix'),parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0],''),'nic1')]"
          },
          "location": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].location]"
          },
          "privateLinkServiceId": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].privateLinkServiceId]"
          },
          "virtualNetworkId": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].virtualNetworkId]"
          },
          "virtualNetworkSubnetName": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].virtualNetworkSubnetName]"
          },
          "serviceGroupNames": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,'-PvtEpStaticIp-',copyindex(1), parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('privateEndpointsDetails') [copyIndex()].resourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "setPvtEndPointStaticIpLoop",
        "mode": "serial",
        "count": "[length(parameters('privateEndpointsDetails'))]"
      },
      "dependsOn": [
        "[take(concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,'-PvtEndPoint-',copyindex(1), parameters('date')),60)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateEndPoint-staticIP', '/versions/v1')]"
        },
        "parameters": {
          "privateEndpointName": {
            "value": "[concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,if(parameters('addPrivateEndPointPrefix'),parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0],''),'pvtep')]"
          },
          "customNetworkInterfaceName": {
            "value": "[concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,if(parameters('addPrivateEndPointPrefix'),parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0],''),'nic1')]"
          },
          "location": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].location]"
          },
          "privateLinkServiceId": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].privateLinkServiceId]"
          },
          "virtualNetworkId": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].virtualNetworkId]"
          },
          "virtualNetworkSubnetName": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].virtualNetworkSubnetName]"
          },
          "serviceGroupNames": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames]"
          },
          "ipConfigurations": {
            "value": [
              {
                "name": "ipconfig1",
                "properties": {
                  "memberName": "[if(or(equals(tolower(parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0]),'vault'),equals(tolower(parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0]),'account')),'default',parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0])]",
                  "groupId": "[parameters('privateEndpointsDetails') [copyIndex()].serviceGroupNames[0]]",
                  "privateIPAddress": "[reference(take(concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,'-PvtEndPoint-',copyindex(1), parameters('date')),60)).outputs.privateEndPointIpConfiguration.value[0].properties.privateIPAddress]"
                }
              }
            ]
          }
        }
      }
    },
    {
      "condition": "[parameters('createDNSRecords')]",
      "name": "[take(concat('createDNSRecordA-',parameters('privateEndpointsDetails') [copyIndex()].resourceName,copyindex(1), parameters('date')),60)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('privateEndpointsDetails') [copyIndex()].networkResourceGroupName]",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "createDNSRecordLoop",
        "mode": "serial",
        "count": "[length(parameters('privateEndpointsDetails'))]"
      },
      "dependsOn": [
        "setPvtEndPointStaticIpLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateDNSRecordA', '/versions/v1')]"
        },
        "parameters": {
          "privateDNSZoneName": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].privateDNSZoneName]"
          },
          "dnsRecordName": {
            "value": "[parameters('privateEndpointsDetails') [copyIndex()].resourceName]"
          },
          "ipAddress": {
            "value": "[reference(concat(parameters('privateEndpointsDetails') [copyIndex()].resourceName,'-PvtEpStaticIp-',copyindex(1), parameters('date'))).outputs.privateEndPointIpAddress.value]"
          }
        }
      }
    }
  ]
}