{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dotnetFrameworkVersion": {
      "type": "string",
      "defaultValue": "v8.0",
      "metadata": {
        "description": "The .NET Framework version that you want to use for the function app."
      }
    },
    "functionIdentities": {
      "type": "object",
      "defaultValue": {
        "type": "SystemAssigned"
      },
      "metadata": {
        "description": "The System or User Assigned Identities Object used to create the function and the Identities used by the function."
      }
    },
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the keyvault to store the secrets"
      }
    },
    "functionDelagatedSubnetName": {
      "type": "string",
      "metadata": {
        "description": "The name of the subnet that is delegated to integrate the function app. at least a /27 subnet"
      }
    },
    "functionPrivateEndpointSubnetName": {
      "type": "string",
      "metadata": {
        "description": "The name of the subnet that will be use to host the fucntion private endpoint"
      }
    },
    "functionSettings": {
      "type": "secureObject",
      "metadata": {
        "description": "An array with all the configuration of the function"
      }
    },
    "hostingPlanResourceId": {
      "type": "string",
      "metadata": {
        "description": "The Name of the keyvault to store the secrets"
      }
    },
    "componentTag": {
      "type": "string",
      "metadata": {
        "description": "3 to 6 letters to abbreviate the component name"
      }
    },
    "componentResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource Group where this component will be places"
      }
    },
    "commonResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource Group where common resources like kv, la are placed "
      }
    },
    "networkResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource Group where network resources are placed"
      }
    },
    "commonVirtualNetworkResourceId": {
      "type": "string",
      "metadata": {
        "description": "The name of the Resource id of the common virtual network"
      }
    },
    "commonKeyvaultName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the keyvault to store the secrets"
      }
    },
    "commonWorkSpaceResourceId": {
      "type": "string",
      "defaultValue": "workspace resource ID",
      "metadata": {
        "description": "Full Resource ID for the Log Analytics workspace "
      }
    },
    "guidValue": {
      "type": "string",
      "defaultValue": "[newGuid()]",
      "metadata": {
        "description": "A unique value to ensure deployment names are unique"
      }
    },
    "publicNetworkAccess": {
      "type": "string"
    },
    "roleDefinitionObjectId": {
      "type": "string"
    }
  },
  "variables": {
    "functionNICName": "[concat(parameters('functionAppName'),'nic1')]",
    "serviceGroupNames": [
      "sites"
    ],
    "corsAllowURL": [
      "https://functions.azure.com",
      "https://functions-staging.azure.com",
      "https://functions-next.azure.com"
    ]
  },
  "resources": [
    {
      "name": "[take(concat('createFunctionApp-',parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('componentResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Function-template-function', '/versions/v1')]"
        },
        "parameters": {
          "dotnetFrameworkVersion": {
            "value": "[parameters('dotnetFrameworkVersion')]"
          },
          "functionIdentities": {
            "value": "[parameters('functionIdentities')]"
          },
          "functionAppName": {
            "value": "[parameters('functionAppName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "corsAllowURL": {
            "value": "[variables('corsAllowURL')]"
          },
          "hostingPlanResourceId": {
            "value": "[parameters('hostingPlanResourceId')]"
          },
          "appSettings": {
            "value": "[parameters('functionSettings')]"
          },
          "virtualNetworkSubnetId": {
            "value": "[concat(parameters('commonVirtualNetworkResourceId'),'/subnets/',parameters('functionDelagatedSubnetName'))]"
          },
          "workSpaceResourceId": {
            "value": "[parameters('commonWorkSpaceResourceId')]"
          },
          "publicNetworkAccess": {
            "value": "[parameters('publicNetworkAccess')]"
          }
        }
      }
    },
    {
      "name": "[take(concat('createPrivateEndPoint-', parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('componentResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[take(concat('createFunctionApp-',parameters('guidValue')),64)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateEndPoint', '/versions/v1')]"
        },
        "parameters": {
          "privateEndpointName": {
            "value": "[concat(parameters('functionAppName'),'pvtep')]"
          },
          "customNetworkInterfaceName": {
            "value": "[variables('functionNICName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "privateLinkServiceId": {
            "value": "[reference(take(concat('createFunctionApp-',parameters('guidValue')),64)).outputs.functionResourceId.value]"
          },
          "virtualNetworkId": {
            "value": "[parameters('commonVirtualNetworkResourceId')]"
          },
          "virtualNetworkSubnetName": {
            "value": "[parameters('functionPrivateEndpointSubnetName')]"
          },
          "serviceGroupNames": {
            "value": "[variables('serviceGroupNames')]"
          }
        }
      }
    },
    {
      "name": "[take(concat('setStaticIPAddressPrivateEndPoint-', parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('componentResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[take(concat('createPrivateEndPoint-', parameters('guidValue')),64)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateEndPoint-staticIP', '/versions/v1')]"
        },
        "parameters": {
          "privateEndpointName": {
            "value": "[concat(parameters('functionAppName'),'pvtep')]"
          },
          "customNetworkInterfaceName": {
            "value": "[variables('functionNICName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "privateLinkServiceId": {
            "value": "[reference(take(concat('createFunctionApp-',parameters('guidValue')),64)).outputs.functionResourceId.value]"
          },
          "virtualNetworkId": {
            "value": "[parameters('commonVirtualNetworkResourceId')]"
          },
          "virtualNetworkSubnetName": {
            "value": "[parameters('functionPrivateEndpointSubnetName')]"
          },
          "serviceGroupNames": {
            "value": "[variables('serviceGroupNames')]"
          },
          "ipConfigurations": {
            "value": [
              {
                "name": "ipconfig1",
                "properties": {
                  "memberName": "sites",
                  "groupId": "sites",
                  "privateIPAddress": "[reference(take(concat('createPrivateEndPoint-', parameters('guidValue')),64)).outputs.privateEndPointIpConfiguration.value[0].properties.privateIPAddress]"
                }
              }
            ]
          }
        }
      }
    },
    {
      "name": "[take(concat('add',parameters('componentTag'),'FunctionAppKVPermissions-', parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('commonResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[take(concat('createFunctionApp-',parameters('guidValue')),64)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('commonResourceGroupName'),'/providers/Microsoft.KeyVault/vaults/',parameters('commonKeyvaultName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(take(concat('createFunctionApp-',parameters('guidValue')),64)).outputs.functionObjectId.value]"
          },
          "roleDefinitionObjectId": {
            "value": "[parameters('roleDefinitionObjectId')]"
          }
        }
      }
    },
    {
      "name": "[take(concat('add',parameters('componentTag'),'FunctionAppKVReaderPermissions-', parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('commonResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[take(concat('createFunctionApp-',parameters('guidValue')),64)]",
        "[take(concat('add',parameters('componentTag'),'FunctionAppKVPermissions-', parameters('guidValue')),64)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Security-template-authorization-roleAssigment', '/versions/v1')]"
        },
        "parameters": {
          "resourceIdToAddAccessTo": {
            "value": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('commonResourceGroupName'),'/providers/Microsoft.KeyVault/vaults/',parameters('commonKeyvaultName'))]"
          },
          "ObjectIdToGrantAccess": {
            "value": "[reference(take(concat('createFunctionApp-',parameters('guidValue')),64)).outputs.functionObjectId.value]"
          },
          "roleDefinitionObjectId": {
            "value": "21090545-7ca7-4776-b22c-e363652d74d2"
          }
        }
      }
    },
    {
      "name": "[take(concat('create',parameters('componentTag'),'FunctionADNSRecordA-', parameters('guidValue')),64)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('networkResourceGroupName')]",
      "apiVersion": "2022-09-01",
      "dependsOn": [
        "[take(concat('setStaticIPAddressPrivateEndPoint-', parameters('guidValue')),64)]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Network-template-network-privateDNSRecordA', '/versions/v1')]"
        },
        "parameters": {
          "privateDNSZoneName": {
            "value": "privatelink.azurewebsites.net"
          },
          "dnsRecordName": {
            "value": "[parameters('functionAppName')]"
          },
          "ipAddress": {
            "value": "[reference(take(concat('setStaticIPAddressPrivateEndPoint-', parameters('guidValue')),64)).outputs.privateEndPointIpAddress.value]"
          }
        }
      }
    }
  ],
  "outputs": {
    "functionObjectId": {
      "type": "string",
      "value": "[reference(take(concat('createFunctionApp-',parameters('guidValue')),64)).outputs.functionObjectId.value]"
    }
  }
}