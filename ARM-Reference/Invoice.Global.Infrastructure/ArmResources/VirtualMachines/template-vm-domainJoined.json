{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "CSEOAutomationDSCRegistrationKey": {
      "type": "securestring",
      "metadata": {
        "description": "Azure Automation Registration Key"
      }
    },
    "CSEOAutomationDSCServerUrlKeyVault": {
      "type": "securestring",
      "metadata": {
        "description": "Azure Automation Registration URL"
      }
    },
    "CSEOSasToken": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "SAS token to access blob/container of CSEO Templates"
      }
    },
    "armTemplatesSasToken": {
      "type": "string"
    },
    "armTemplateURI": {
      "type": "string",
      "metadata": {
        "description": "The Url of the storage account and Container where your Resources are stored"
      }
    },
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "vmName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "The resource id of a user assigned managed Identity"
      }
    },
    "vmRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "timeZone": {
      "type": "string",
      "defaultValue": "\"Pacific Standard Time\""
    },
    "AvailabilitySetName": {
      "type": "string",
      "defaultValue": "",
      "minLength": 3,
      "metadata": {
        "description": "Name for the AvailabilitySet."
      }
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Number of VMs to deploy"
      }
    },
    "localAdminUserName": {
      "type": "string",
      "defaultValue": "ITSVC0",
      "metadata": {
        "description": "Local Username for the Virtual Machine."
      }
    },
    "localAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Local Password for the Virtual Machine."
      }
    },
    "domainJoinUserName": {
      "minLength": 1,
      "type": "String",
      "defaultValue": "redmond\\mssoadev",
      "metadata": {
        "description": "Account for domain joining, ex. redmond\\serviceaccount"
      }
    },
    "domainJoinPassword": {
      "minLength": 1,
      "type": "SecureString",
      "metadata": {
        "description": "Password for domain joining"
      }
    },
    "localAdmins": {
      "defaultValue": "Redmond\\mssoadev,Redmond\\JIT_MSS-FIFSASWE_ElevatedAccess",
      "type": "String",
      "metadata": {
        "description": "Users and groups added to the local administrator group.  For SQL, SQL AO, and Web ILB templates. Example: Redmond\\SQLSvcAccounts,redmond\\serviceaccount,redmond\\teamgroup"
      }
    },
    "SQLAdmins": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "SQL SYS admins that can login to the Default SQL Instance instaqlled on the VM. csv list of domain\\user. Leave this blank (default value) if no SQL VM"
      }
    },
    "SQLServerAccount": {
      "type": "string",
      "defaultValue": "[parameters('domainJoinUserName')]",
      "minLength": 1,
      "metadata": {
        "description": "Account for SQL Server"
      }
    },
    "SQLServerPassword": {
      "type": "securestring",
      "defaultValue": "[parameters('domainJoinPassword')]",
      "metadata": {
        "description": "Password for SQL Server"
      }
    },
    "Domain": {
      "defaultValue": "Redmond",
      "allowedValues": [
        "Redmond",
        "Partners",
        "Europe",
        "NorthAmerica",
        "Fareast",
        "SouthPacific",
        "SouthAmerica",
        "MiddleEast",
        "Africa"
      ],
      "type": "String",
      "metadata": {
        "description": "The FQDN of the AD domain.  Important! Administrative access to servers at Microsoft may require the use of Secure Admin Workstation SAW.  Details at http://aka.ms/SAWfaq"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_A2",
      "metadata": {
        "description": "Size for the Virtual Machine."
      }
    },
    "AcceleratedNetworking": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Accelerated Networking can only be enabled on supported SKUs.  See https://docs.microsoft.com/en-us/azure/virtual-network/create-vm-accelerated-networking-powershell for details."
      }
    },
    "imagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsServer",
      "metadata": {
        "description": "OS Image Publisher. https://azure.microsoft.com/en-us/documentation/articles/virtual-machines-linux-cli-ps-findimage/"
      }
    },
    "imageOffer": {
      "type": "string",
      "defaultValue": "WindowsServer",
      "metadata": {
        "description": "Allowed Windows values: WindowsServer. Allowed SQL Values: SQL2012SP2-WS2012, SQL2012SP2-WS2012R2,SQL2014-WS2012R2, SQL2014SP1-WS2012R2, SQL2016CTP3-WS2012R2, SQL2016CTP3.1-WS2012R2, SQL2016CTP3.2-WS2012R2, SQL2016RC3-WS2012R2v2."
      }
    },
    "StorageAccountType": {
      "type": "string",
      "minLength": 1,
      "allowedValues": [
        "Standard_LRS",
        "Premium_LRS",
        "StandardSSD_LRS"
      ],
      "metadata": {
        "description": "Storage performance, Standard_LRS for standard skus and Premium_LRS for premium skus"
      }
    },
    "sku": {
      "defaultValue": "2019-datacenter",
      "minLength": 1,
      "type": "String",
      "metadata": {
        "description": "See publisher for details"
      }
    },
    "osDiskSizeGB": {
      "type": "string",
      "defaultValue": "256",
      "metadata": {
        "description": "The Size of OS Disks in GB"
      }
    },
    "dataDiskCount": {
      "type": "int",
      "defaultValue": 8,
      "metadata": {
        "description": "Number of Data Disks per VM to deploy. Ensure you attach enough Disk the DataDiskConfiguration"
      }
    },
    "dataDiskSizeGB": {
      "type": "string",
      "defaultValue": "1024",
      "metadata": {
        "description": "The Size of all the Data Disks in GB"
      }
    },
    "driveConfig": {
      "type": "string",
      "defaultValue": "-DriveString E:2,H:2,O:2,T:2 -ResiliencySetting simple -InterleaveValue 262144 -OSAllocationUnitSize 65536 -Verbose",
      "metadata": {
        "description": "Please provide the Drive onfiguration String as shown on the default value. DriveString is VolumeLetter:NumberOfDisks. The size of each VirtualDisk will be NumberOfDisks X dataDiskSizeGB"
      }
    },
    "virtualNetwork": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name for the VirtualNetwork"
      }
    },
    "vnetResourceGroup": {
      "type": "string",
      "defaultValue": "ERNetwork-DB",
      "metadata": {
        "description": "Name for the Resource Group that contains VirtualNetwork"
      }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "Subnet-1",
      "metadata": {
        "description": "Name for the subnet"
      }
    },
    "bootDiagnosysStorageAccountName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "bootDiagnosticsResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Boot Diagnosys Storage Account Resource Group Name"
      }
    },
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "workspaceResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics Resource Group Name"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the KeyVault to place the volume encryption key"
      }
    },
    "keyVaultResourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group of the KeyVault"
      }
    },
    "isFirstDeployment": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Select whether this is the first Deployment or not."
      }
    },
    "isS2DCluster": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "This Flag is only used to create S2D Cluster. If you want to create an S2D Cluster look at component Domain Servers as sample otherwise leave this as No its default value"
      }
    },
    "setSQLServiceAccount": {
      "type": "bool",
      "defaultValue": true
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/",
    "scriptsTemplatePath": "/Scripts/",
    "vmsConfigPath": "/VirtualMachinesConfig/",
    "Role": "[if(equals(parameters('imagePublisher'),'MicrosoftWindowsServer'),'Win','SQL')]",
    "branch": "master",
    "NestedBaseURL": "[concat('https://armcloudms.blob.core.windows.net/nested/',variables('branch'))]",
    "nestedURL": "[concat(variables('NestedBaseURL'),'/all-nested/')]",
    "AttachVMtoPullServerURL": "[concat(variables('nestedURL'),variables('configurePullTemplate'))]",
    "configurePullTemplate": "[concat('template-ConfigureDscPull.json',parameters('CSEOSasToken'))]",
    "AzureAutomation": {
      "RegistrationKey": "[parameters('CSEOAutomationDSCRegistrationKey')]",
      "registrationUrl": "[parameters('CSEOAutomationDSCServerUrlKeyVault')]",
      "configurationFunction": "UpdateLCMforAAPull.ps1\\ConfigureLCMforAAPull",
      "timestamp": "1/1/2015"
    }
  },
  "resources": [
    {
      "condition": "[parameters('isFirstDeployment')]",
      "apiVersion": "2016-04-30-preview",
      "type": "Microsoft.Compute/availabilitySets",
      "name": "[parameters('availabilitySetName')]",
      "location": "[parameters('vmRegion')]",
      "tags": {
        "displayName": "AvailabilitySet"
      },
      "properties": {
        "platformFaultDomainCount": "[if(greater(parameters('numberOfInstances'),5),3,2)]",
        "platformUpdateDomainCount": 10,
        "managed": true
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CreateVirtualMachinesLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat('Microsoft.Compute/availabilitySets/', parameters('availabilitySetName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VirtualMachine-template-virtualMachine', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "userAssignedIdentityResourceId": {
            "value": "[parameters('userAssignedIdentityResourceId')]"
          },
          "AvailabilitySetName": {
            "value": "[parameters('availabilitySetName')]"
          },
          "localAdminUserName": {
            "value": "[parameters('localAdminUserName')]"
          },
          "localAdminPassword": {
            "value": "[parameters('localAdminPassword')]"
          },
          "vmOwnerAccount": {
            "value": "[parameters('domainJoinUserName')]"
          },
          "vmSize": {
            "value": "[parameters('vmSize')]"
          },
          "AcceleratedNetworking": {
            "value": "[parameters('AcceleratedNetworking')]"
          },
          "imagePublisher": {
            "value": "[parameters('imagePublisher')]"
          },
          "imageOffer": {
            "value": "[parameters('imageOffer')]"
          },
          "StorageAccountType": {
            "value": "[parameters('StorageAccountType')]"
          },
          "sku": {
            "value": "[parameters('sku')]"
          },
          "osDiskSizeGB": {
            "value": "[parameters('osDiskSizeGB')]"
          },
          "dataDiskCount": {
            "value": "[parameters('dataDiskCount')]"
          },
          "dataDiskSizeGB": {
            "value": "[parameters('dataDiskSizeGB')]"
          },
          "virtualNetwork": {
            "value": "[parameters('virtualNetwork')]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('vnetResourceGroup')]"
          },
          "subnetName": {
            "value": "[parameters('subnetName')]"
          },
          "bootDiagnosysStorageAccountName": {
            "value": "[parameters('bootDiagnosysStorageAccountName')]"
          },
          "bootDiagnosticsResourceGroupName": {
            "value": "[parameters('bootDiagnosticsResourceGroupName')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[not(parameters('isS2DCluster'))]",
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureStoragePools')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ConfigureStoragePoolsLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-ps-script', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "powershellFileName": {
            "value": "ConfigureStoragePools.ps1"
          },
          "powershellParameters": {
            "value": "[parameters('driveConfig')]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath') ,'ConfigureStoragePools.ps1', parameters('armTemplatesSasToken'))]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('isFirstDeployment')]",
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-JoinToDomain')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "DomainJoinLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureStoragePools')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-joinDomain', '/versions/v1')]"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "localAdminUserName": {
            "value": "[parameters('localAdminUserName')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "localAdminPassword": {
            "value": "[parameters('localAdminPassword')]"
          },
          "domainJoinUserName": {
            "value": "[parameters('domainJoinUserName')]"
          },
          "domainJoinPassword": {
            "value": "[parameters('domainJoinPassword')]"
          },
          "localAdmins": {
            "value": "[parameters('localAdmins')]"
          },
          "SQLAdmins": {
            "value": "[parameters('SQLAdmins')]"
          },
          "Domain": {
            "value": "[parameters('Domain')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-BaseConfig')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-JoinToDomain')]"
      ],
      "copy": {
        "name": "ConfigureVirtualMachinesLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'template-vm-baseConfiguration', '/versions/v1')]"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('templatespecsBaseResourceId')]"
          },
          "timeZone": {
            "value": "[parameters('timeZone')]"
          },
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "AcceleratedNetworking": {
            "value": "[parameters('AcceleratedNetworking')]"
          },
          "virtualNetwork": {
            "value": "[parameters('virtualNetwork')]"
          },
          "IpAddress": {
            "value": "[reference(concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')).outputs.ipAddress.value]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('vnetResourceGroup')]"
          },
          "subnetName": {
            "value": "[parameters('subnetName')]"
          },
          "workspaceName": {
            "value": "[parameters('workspaceName')]"
          },
          "workspaceResourceGroupName": {
            "value": "[parameters('workspaceResourceGroupName')]"
          },
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          },
          "keyVaultResourceGroup": {
            "value": "[parameters('keyVaultResourceGroupName')]"
          },
          "isFirstDeployment": {
            "value": "[parameters('isFirstDeployment')]"
          },
          "diagnosticsStorageAccountName": {
            "value": "[parameters('bootDiagnosysStorageAccountName')]"
          },
          "diagnosticsResourceGroupName": {
            "value": "[parameters('bootDiagnosticsResourceGroupName')]"
          },
          "isS2DCluster": {
            "value": "[parameters('isS2DCluster')]"
          }
        }
      }
    },
    {
      "condition": "[and(equals(variables('Role'), 'SQL'),parameters('isFirstDeployment'))]",
      "type": "Microsoft.Resources/deployments",
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureSQLServer')]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-BaseConfig')]"
      ],
      "copy": {
        "name": "BuildSQLMachineRoleLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'template-domainJoined-vm-sql-configuration', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('templatespecsBaseResourceId')]"
          },
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "SQLDiskConfig": {
            "value": "SQLPrem"
          },
          "vmSize": {
            "value": "[parameters('vmSize')]"
          },
          "SQLServerAccount": {
            "value": "[parameters('SQLServerAccount')]"
          },
          "SQLServerPassword": {
            "value": "[parameters('SQLServerPassword')]"
          },
          "SQLAgentAccount": {
            "value": "[parameters('SQLServerAccount')]"
          },
          "SQLAgentPassword": {
            "value": "[parameters('SQLServerPassword')]"
          },
          "SQLAdmin": {
            "value": "[parameters('SQLServerAccount')]"
          },
          "SQLAdminPwd": {
            "value": "[parameters('SQLServerPassword')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "setSQLServiceAccount": {
            "value": "[parameters('setSQLServiceAccount')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "vmIpAddresses": {
      "type": "array",
      "copy": {
        "count": "[parameters('numberOfInstances')]",
        "input": "[reference(concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')).outputs.ipAddress.value]"
      }
    },
    "vmIdentityObjectIds": {
      "type": "array",
      "copy": {
        "count": "[parameters('numberOfInstances')]",
        "input": "[reference(concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')).outputs.vmIdentityObjectId.value]"
      }
    }
  }
}