{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "armTemplatesSasToken": {
      "type": "string"
    },
    "armTemplateURI": {
      "type": "string",
      "metadata": {
        "description": "The Url of the storage account and Container where your Resources are stored"
      }
    },
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "vmName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "The resource id of a user assigned managed Identity"
      }
    },
    "vmRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "AvailabilitySetName": {
      "type": "string",
      "defaultValue": "",
      "minLength": 3,
      "metadata": {
        "description": "Name for the AvailabilitySet."
      }
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Number of VMs to deploy"
      }
    },
    "localAdminUserName": {
      "type": "string",
      "metadata": {
        "description": "Local Username for the Virtual Machine."
      }
    },
    "localAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Local Password for the Virtual Machine."
      }
    },
    "vmOwnerAccount": {
      "type": "string",
      "metadata": {
        "description": "Username for domain joining"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_A2",
      "metadata": {
        "description": "Size for the Virtual Machine."
      }
    },
    "AcceleratedNetworking": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Accelerated Networking can only be enabled on supported SKUs.  See https://docs.microsoft.com/en-us/azure/virtual-network/create-vm-accelerated-networking-powershell for details."
      }
    },
    "imagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsServer",
      "metadata": {
        "description": "OS Image Publisher. https://azure.microsoft.com/en-us/documentation/articles/virtual-machines-linux-cli-ps-findimage/"
      }
    },
    "imageOffer": {
      "type": "string",
      "defaultValue": "WindowsServer",
      "metadata": {
        "description": "Allowed Windows values: WindowsServer. Allowed SQL Values: SQL2012SP2-WS2012, SQL2012SP2-WS2012R2,SQL2014-WS2012R2, SQL2014SP1-WS2012R2, SQL2016CTP3-WS2012R2, SQL2016CTP3.1-WS2012R2, SQL2016CTP3.2-WS2012R2, SQL2016RC3-WS2012R2v2."
      }
    },
    "StorageAccountType": {
      "type": "string",
      "minLength": 1,
      "allowedValues": [
        "Standard_LRS",
        "Premium_LRS",
        "StandardSSD_LRS"
      ],
      "metadata": {
        "description": "Storage performance, Standard_LRS for standard skus and Premium_LRS for premium skus"
      }
    },
    "sku": {
      "defaultValue": "2022-datacenter",
      "minLength": 1,
      "type": "String",
      "metadata": {
        "description": "See publisher for details"
      }
    },
    "osDiskSizeGB": {
      "type": "string",
      "defaultValue": "256",
      "metadata": {
        "description": "The Size of OS Disks in GB"
      }
    },
    "dataDiskCount": {
      "type": "int",
      "defaultValue": 8,
      "metadata": {
        "description": "Number of Data Disks per VM to deploy. Ensure you attach enough Disk to handle the driveConfig Paramater."
      }
    },
    "dataDiskSizeGB": {
      "type": "string",
      "defaultValue": "1024",
      "metadata": {
        "description": "The Size of all the Data Disks in GB"
      }
    },
    "driveConfig": {
      "type": "string",
      "defaultValue": "-DriveString E:2,H:2,O:2,T:2 -ResiliencySetting simple -InterleaveValue 262144 -OSAllocationUnitSize 65536 -Verbose",
      "metadata": {
        "description": "Please provide the Drive onfiguration String as shown on the default value. DriveString is VolumeLetter:NumberOfDisks. The size of each VirtualDisk will be NumberOfDisks X dataDiskSizeGB"
      }
    },
    "virtualNetwork": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name for the VirtualNetwork"
      }
    },
    "vnetResourceGroup": {
      "type": "string",
      "defaultValue": "ERNetwork",
      "metadata": {
        "description": "Name for the Resource Group that contains VirtualNetwork"
      }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "Subnet-1",
      "metadata": {
        "description": "Name for the subnet"
      }
    },
    "bootDiagnosysStorageAccountName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "bootDiagnosticsResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Boot Diagnosys Storage Account Resource Group Name"
      }
    },
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "workspaceResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics Resource Group Name"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the KeyVault to place the volume encryption key"
      }
    },
    "keyVaultResourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group of the KeyVault"
      }
    },
    "isFirstDeployment": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Select whether this is the first Deployment or not."
      }
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/",
    "scriptsTemplatePath": "/Scripts/",
    "vmsConfigPath": "/VirtualMachinesConfig/"
  },
  "resources": [
    {
      "condition": "[parameters('isFirstDeployment')]",
      "apiVersion": "2016-04-30-preview",
      "type": "Microsoft.Compute/availabilitySets",
      "name": "[parameters('availabilitySetName')]",
      "location": "[parameters('vmRegion')]",
      "tags": {
        "displayName": "AvailabilitySet"
      },
      "properties": {
        "platformFaultDomainCount": "[if(greater(parameters('numberOfInstances'),5),3,2)]",
        "platformUpdateDomainCount": 10,
        "managed": true
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "CreateVirtualMachinesLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat('Microsoft.Compute/availabilitySets/', parameters('availabilitySetName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[concat(parameters('armTemplateURI'), variables('baseTemplatePath') ,'template-virtualMachine.json', parameters('armTemplatesSasToken'))]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "userAssignedIdentityResourceId": {
            "value": "[parameters('userAssignedIdentityResourceId')]"
          },
          "AvailabilitySetName": {
            "value": "[parameters('availabilitySetName')]"
          },
          "localAdminUserName": {
            "value": "[parameters('localAdminUserName')]"
          },
          "localAdminPassword": {
            "value": "[parameters('localAdminPassword')]"
          },
          "vmOwnerAccount": {
            "value": "[parameters('vmOwnerAccount')]"
          },
          "vmSize": {
            "value": "[parameters('vmSize')]"
          },
          "AcceleratedNetworking": {
            "value": "[parameters('AcceleratedNetworking')]"
          },
          "imagePublisher": {
            "value": "[parameters('imagePublisher')]"
          },
          "imageOffer": {
            "value": "[parameters('imageOffer')]"
          },
          "StorageAccountType": {
            "value": "[parameters('StorageAccountType')]"
          },
          "sku": {
            "value": "[parameters('sku')]"
          },
          "osDiskSizeGB": {
            "value": "[parameters('osDiskSizeGB')]"
          },
          "dataDiskCount": {
            "value": "[parameters('dataDiskCount')]"
          },
          "dataDiskSizeGB": {
            "value": "[parameters('dataDiskSizeGB')]"
          },
          "virtualNetwork": {
            "value": "[parameters('virtualNetwork')]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('vnetResourceGroup')]"
          },
          "subnetName": {
            "value": "[parameters('subnetName')]"
          },
          "bootDiagnosysStorageAccountName": {
            "value": "[parameters('bootDiagnosysStorageAccountName')]"
          },
          "bootDiagnosticsResourceGroupName": {
            "value": "[parameters('bootDiagnosticsResourceGroupName')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureStoragePools')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "ConfigureStoragePoolsLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[concat(parameters('armTemplateURI'), variables('baseTemplatePath') ,'VMExtensions/template-vm-extension-ps-script.json', parameters('armTemplatesSasToken'))]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "powershellFileName": {
            "value": "ConfigureStoragePools.ps1"
          },
          "powershellParameters": {
            "value": "[parameters('driveConfig')]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath') ,'ConfigureStoragePools.ps1', parameters('armTemplatesSasToken'))]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-BaseConfig')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[concat('Microsoft.Resources/deployments/',parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-ConfigureStoragePools')]"
      ],
      "copy": {
        "name": "ConfigureVirtualMachinesLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[concat(parameters('armTemplateURI'), variables('vmsConfigPath'), 'template-vm-baseConfiguration.json', parameters('armTemplatesSasToken'))]"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "templatespecsBaseResourceId": {
            "value": "[parameters('templatespecsBaseResourceId')]"
          },
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "AcceleratedNetworking": {
            "value": "[parameters('AcceleratedNetworking')]"
          },
          "virtualNetwork": {
            "value": "[parameters('virtualNetwork')]"
          },
          "IpAddress": {
            "value": "[reference(concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-CreateVirtualMachine')).outputs.ipAddress.value]"
          },
          "vnetResourceGroup": {
            "value": "[parameters('vnetResourceGroup')]"
          },
          "subnetName": {
            "value": "[parameters('subnetName')]"
          },
          "workspaceName": {
            "value": "[parameters('workspaceName')]"
          },
          "workspaceResourceGroupName": {
            "value": "[parameters('workspaceResourceGroupName')]"
          },
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          },
          "keyVaultResourceGroup": {
            "value": "[parameters('keyVaultResourceGroupName')]"
          },
          "isFirstDeployment": {
            "value": "[parameters('isFirstDeployment')]"
          },
          "diagnosticsStorageAccountName": {
            "value": "[parameters('bootDiagnosysStorageAccountName')]"
          },
          "diagnosticsResourceGroupName": {
            "value": "[parameters('bootDiagnosticsResourceGroupName')]"
          }
        }
      }
    }
  ]
}