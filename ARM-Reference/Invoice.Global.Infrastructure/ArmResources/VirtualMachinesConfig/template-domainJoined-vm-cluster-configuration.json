{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "armTemplatesSasToken": {
      "type": "string"
    },
    "armTemplateURI": {
      "type": "string",
      "metadata": {
        "description": "The Url of the storage account and Container where your Resources are stored"
      }
    },
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "vmName": {
      "type": "string",
      "minLength": 3,
      "metadata": {
        "description": "Name for the Virtual Machine."
      }
    },
    "ListenerName": {
      "type": "string",
      "metadata": {
        "description": "Listener Name"
      }
    },
    "vmRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Number of VMs to deploy"
      }
    },
    "loadBalancerName": {
      "type": "string",
      "metadata": {
        "description": "The Name of the Load Balancer"
      }
    },
    "lbFrontendPort": {
      "type": "int",
      "defaultValue": 1433,
      "metadata": {
        "description": "Load balancer Frontend port"
      }
    },
    "lbBackendPort": {
      "type": "int",
      "defaultValue": 1433,
      "metadata": {
        "description": "Load balancer Backend port"
      }
    },
    "virtualNetworkName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name for the VirtualNetwork"
      }
    },
    "vnetResourceGroupName": {
      "type": "string",
      "defaultValue": "ERNetwork-DB",
      "metadata": {
        "description": "Name for the Resource Group that contains VirtualNetwork"
      }
    },
    "storageAccountSKU": {
      "type": "string",
      "defaultValue": "Standard_LRS",
      "allowedValues": [
        "Standard_LRS",
        "Standard_GRS",
        "Standard_RAGRS",
        "Standard_ZRS",
        "Premium_LRS",
        "Premium_ZRS",
        "Standard_GZRS",
        "Standard_RAGZRS"
      ],
      "metadata": {
        "description": "Specify the storage account type."
      }
    },
    "serviceAccount": {
      "minLength": 1,
      "type": "String",
      "defaultValue": "redmond\\mssoadev",
      "metadata": {
        "description": "Account for domain joining, ex. redmond\\serviceaccount"
      }
    },
    "serviceAccountPassword": {
      "minLength": 1,
      "type": "SecureString",
      "metadata": {
        "description": "Password for domain joining"
      }
    },
    "backEndIpAddresses": {
      "type": "array",
      "metadata": {
        "description": "An Array with all the IP addresses that will be part of the Load Balancer"
      }
    },
    "isFirstDeployment": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Select whether this is the first Deployment or not."
      }
    },
    "isS2DCluster": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "This Flag is only used to create S2D Cluster. If you want to create an S2D Cluster look at component Domain Servers as sample otherwise leave this as No its default value"
      }
    },
    "isHALoadBalancer": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "This Flag is used decide if the load balancer is HA, has all ports available or specific ports are open"
      }
    },
    "driveConfig": {
      "type": "String",
      "defaultValue": "-DriveString E:200,O:200,T:200,H:200,M:100 -OSAllocationUnitSize 65536",
      "metadata": {
        "description": "DriveString Is composed of the Drive letter plus the size of the Virtual Disk in GB, OSAllocationUnitSize is the way the drive will be formatted"
      }
    },
    "AcceleratedNetworking": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Accelerated Networking can only be enabled on supported SKUs.  See https://docs.microsoft.com/en-us/azure/virtual-network/create-vm-accelerated-networking-powershell for details."
      }
    }
  },
  "variables": {
    "deploymentDriver": false,
    "baseTemplatePath": "/BaseTemplates/",
    "scriptsTemplatePath": "/Scripts/",
    "vnetID": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',parameters('vnetResourceGroupName'),'/providers/Microsoft.Network/virtualnetworks/',parameters('virtualNetworkName'))]",
    "subnetName": "Subnet-1",
    "subnetRef": "[concat(variables('vnetId'), '/subnets/', variables('subnetName'))]",
    "witnessStorageAccountName": "[tolower(concat(parameters('vmName'), 'witness'))]",
    "networkAclIpRules": [
      {
        "comment": "SAW Range IPv4 (legacy) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "207.68.190.32/27"
      },
      {
        "comment": "SAW Range IPv4 range (E3+) from https://microsoft.sharepoint.com/sites/Security_Tools_Services/SitePages/SAS/SAW%20KB/SAW-datacenter-IP-ranges.aspx",
        "value": "157.58.216.64/26"
      }
    ]
  },
  "resources": [
    {
      "name": "witnessStorageAccount",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'StorageAccount-template-storageAccount', '/versions/v1')]"
        },
        "parameters": {
          "storageAccountName": {
            "value": "[variables('witnessStorageAccountName')]"
          },
          "storageSKU": {
            "value": "[if(contains(tolower(parameters('vmName')),'prd'),'Standard_GRS','Standard_LRS')]"
          },
          "networkAclDefaultAction": {
            "value": "[if(parameters('isFirstDeployment'),'Allow','Deny')]"
          },
          "networkAclIpRules": {
            "value": "[variables('networkAclIpRules')]"
          }
        }
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-InstallClusterFeature')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "copy": {
        "name": "InstallClusterFeatureLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-clusterFeature', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[parameters('isHALoadBalancer')]",
      "name": "[toupper(concat(parameters('loadBalancerName'),'HA'))]",
      "apiVersion": "2017-08-01",
      "type": "Microsoft.Network/loadBalancers",
      "location": "[parameters('vmRegion')]",
      "sku": {
        "name": "Standard"
      },
      "dependsOn": [
      ],
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "LoadBalancerFrontEnd",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[variables('subnetRef')]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "BackendPool1"
          }
        ],
        "loadBalancingRules": [
          {
            "properties": {
              "frontendIPConfiguration": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', concat(parameters('loadBalancerName'),'HA')), '/frontendIPConfigurations/LoadBalancerFrontend')]"
              },
              "backendAddressPool": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', concat(parameters('loadBalancerName'),'HA')), '/backendAddressPools/BackendPool1')]"
              },
              "probe": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', concat(parameters('loadBalancerName'),'HA')), '/probes/lbprobe')]"
              },
              "protocol": "All",
              "frontendPort": 0,
              "backendPort": 0,
              "idleTimeoutInMinutes": 4,
              "enableFloatingIP": true,
              "enableTcpReset": false,
              "loadDistribution": "Default",
              "disableOutboundSnat": false
            },
            "name": "lbrule"
          }
        ],
        "probes": [
          {
            "properties": {
              "protocol": "Tcp",
              "port": 50001,
              "intervalInSeconds": 15,
              "numberOfProbes": 2
            },
            "name": "lbprobe"
          }
        ]
      }
    },
    {
      "condition": "[not(parameters('isHALoadBalancer'))]",
      "name": "[toupper(parameters('loadBalancerName'))]",
      "apiVersion": "2017-08-01",
      "type": "Microsoft.Network/loadBalancers",
      "location": "[parameters('vmRegion')]",
      "sku": {
        "name": "Standard"
      },
      "dependsOn": [
      ],
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "LoadBalancerFrontEnd",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[variables('subnetRef')]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "BackendPool1"
          }
        ],
        "loadBalancingRules": [
          {
            "properties": {
              "frontendIPConfiguration": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/frontendIPConfigurations/LoadBalancerFrontend')]"
              },
              "backendAddressPool": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/backendAddressPools/BackendPool1')]"
              },
              "probe": {
                "id": "[concat(resourceId('Microsoft.Network/loadBalancers', parameters('loadBalancerName')), '/probes/lbprobe')]"
              },
              "protocol": "Tcp",
              "frontendPort": "[parameters('lbFrontendPort')]",
              "backendPort": "[parameters('lbBackendPort')]",
              "enableFloatingIP": true,
              "loadDistribution": "SourceIPProtocol",
              "idleTimeoutInMinutes": 15
            },
            "name": "lbrule"
          }
        ],
        "probes": [
          {
            "properties": {
              "protocol": "Tcp",
              "port": 50001,
              "intervalInSeconds": 15,
              "numberOfProbes": 2
            },
            "name": "lbprobe"
          }
        ]
      }
    },
    {
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-SetBackendPool')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "[parameters('loadBalancerName')]",
        "[toupper(concat(parameters('loadBalancerName'),'HA'))]"
      ],
      "copy": {
        "name": "BackendLoop",
        "count": "[parameters('numberOfInstances')]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VirtualMachine-template-ilb-backendpool', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "lbID": {
            "value": "[resourceId('Microsoft.Network/loadBalancers',if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName')))]"
          },
          "nicName": {
            "value": "[concat(parameters('vmName'),copyindex(1))]"
          },
          "AcceleratedNetworking": {
            "value": "[parameters('AcceleratedNetworking')]"
          },
          "ipAddress": {
            "value": "[parameters('backEndIpAddresses')[copyIndex()]]"
          },
          "subnetRef": {
            "value": "[variables('subnetRef')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "name": "[concat(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName')),'-ConvertILBToStatic')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "BackendLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VirtualMachine-template-ilb-staticIP', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "loadBalancerName": {
            "value": "[if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName'))]"
          },
          "subnetRef": {
            "value": "[variables('subnetRef')]"
          },
          "ipaddress": {
            "value": "[reference(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName'))).frontendIPConfigurations[0].properties.privateIPAddress]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[and(not(parameters('isS2DCluster')),parameters('isFirstDeployment'))]",
      "name": "[concat(parameters('vmName'),'-ClusterAOAGSetup')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "witnessStorageAccount",
        "InstallClusterFeatureLoop",
        "[parameters('loadBalancerName')]",
        "BackendLoop",
        "[concat(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName')),'-ConvertILBToStatic')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-sql-aoag', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "AOAGListenerName": {
            "value": "[parameters('ListenerName')]"
          },
          "numberOfInstances": {
            "value": "[parameters('numberOfInstances')]"
          },
          "serviceAccount": {
            "value": "[parameters('serviceAccount')]"
          },
          "serviceAccountPassword": {
            "value": "[parameters('serviceAccountPassword')]"
          },
          "storageAccountName": {
            "value": "[variables('witnessStorageAccountName')]"
          },
          "witnessSaAccessKey": {
            "value": "[listKeys(concat(resourceGroup().id,'/providers/','Microsoft.Storage/storageAccounts/', variables('witnessStorageAccountName')),'2019-04-01').keys[0].value]"
          },
          "ILBStaticIP": {
            "value": "[reference(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName'))).frontendIPConfigurations[0].properties.privateIPAddress]"
          },
          "powershellFileName": {
            "value": "Clusteraoagsetup.ps1"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath') ,'Clusteraoagsetup.ps1', parameters('armTemplatesSasToken'))]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[and(parameters('isS2DCluster'),parameters('isFirstDeployment'))]",
      "name": "[concat(parameters('vmName'),'-CreateCluster')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "witnessStorageAccount",
        "InstallClusterFeatureLoop",
        "[parameters('loadBalancerName')]",
        "[toupper(concat(parameters('loadBalancerName'),'HA'))]",
        "BackendLoop",
        "[concat(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName')),'-ConvertILBToStatic')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-s2d-cluster', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "numberOfInstances": {
            "value": "[parameters('numberOfInstances')]"
          },
          "driveConfig": {
            "value": "[parameters('driveConfig')]"
          },
          "serviceAccount": {
            "value": "[parameters('serviceAccount')]"
          },
          "serviceAccountPassword": {
            "value": "[parameters('serviceAccountPassword')]"
          },
          "storageAccountName": {
            "value": "[variables('witnessStorageAccountName')]"
          },
          "witnessSaAccessKey": {
            "value": "[listKeys(concat(resourceGroup().id,'/providers/','Microsoft.Storage/storageAccounts/', variables('witnessStorageAccountName')),'2019-04-01').keys[0].value]"
          },
          "powershellFileName": {
            "value": "CreateCluster.ps1"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath') ,'CreateCluster.ps1', parameters('armTemplatesSasToken'))]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    },
    {
      "condition": "[and(parameters('isS2DCluster'),parameters('isFirstDeployment'))]",
      "name": "[concat(parameters('vmName'),'-ClusterS2DStorage')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "witnessStorageAccount",
        "InstallClusterFeatureLoop",
        "[parameters('loadBalancerName')]",
        "[toupper(concat(parameters('loadBalancerName'),'HA'))]",
        "BackendLoop",
        "[concat(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName')),'-ConvertILBToStatic')]",
        "[concat(parameters('vmName'),'-CreateCluster')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'VMExtensions-template-vm-extension-ps-script-with-secret', '/versions/v1')]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),'1')]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          },
          "powershellFileName": {
            "value": "CreateClusterS2DStorage.ps1"
          },
          "powershellParameters": {
            "value": "[concat( '-ClusterSetupAccount ',parameters('serviceAccount'),
                               ' ', parameters('driveConfig'))]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath') ,'CreateClusterS2DStorage.ps1', parameters('armTemplatesSasToken'))]"
          },
          "secretParameterName": {
            "value": "ClusterSetupPassword"
          },
          "secretParameterValue": {
            "value": "[parameters('serviceAccountPassword')]"
          }
        }
      }
    },
    {
      "name": "createWitnessSaPvtEndPts",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
        "witnessStorageAccount",
        "[concat(parameters('vmName'),'-CreateCluster')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'factory-private-endpoints', '/versions/v1')]"
        },
        "parameters": { 
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "privateEndpointsDetails": {
            "value": [
              {
                "resourceName": "[variables('witnessStorageAccountName')]",
                "resourceGroupName": "[resourceGroup().name]",
                "privateLinkServiceId": "[concat('/subscriptions/',subscription().subscriptionId,'/resourceGroups/',resourceGroup().name,'/providers/Microsoft.Storage/storageAccounts/',variables('witnessStorageAccountName'))]",
                "virtualNetworkId": "[variables('vnetID')]",
                "virtualNetworkSubnetName": "[variables('subnetName')]",
                "serviceGroupNames": [ "blob" ],
                "location": "[resourceGroup().location]",
                "networkResourceGroupName": "N/A",
                "privateDNSZoneName": "N/A"
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "ILBStaticIP": {
      "type": "string",
      "value": "[reference(if(parameters('isHALoadBalancer'),concat(parameters('loadBalancerName'),'HA'),parameters('loadBalancerName'))).frontendIPConfigurations[0].properties.privateIPAddress]"
    }
  }
}
