{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "armTemplatesSasToken": {
      "type": "string"
    },
    "armTemplateURI": {
      "type": "string",
      "metadata": {
        "description": "The Url of the storage account and Container where your Resources are stored"
      }
    },
    "vmName": {
      "type": "string"
    },
    "vmRegion": {
      "minLength": 3,
      "type": "String",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": [
        "[resourceGroup().location]",
        "eastus",
        "eastus2",
        "centralus",
        "northcentralus",
        "southcentralus",
        "southeastasia",
        "westcentralus",
        "westeurope",
        "northeurope",
        "westus",
        "westus2"
      ],
      "metadata": {
        "description": ""
      }
    },
    "numberOfInstances": {
      "type": "int",
      "metadata": {
        "description": "The Number of Virtual Machine Instances."
      }
    },
    "listenerNamePostFix": {
      "type": "string",
      "metadata": {
        "description": "This will be the last letters at the end of the vmbasename"
      }
    },
    "SQLServerAccount": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Account for SQL Server"
      }
    },
    "SQLServerPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for SQL Server"
      }
    },
    "SQLSysAdmins": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "A list of accounts separated by a comma that need to be added as SysAdmins in SQL"
      }
    },
    "sqlImageOffer": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "The Iso will be named as the SQL ImageOffer Property"
      }
    },
    "ILBStaticIP": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "The Static Ip of the load balancer in front of the cluster. This should be optained from an output of the Load Balancer Resource Creation"
      }
    },
    "isFirstDeployment": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Select whether this is the first Deployment or not."
      }
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/",
    "scriptsTemplatePath": "/Scripts/",
    "installersPath": "/Installers/",
    "installersURI": "[concat(parameters('armTemplateURI'), variables('installersPath'))]",
    "listenerName": "[concat(parameters('vmName'),toupper(parameters('listenerNamePostFix')))]"
  },
  "resources": [
    {
      "condition": "[parameters('isFirstDeployment')]",
      "name": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)),'-InstallSQLServerOnS2DCluster')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "copy": {
        "name": "InstallSQLOnS2DLoop",
        "count": "[parameters('numberOfInstances')]",
        "mode": "Serial"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[concat(parameters('armTemplateURI'), variables('baseTemplatePath'), 'VMExtensions/template-vm-extension-ps-script-with-secret.json',  parameters('armTemplatesSasToken'))]"
        },
        "parameters": {
          "vmName": {
            "value": "[concat(parameters('vmName'),if(equals(parameters('numberOfInstances'),1),'1', copyindex(1)))]"
          },
          "powershellFileName": {
            "value": "DeploySQLS2DCluster.ps1"
          },
          "powershellParameters": {
            "value": "[concat(' -VMName ', parameters('vmName'), ' -ILBStaticIP ', parameters('ILBStaticIP'), ' -ListenerName ', variables('listenerName'), ' -InstallerURI ', variables('installersURI'), ' -sqlImageOffer ',parameters('sqlImageOffer'),' -ClusterSetupAccount ',parameters('SQLServerAccount'),' -sysAdmins ','\"',parameters('SQLSysAdmins'),'\"',' -SASToken ','\"', parameters('armTemplatesSasToken'),'\"')]"
          },
          "secretParameterName": {
            "value": "ClusterSetupPassword"
          },
          "secretParameterValue": {
            "value": "[parameters('SQLServerPassword')]"
          },
          "powershellFileBlobUrl": {
            "value": "[concat(parameters('armTemplateURI'), variables('scriptsTemplatePath'), 'DeploySQLS2DCluster.ps1', parameters('armTemplatesSasToken'))]"
          },
          "location": {
            "value": "[parameters('vmRegion')]"
          }
        }
      }
    }
  ]
}