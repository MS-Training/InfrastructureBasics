{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "armTemplatesSasToken": {
      "type": "string"
    },
    "armTemplateURI": {
      "type": "string",
      "metadata": {
        "description": "The Url of the storage account and Container where your Resources are stored"
      }
    },
    "templatespecsBaseResourceId": {
      "type": "string"
    },
    "vmName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing VM to apply the DSC configuration to"
      }
    },
    "SQLDiskConfig": {
      "type": "string",
      "metadata": {
        "description": "IIS/SQLStd, SQLPrem/Win"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_A2"
    },
    "SQLServerAccount": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Account for SQL Server"
      }
    },
    "SQLServerPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for SQL Server"
      }
    },
    "SQLAgentAccount": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Account for SQL Agent"
      }
    },
    "SQLAgentPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password for SQL Agent"
      }
    },
    "SQLAdmin": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Account for SQL Acccess"
      }
    },
    "SQLAdminPwd": {
      "type": "securestring",
      "metadata": {
        "description": "Password for SQL Access"
      }
    },
    "vmRegion": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "setSQLServiceAccount": {
      "type": "bool",
      "defaultValue": true
    }
  },
  "variables": {
    "baseTemplatePath": "/BaseTemplates/"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "name": "[concat(parameters('vmName'),'-BuildMachineRole-SQL')]",
      "apiVersion": "2020-06-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('templatespecsBaseResourceId'), 'Scripts-template-BuildSQL', '/versions/v1')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "armTemplatesSasToken": {
            "value": "[parameters('armTemplatesSasToken')]"
          },
          "armTemplateURI": {
            "value": "[parameters('armTemplateURI')]"
          },
          "vmName": {
            "value": "[parameters('vmName')]"
          },
          "DiskConfig": {
            "value": "[parameters('SQLDiskConfig')]"
          },
          "vmSize": {
            "value": "[parameters('vmSize')]"
          },
          "SQLServerAccount": {
            "value": "[parameters('SQLServerAccount')]"
          },
          "SQLServerPassword": {
            "value": "[parameters('SQLServerPassword')]"
          },
          "SQLAgentAccount": {
            "value": "[parameters('SQLAgentAccount')]"
          },
          "SQLAgentPassword": {
            "value": "[parameters('SQLAgentPassword')]"
          },
          "SQLAdmin": {
            "value": "[parameters('SQLAdmin')]"
          },
          "SQLAdminPwd": {
            "value": "[parameters('SQLAdminPwd')]"
          },
          "vmRegion": {
            "value": "[parameters('vmRegion')]"
          },
          "setSQLServiceAccount": {
            "value": "[parameters('setSQLServiceAccount')]"
          }
        }
      }
    }
  ]
}