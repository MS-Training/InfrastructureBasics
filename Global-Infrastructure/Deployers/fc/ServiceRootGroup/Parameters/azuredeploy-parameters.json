{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploymentFlags": {
            "value": {
                "comment": "Deployment flags to control which resources are deployed",
                "deployFrontDoor": false
            }
        },
        "settings": {
            "value": {
                "resourceTag": {
                    "resourceGroup": "rg",
                    "storageAccount": "st",
                    "frontDoor": "fd",
                    "virtualNetwork": "vnet",
                    "subnet": "subnet",
                    "networkSecurityGroup": "nsg"
                },
                "organizationTag": "fc",
                "environment": "dev",
                "location": "eastus",
                "managedBy": "Global-Infrastructure-Framework",
                "standardTags": {
                    "Team": "FullCode",
                    "Project": "Global-Infrastructure",
                    "Environment": "Development"
                },
                "Network": {
                    "ResourceGroup": {
                        "comment": "Settings for the Network Resource Group",
                        "name": "fullcodenetwork"
                    },
                    "FrontDoor": {
                        "comment": "Base Module settings for FrontDoor Deployment",
                        "parameterComments": "Basic Front Door settings to setup Front Door Standard/Premium without any custom endpoints or rules.",
                        "location": "Global",
                        "profileName": "fullcodeservices",
                        "enableRequestBodyCheck": true,
                        "sku": {
                            "name": "Premium_AzureFrontDoor"
                        },
                        "endpoint": {
                            "name": "fullcodeservices",
                            "properties": {
                                "enabledState": "Enabled",
                                "autoGeneratedDomainNameLabelScope": "TenantReuse"
                            }
                        },
                        "properties": {
                            "originResponseTimeoutSeconds": 120
                        }
                    },
                    "VirtualNetwork": {
                        "Properties": {
                            "name": "fullcode",
                            "extendedLocation": {},
                            "addressSpaces": [
                                "10.0.0.0/16"
                            ],
                            "ddosProtectionPlanEnabled": false,
                            "privateEndpointVNetPolicies": "Enabled",
                            "defaultServiceEndpoints": [
                                {
                                    "service": "Microsoft.AzureActiveDirectory"
                                },
                                {
                                    "service": "Microsoft.AzureCosmosDB"
                                },
                                {
                                    "service": "Microsoft.CognitiveServices"
                                },
                                {
                                    "service": "Microsoft.ContainerRegistry"
                                },
                                {
                                    "service": "Microsoft.EventHub"
                                },
                                {
                                    "service": "Microsoft.KeyVault"
                                },
                                {
                                    "service": "Microsoft.ServiceBus"
                                },
                                {
                                    "service": "Microsoft.Sql"
                                },
                                {
                                    "service": "Microsoft.Storage"
                                },
                                {
                                    "service": "Microsoft.Web"
                                }
                            ],
                            "subNets": [
                                {
                                    "name": "application",
                                    "addressRange": "10.0.0.0/22",
                                    "networkSecurityGroup": {
                                        "comment": "The network security group name should correspond to the Subnet that will be assigned to its usage. Example Subnet00 would have an nsg called nsgSubnet00",
                                        "name": "applicationsg",
                                        "RuleList": [
                                            {
                                                "name": "AllowHTTPS",
                                                "description": "Allow HTTPS traffic",
                                                "direction": "Inbound",
                                                "priority": 100,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "443",
                                                "access": "Allow",
                                                "protocol": "Tcp"
                                            },
                                            {
                                                "name": "AllowHTTP",
                                                "description": "Allow HTTP traffic",
                                                "direction": "Inbound",
                                                "priority": 110,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "80",
                                                "access": "Allow",
                                                "protocol": "Tcp"
                                            },
                                            {
                                                "name": "AllowSSH",
                                                "description": "Allow SSH from VNet only",
                                                "direction": "Inbound",
                                                "priority": 120,
                                                "sourceAddressPrefix": "VirtualNetwork",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "22",
                                                "access": "Allow",
                                                "protocol": "Tcp"
                                            },
                                            {
                                                "name": "AllowAzureLoadBalancer",
                                                "description": "Allow Azure Load Balancer health probes",
                                                "direction": "Inbound",
                                                "priority": 130,
                                                "sourceAddressPrefix": "AzureLoadBalancer",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "*",
                                                "access": "Allow",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "DenyInternetOutbound",
                                                "description": "Deny direct internet outbound traffic",
                                                "direction": "Outbound",
                                                "priority": 4000,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "Internet",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "*",
                                                "access": "Deny",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "BlockAll",
                                                "description": "block all traffic except what we've explicitly allow",
                                                "direction": "Inbound",
                                                "priority": 4095,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "3389",
                                                "access": "Deny",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "VNetRDP",
                                                "description": "Allow RDP within the net",
                                                "direction": "Inbound",
                                                "priority": 3960,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "3389-4500",
                                                "access": "Deny",
                                                "protocol": "*"
                                            }
                                        ]
                                    }
                                },
                                {
                                    "name": "data",
                                    "addressRange": "10.0.4.0/22",
                                    "networkSecurityGroup": {
                                        "comment": "The network security group name should correspond to the Subnet that will be assigned to its usage. Example Subnet00 would have an nsg called nsgSubnet00",
                                        "name": "datasg",
                                        "RuleList": [
                                            {
                                                "name": "AllowSQL",
                                                "description": "Allow SQL traffic from application subnet",
                                                "direction": "Inbound",
                                                "priority": 100,
                                                "sourceAddressPrefix": "10.0.0.0/22",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "1433",
                                                "access": "Allow",
                                                "protocol": "Tcp"
                                            },
                                            {
                                                "name": "AllowCosmosDB",
                                                "description": "Allow CosmosDB traffic",
                                                "direction": "Inbound",
                                                "priority": 110,
                                                "sourceAddressPrefix": "10.0.0.0/22",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "443",
                                                "access": "Allow",
                                                "protocol": "Tcp"
                                            },
                                            {
                                                "name": "AllowAzureLoadBalancer",
                                                "description": "Allow Azure Load Balancer health probes",
                                                "direction": "Inbound",
                                                "priority": 120,
                                                "sourceAddressPrefix": "AzureLoadBalancer",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "*",
                                                "access": "Allow",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "DenyInternetOutbound",
                                                "description": "Deny direct internet outbound traffic",
                                                "direction": "Outbound",
                                                "priority": 4000,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "Internet",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "*",
                                                "access": "Deny",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "BlockAll",
                                                "description": "block all traffic except what we've explicitly allow",
                                                "direction": "Inbound",
                                                "priority": 4095,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "3389",
                                                "access": "Deny",
                                                "protocol": "*"
                                            },
                                            {
                                                "name": "VNetRDP",
                                                "description": "Allow RDP within the net",
                                                "direction": "Inbound",
                                                "priority": 3960,
                                                "sourceAddressPrefix": "*",
                                                "destinationAddressPrefix": "*",
                                                "sourcePortRange": "*",
                                                "destinationPortRange": "3389-4500",
                                                "access": "Deny",
                                                "protocol": "*"
                                            }
                                        ]
                                    }
                                }
                            ]
                        }
                    }
                },
                "TemplateSpec": {
                    "ResourceGroup": {
                        "comment": "Settings for the Template Spec Resource Group",
                        "name": "templatespec"
                    }
                },
                "StorageAccounts": {
                    "NetworkStorageAccount": {
                        "comment": "The default Storage Account used for general purposes",
                        "name": "network",
                        "kind": "StorageV2",
                        "location": "eastus",
                        "properties": {
                            "allowSharedKeyAccess": false,
                            "supportsHttpsTrafficOnly": true,
                            "minimumTlsVersion": "TLS1_2",
                            "allowBlobPublicAccess": false,
                            "networkAcls": {
                                "defaultAction": "Deny",
                                "bypass": "AzureServices"
                            },
                            "isHnsEnabled": false,
                            "accessTier": "Hot"
                        },
                        "sku": {
                            "name": "Standard_LRS"
                        },
                        "BlobStorage": {
                            "name": "default",
                            "properties": {
                                "deleteRetentionPolicy": {
                                    "enabled": true,
                                    "days": 7
                                },
                                "containerDeleteRetentionPolicy": {
                                    "enabled": true,
                                    "days": 7
                                }
                            }
                        }
                    }
                },
                "KeyVaults": {
                    "comment": "Settings for Key Vaults used in the deployment",
                    "defaultKeyVault": {
                        "name": "fcdefaultkv",
                        "location": "eastus",
                        "sku": {
                            "name": "premium"
                        },
                        "properties": {
                            "enabledForDeployment": true,
                            "enabledForDiskEncryption": true,
                            "enabledForTemplateDeployment": true,
                            "enableRbacAuthorization": true,
                            "tenantId": "<your-tenant-id>"
                        }
                    }
                }
            }
        }
    }
}