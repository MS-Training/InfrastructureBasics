{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploymentFlags": {
            "value": {
                "comment": "Deployment flags to control which resources are deployed",
                "deployFrontDoor": true
            }
        },
        "settings": {
            "value": {
                "organizationTag": "fc",
                "environment": "dev",
                "location": "eastus",
                "managedBy": "Global-Infrastructure-Framework",
                "standardTags": {
                    "Team": "FullCode",
                    "Project": "Global-Infrastructure",
                    "Environment": "Development"
                },
                "Network": {
                    "ResourceGroup": {
                        "comment": "Settings for the Network Resource Group",
                        "name": "fullcodenetwork"
                    },
                    "addressPrefix": "10.0.0.0/16",
                    "FrontDoor": {
                        "comment": "Base Module settings for FrontDoor Deployment",
                        "parameterComments": "Basic Front Door settings to setup Front Door Standard/Premium without any custom endpoints or rules.",
                        "location": "Global",
                        "profileName": "fullcodeservices",
                        "enableRequestBodyCheck": true,
                        "sku": {
                            "name": "Premium_AzureFrontDoor"
                        },
                        "endpoint": {
                            "name": "fullcodeservices",
                            "properties": {
                                "enabledState": "Enabled",
                                "autoGeneratedDomainNameLabelScope": "TenantReuse"
                            }
                        },
                        "properties": {
                            "originResponseTimeoutSeconds": 120
                        }
                    }
                },
                "TemplateSpec": {
                    "ResourceGroup": {
                        "comment": "Settings for the Template Spec Resource Group",
                        "name": "templatespec"
                    }
                },
                "StorageAccounts": {
                    "NetworkStorageAccount": {
                        "comment": "The default Storage Account used for general purposes",
                        "name": "network",
                        "kind": "StorageV2",
                        "location": "eastus",
                        "properties": {
                            "allowSharedKeyAccess": false,
                            "supportsHttpsTrafficOnly": true,
                            "minimumTlsVersion": "TLS1_2",
                            "allowBlobPublicAccess": false,
                            "networkAcls": {
                                "defaultAction": "Deny",
                                "bypass": "AzureServices"
                            },
                            "isHnsEnabled": false,
                            "accessTier": "Hot"
                        },
                        "sku": {
                            "name": "Standard_LRS"
                        },
                        "BlobStorage": {
                            "name": "default",
                            "properties": {
                                "deleteRetentionPolicy": {
                                    "enabled": true,
                                    "days": 7
                                },
                                "containerDeleteRetentionPolicy": {
                                    "enabled": true,
                                    "days": 7
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}