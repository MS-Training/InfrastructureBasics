{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploymentFlags": {
            "value": {
                "comment": "Deployment flags to control which resources are deployed",
                "deployNetworkResourceGroup": true
            }
        },
        "settings": {
            "value": {
                "organizationTag": "fc",
                "environment": "dev",
                "location": "eastus",
                "managedBy": "Global-Infrastructure-Framework",
                "Network": {
                    "ResourceGroup": {
                        "comment": "Settings for the Network Resource Group",
                        "name": "fullcodenetwork",
                        "shouldDeploy": true
                    },
                    "addressPrefix": "10.0.0.0/16",
                    "FrontDoorCDN": {
                        "comment": "Settings for FrontDoor CDN",
                        "parameterComments": "",
                        "location": "Global",
                        "profileName": "fullcodeservices",
                        "wafPolicyName": "fd-waf-policy",
                        "wafMode": "Prevention",
                        "enableRequestBodyCheck": true,
                        "sku": {
                            "name": "Premium_AzureFrontDoor"
                        },
                        "endpoint": {
                            "name": "fullcodeservices",
                            "properties": {
                                "enabledState": "Enabled",
                                "autoGeneratedDomainNameLabelScope": "TenantReuse"
                            }
                        },
                        "originGroup": {
                            "name": "webapp-origin-group",
                            "loadBalancingSettings": {
                                "sampleSize": 4,
                                "successfulSamplesRequired": 3,
                                "additionalLatencyInMilliseconds": 50
                            },
                            "healthProbeSettings": {
                                "probePath": "/health",
                                "probeProtocol": "Https",
                                "probeRequestType": "GET",
                                "probeIntervalInSeconds": 30
                            },
                            "sessionAffinityState": "Disabled"
                        },
                        "origin": {
                            "name": "webapp-origin",
                            "properties": {
                                "hostName": "myapp.azurewebsites.net",
                                "httpPort": 80,
                                "httpsPort": 443,
                                "priority": 1,
                                "weight": 1000,
                                "originHostHeader": "myapp.azurewebsites.net",
                                "enabledState": "Enabled"
                            }
                        },
                        "route": {
                            "name": "default-route",
                            "originPath": "/",
                            "patternsToMatch": [
                                "/*"
                            ],
                            "supportedProtocols": [
                                "Http",
                                "Https"
                            ],
                            "forwardingProtocol": "HttpsOnly",
                            "httpsRedirect": "Enabled",
                            "linkToDefaultDomain": "Enabled"
                        },
                        "properties": {
                            "originResponseTimeoutSeconds": 120
                        }
                    }
                },
                "standardTags": {
                    "Team": "FullCode",
                    "Project": "Global-Infrastructure",
                    "Environment": "Development"
                }
            }
        }
    }
}