{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploymentFlags": {
            "value": {
                "comment": "Deployment flags to control which resources are deployed",
                "deployNetworkResourceGroup": true
            }
        },
        "settings": {
            "value": {
                "organizationTag": "fc",
                "environment": "dev",
                "location": "eastus",
                "managedBy": "Global-Infrastructure-Framework",
                "Network": {
                    "ResourceGroup": {
                        "comment": "Settings for the Network Resource Group",
                        "name": "FullCodeNetwork"
                    },
                    "addressPrefix": "10.0.0.0/16",
                    "FrontDoorCDN": {
                        "comment": "Settings for FrontDoor with WAF Module. Limit of 6 characters for Names.",
                        "parameterComments": "Please see module-network-frontdoor-waf.bicep for details.",
                        "location": "Global",
                        "profileName": "fullcodeservices",
                        "originGroupName": "webapp-origin-group",
                        "wafPolicyName": "fd-waf-policy",
                        "routeName": "default-route",
                        "originName": "webapp-origin",
                        "wafMode": "Prevention",
                        "enableRequestBodyCheck": true,
                        "sku": {
                            "name": "Premium_AzureFrontDoor"
                        },
                        "endpoint": {
                            "name": "fullcodeservices",
                            "properties": {
                                "enabledState": "Enabled"
                            }
                        },
                        "originConfig": {
                            "hostName": "myapp.azurewebsites.net",
                            "httpPort": 80,
                            "httpsPort": 443,
                            "priority": 1,
                            "weight": 1000,
                            "enabled": true
                        },
                        "healthProbeConfig": {
                            "probePath": "/health",
                            "probeProtocol": "Https",
                            "probeRequestType": "GET",
                            "probeIntervalInSeconds": 30
                        },
                        "routeConfig": {
                            "patternsToMatch": [
                                "/*"
                            ],
                            "supportedProtocols": [
                                "Http",
                                "Https"
                            ],
                            "forwardingProtocol": "HttpsOnly",
                            "httpsRedirect": "Enabled"
                        },
                        "properties": {
                            "originResponseTimeoutSeconds": 120
                        }
                    }
                },
                "standardTags": {
                    "Team": "FullCode",
                    "Project": "Global-Infrastructure",
                    "Environment": "Development"
                }
            }
        }
    }
}