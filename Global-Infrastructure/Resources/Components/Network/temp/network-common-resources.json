  "resources": [
    {
      "name": "[concat('CreatePublicIpPrefix-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2021-04-01",
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-publicIpPrefix', '/versions/v1')]"
        },
        "parameters": {
          "publicIpPrefixName": {
            "value": "[tolower(concat(parameters('resourceNames').publicIpPrefixBaseName,parameters('settings').common.tag))]"
          },
          "ipTagName": {
            "value": "[if(contains(toupper(parameters('resourceNames').environment),'PRD'),'APInvoiceServices','APInvoiceServicesTest')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          }
        }
      }
    },
    {
      "name": "[concat('CreateNATGateway-', parameters('date'))]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2021-04-01",
      "dependsOn": [
        "[concat('CreatePublicIpPrefix-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-natGateway', '/versions/v1')]"
        },
        "parameters": {
          "natGatewayName": {
            "value": "[variables('natGatewayName')]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          },
          "natGatewayProperties": {
            "value": {
              "idleTimeoutInMinutes": "4",
              "publicIpPrefixes": [
                {
                  "id": "[reference(concat('CreatePublicIpPrefix-', parameters('date'))).outputs.publicIpPrefixResourceId.value]"
                }
              ]
            }
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').commonNetwork.isFirstDeployment]",
