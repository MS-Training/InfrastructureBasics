    "nspResourceAssociations": [
      {
        "associationName": "[concat(parameters('resourceNames').keyVaultBaseName, parameters('settings').common.tag,'-nsplink')]",
        "privateLinkResourceId": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('resourceNames').commonResourceGroupName, '/providers/Microsoft.KeyVault/vaults/',concat(parameters('resourceNames').keyVaultBaseName, parameters('settings').common.tag))]"
      },
      {
        "associationName": "[concat(parameters('resourceNames').diagnosysStorageAccountName,'-nsplink')]",
        "privateLinkResourceId": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('resourceNames').commonResourceGroupName, '/providers/Microsoft.Storage/storageAccounts/',concat(parameters('resourceNames').diagnosysStorageAccountName))]"
      },
      {
        "associationName": "[concat(parameters('resourceNames').functionsStorageAccountName,'-nsplink')]",
        "privateLinkResourceId": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('resourceNames').commonResourceGroupName, '/providers/Microsoft.Storage/storageAccounts/',concat(parameters('resourceNames').functionsStorageAccountName))]"
      },
      {
        "associationName": "[concat(parameters('resourceNames').storageAccountBaseName,'global-nsplink')]",
