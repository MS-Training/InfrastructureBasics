          },
          "virtualNetworkAddressPrefix": {
            "value": "[parameters('settings').commonNetwork.virtualNetworkAddressPrefix]"
          },
          "location": {
            "value": "[parameters('settings').common.region]"
          }
        }
      }
    },
    {
      "comments": "IMPORTANT: This only runs when it is the first deployment, If you do enable this to run, ensure all callers of this file template-network-nsg-rules.json are deployed",
      "condition": "[parameters('settings').commonNetwork.isFirstDeployment]",
      "name": "[concat('createSubnetsNsgs-',parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsNsgsLoop')].subnetName)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "createSubnetsNsgsLoop",
        "count": "[length(parameters('settings').commonNetwork.subnets)]"
      },
      "dependsOn": [
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-nsg', '/versions/v1')]"
        },
        "parameters": {
          "subnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsNsgsLoop')].subnetName]"
          }
        }
      }
    },
    {
      "name": "[concat('createSubnet-',parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsLoop')].subnetName)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "createSubnetsLoop",
        "count": "[length(parameters('settings').commonNetwork.subnets)]",
        "mode": "Serial"
      },
      "dependsOn": [
        "[concat('CreateMainVirtualNetwork-', parameters('date'))]",
        "[concat('CreateNATGateway-', parameters('date'))]",
        "createSubnetsNsgsLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-subnet', '/versions/v1')]"
        },
        "parameters": {
          "virtualNetworkName": {
            "value": "[variables('virtualNetworkName')]"
          },
          "subnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsLoop')].subnetName]"
          },
          "natGatewayResourceId": {
            "value": "[reference(concat('CreateNATGateway-', parameters('date'))).outputs.natGatewayResourceId.value]"
          },
          "subnetAddressPrefix": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsLoop')].subnetAddressPrefix]"
          },
          "delegations": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsLoop')].delegations]"
          },
          "serviceEndpoints": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsLoop')].serviceEndpoints]"
          }
        }
      }
    },
    {
      "name": "[concat('createSubnetsRules-',parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsNsgRulesLoop')].subnetName)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "createSubnetsNsgRulesLoop",
        "count": "[length(parameters('settings').commonNetwork.subnets)]"
      },
      "dependsOn": [
        "createSubnetsNsgsLoop",
        "createSubnetsLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-nsg-rules', '/versions/v1')]"
        },
        "parameters": {
          "subnetName": {
            "value": "[parameters('settings').commonNetwork.subnets[copyIndex('createSubnetsNsgRulesLoop')].subnetName]"
          },
          "ruleDetailsList": {
            "value": "[variables('standardNsgRules')]"
          }
        }
      }
    },
    {
      "name": "[take(concat('createPrivateDNSZones-',variables('privateDNSZoneList')[copyIndex('createPrivateDNSZonesLoop')]),65)]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "createPrivateDNSZonesLoop",
        "count": "[length(variables('privateDNSZoneList'))]"
      },
      "dependsOn": [
        "[concat('CreateMainVirtualNetwork-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'Network-template-network-privateDNSZone', '/versions/v1')]"
        },
        "parameters": {
          "privateDNSZoneName": {
            "value": "[variables('privateDNSZoneList')[copyIndex('createPrivateDNSZonesLoop')]]"
          },
          "virtualNetworkResourceId": {
            "value": "[parameters('resourceNames').commonVirtualNetworkResourceId]"
          }
        }
      }
    },
    {
