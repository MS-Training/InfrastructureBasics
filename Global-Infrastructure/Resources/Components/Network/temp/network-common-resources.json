            "value": 60
          },
          "workSpaceResourceId": {
            "value": "[parameters('resourceNames').commonWorkSpaceResourceId]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').common.isPrimaryRegion]",
      "name": "[concat('Create-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorEndPointsLoop')].mainServiceName,'-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorEndPointsLoop')].serviceRoleName,'-FrontDoorEndPoint')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "CreateFrontDoorEndPointsLoop",
        "count": "[length(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration)]"
      },
      "dependsOn": [
        "[concat('CreateAzureFrontDoor-', parameters('date'))]"
