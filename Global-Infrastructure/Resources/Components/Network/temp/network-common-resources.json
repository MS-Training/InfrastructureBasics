      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-afdEndPoint', '/versions/v1')]"
        },
        "parameters": {
          "cdnProfileName": {
            "value": "[variables('cdnProfileName')]"
          },
          "afdEndPointName": {
            "value": "[tolower(concat(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorEndPointsLoop')].mainServiceName,parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorEndPointsLoop')].serviceRoleName,parameters('resourceNames').environment))]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').common.isPrimaryRegion]",
      "name": "[concat('Create-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorCustomDomainsLoop')].mainServiceName,'-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorCustomDomainsLoop')].serviceRoleName,'-FrontDoorCustomDomain')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "CreateFrontDoorCustomDomainsLoop",
        "count": "[length(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration)]"
      },
      "dependsOn": [
        "[concat('CreateAzureFrontDoor-', parameters('date'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-customDomain', '/versions/v1')]"
        },
        "parameters": {
          "cdnProfileName": {
            "value": "[variables('cdnProfileName')]"
          },
          "customDomainHostName": {
            "value": "[tolower(concat(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorCustomDomainsLoop')].mainServiceName,'.',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorCustomDomainsLoop')].serviceRoleName,'.',parameters('resourceNames').environment,'.',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorCustomDomainsLoop')].domainName))]"
          }
        }
      }
    },
    {
      "condition": "[parameters('settings').common.isPrimaryRegion]",
      "name": "[concat('Create-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorSecurityPolicyWAFLoop')].mainServiceName,'-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorSecurityPolicyWAFLoop')].serviceRoleName,'-FrontDoorCustomDomainWAF')]",
      "type": "Microsoft.Resources/deployments",
      "resourceGroup": "[parameters('resourceNames').commonNetworkResourceGroupName]",
      "apiVersion": "2022-09-01",
      "copy": {
        "name": "CreateFrontDoorSecurityPolicyWAFLoop",
        "count": "[length(parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration)]"
      },
      "dependsOn": [
        "[concat('CreateAzureFrontDoor-', parameters('date'))]",
        "[concat('CreateAzureFrontDoorWAFPolicy-', parameters('date'))]",
        "CreateFrontDoorCustomDomainsLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "id": "[concat(parameters('resourceNames').templatespecsBaseResourceId, 'CdnProfiles-template-cdn-profile-securityPolicies', '/versions/v1')]"
        },
        "parameters": {
          "profileName": {
            "value": "[variables('cdnProfileName')]"
          },
          "wafPolicyId": {
            "value": "[reference(concat('CreateAzureFrontDoorWAFPolicy-', parameters('date')), '2022-09-01').outputs.frontDoorWafId.value]"
          },
          "afdEndpoint": {
            "value": "[reference(concat('Create-',parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorSecurityPolicyWAFLoop')].mainServiceName,'-', parameters('settings').commonNetwork.frontDoorConfig.endPointsConfiguration[copyIndex('CreateFrontDoorSecurityPolicyWAFLoop')].serviceRoleName, '-FrontDoorCustomDomain')).outputs.afdCustomEndpoint.value]"
          }
        }
      }
